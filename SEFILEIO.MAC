;============================================================
; FILE:    SEFILEIO.MAC
; PROJECT: SEDIT - Screen Editor for CP/M 2.2
; VERSION: 1.0
; DATE:    1984-01-01
; AUTHOR: Claude Code and RetroTechReboot
;------------------------------------------------------------
; DESCRIPTION:
;   File I/O module. Provides FIOPEN and FISAVE using
;   BDOS sequential read/write and FCB management.
;   FIOPEN loads an existing file (or creates empty buffer
;   for a new name) into the current gap buffer.
;   FISAVE writes the current gap buffer back to disk,
;   renaming the old file to .BAK first.
;   FIPROMPT reads a filename from the status line.
;------------------------------------------------------------
; REVISION HISTORY:
;   1.0  1984-01-01  Initial release
;============================================================

;--- Imports ----------------------------------------------
        EXTRN   CURBDP          ; current buffer descriptor ptr
        EXTRN   INSMODE         ; insert/overwrite flag
        EXTRN   GBINIT          ; initialise gap buffer
        EXTRN   GBINSRT         ; insert char into buffer
        EXTRN   GBMVTOP         ; move cursor to file top
        EXTRN   SYNINIT         ; detect syntax mode from filename
        EXTRN   STATMSG         ; display status message
        EXTRN   ISLOAD          ; loading flag (for info bar)
        EXTRN   INFOBAR         ; update info bar
        EXTRN   OUTSTR          ; write $-string to console
        EXTRN   OUTCHAR         ; output one character
        EXTRN   CURGOTO         ; position cursor (B=row,C=col)
        EXTRN   VIMODE          ; virtual mode flag
        EXTRN   VAFLN           ; lines in AFTER temp
        EXTRN   VIOVFL          ; overflow flag
        EXTRN   VISAVALL        ; three-phase save
        EXTRN   VAFCB           ; AFTER temp FCB
        EXTRN   VTMPDRV         ; virtual temp file drive
        EXTRN   VAFEX           ; AFTER temp existence flag
        EXTRN   VIWBYT          ; write byte to output buffer
        EXTRN   VIWFCB          ; output FCB pointer
        EXTRN   VIOPOS          ; output buffer position
        EXTRN   VIFLUSH         ; flush output buffer
        EXTRN   VIGOTO          ; merge-split at target line
        EXTRN   RSTAT           ; runtime status row

;--- Exports ----------------------------------------------
        PUBLIC  FIOPEN          ; load file into buffer
        PUBLIC  FISAVE          ; save buffer to file
        PUBLIC  FIPROMPT        ; prompt for filename
        PUBLIC  FISAVFN         ; copy WRKFCB name to BD_FNAME
        PUBLIC  FISMOD          ; read BD_MODIF flag
        PUBLIC  WRKFCB          ; working FCB (for SEMENU)
        PUBLIC  FILNBUF         ; filename buffer
        PUBLIC  FIPARSN         ; parse filename with drive+user
        PUBLIC  FILUSR          ; file's user number (FFH=unset)
        PUBLIC  ORGUSR          ; original user number at startup
        PUBLIC  FISWUSR         ; switch to file's user area
        PUBLIC  FIRSTUSR        ; restore original user area

;=============================================================
; FIOPEN - Open a file and load it into the current buffer.
; Entry:  DE = address of a 36-byte FCB (CP/M default FCB
;              at 005CH or caller-built FCB).
;         CURBDP must be valid.
; Exit:   A = 0 on success, A = FFH on fatal error (file too big).
;         Buffer filled; BD_FNAME and BD_MODIF updated.
;         BD_MODIF = 0 (clean after load).
;         On error: status message displayed, buffer empty.
;         Regs: all clobbered.
;=============================================================
        INCLUDE SEDIT.INC

        CSEG

FIOPEN:
        ; If DE=0, WRKFCB already set by caller (e.g. FIPROMPT)
        MOV     A,D
        ORA     E
        JZ      FISKIP

        ; Copy FCB to our working copy
        LXI     H,WRKFCB
        MVI     B,FCB_SIZ
FICPY:  LDAX    D
        MOV     M,A
        INX     D
        INX     H
        DCR     B
        JNZ     FICPY

        ; Save filename from FCB bytes 1-11 into descriptor
FISKIP:
        CALL    FISAVFN

        ; Initialise gap buffer to empty
        CALL    FIBUFCLR

        ; Zero the FCB control fields (CR, EX, S2, RC)
        CALL    FIRCB0

        ; Switch to file's user area if specified
        CALL    FISWUSR

        ; Attempt to open the file
        LXI     D,WRKFCB
        MVI     C,BF_FOPEN
        CALL    BDOS
        INR     A               ; 0FFH -> 0 means not found
        JZ      FIOOPN          ; file does not exist - ok

        ; File opened; show loading indicator on info bar
        MVI     A,1
        STA     ISLOAD
        CALL    INFOBAR
        ; Show loading message on status row
        LXI     D,LDNGMSG
        CALL    STATMSG

        ; Initialise line/column tracking
        LXI     H,1
        SHLD    FILNUM          ; line number = 1
        XRA     A
        STA     FICOL           ; column = 0

FIRLP:
        ; Check if gap is getting too small for another record
        ; Gap size = GAPEN - GAPBG; if < 512, switch to overflow
        LHLD    CURBDP
        PUSH    H
        MVI     A,BD_GAPEN
        ADD     L
        MOV     L,A
        MVI     A,0
        ADC     H
        MOV     H,A
        MOV     E,M
        INX     H
        MOV     D,M             ; DE = GAPEN
        POP     H
        PUSH    D               ; save GAPEN
        PUSH    H
        MVI     A,BD_GAPBG
        ADD     L
        MOV     L,A
        MVI     A,0
        ADC     H
        MOV     H,A
        MOV     E,M
        INX     H
        MOV     D,M             ; DE = GAPBG
        POP     H
        POP     H               ; HL = GAPEN
        MOV     A,L
        SUB     E
        MOV     L,A
        MOV     A,H
        SBB     D               ; HL = gap size = GAPEN - GAPBG
        MOV     H,A
        ; Check if gap < 512 (high byte must be >= 2)
        MOV     A,H
        CPI     2
        JNC     FIRLPN          ; gap >= 512, continue normally
        ; Gap too small: switch to overflow mode
        JMP     FIOVFL

FIRLPN:
        LXI     D,DMABUF        ; set DMA to our buffer
        MVI     C,BF_SETDMA
        CALL    BDOS

        LXI     D,WRKFCB
        MVI     C,BF_FREAD      ; sequential read
        CALL    BDOS
        ORA     A
        JNZ     FIEOF           ; non-zero = EOF or error

        ; Store 128 bytes from DMA into gap buffer
        LXI     H,DMABUF
        MVI     B,RECSIZ
FISTLP: MOV     A,M
        CPI     CPMEOF          ; CP/M EOF marker?
        JZ      FIEOF
        CPI     0DH             ; CR?
        JZ      FICHR           ; insert without counting
        CPI     0AH             ; LF?
        JZ      FILF

        ; Regular character - check line width
        STA     FITMP           ; save original byte
        PUSH    H
        LXI     H,FICOL
        MOV     A,M             ; A = current column count
        CPI     MAXCOLS         ; already at max?
        JNC     FIWDPOP         ; line too wide (pop H)
        INR     M               ; increment column
        POP     H
        LDA     FITMP           ; restore original byte
        JMP     FICHR           ; insert the byte

FILF:   ; LF - reset column, increment line number
        PUSH    H
        XRA     A
        STA     FICOL
        LHLD    FILNUM
        INX     H
        SHLD    FILNUM
        POP     H
        MVI     A,LF            ; restore A to LF value

FICHR:  ; Insert byte into gap buffer
        PUSH    H               ; save DMA pointer
        PUSH    B               ; save loop counter
        CALL    GBINSRT
        POP     B               ; restore loop counter
        POP     H               ; restore DMA pointer
        INR     A               ; 0FFH -> 0 means buffer full
        JZ      FIFULL
        INX     H
        DCR     B
        JNZ     FISTLP
        JMP     FIRLP

FIFULL:
        ; Buffer full - close file, discard buffer, show error
        LXI     D,CMDTAIL
        MVI     C,BF_SETDMA
        CALL    BDOS
        LXI     D,WRKFCB
        MVI     C,BF_FCLOSE
        CALL    BDOS
        CALL    FIRSTUSR        ; restore original user area
        CALL    FIBUFCLR        ; reset gap buffer to empty
        XRA     A
        STA     ISLOAD          ; clear loading flag
        CALL    SYNINIT
        LXI     D,FULLMSG
        CALL    STATMSG
        MVI     A,0FFH          ; return error code
        RET

;------------------------------------------------------------
; FIOVFL - Switch to overflow mode during file load.
; Buffer is nearly full; remaining records go to AFTER temp.
; Entry:  WRKFCB still open for reading.
; Exit:   Falls through to FIEOF when source is exhausted.
;------------------------------------------------------------
FIOVFL:
        ; --- Trim partial line from end of gap buffer ---
        ; Scan backward from GAPBG to find last LF.
        ; Move bytes after the LF into FIOVFRAG for AFTER temp.
        XRA     A
        STA     FIOVFN          ; fragment length = 0

        ; Get buffer base address
        LHLD    CURBDP
        MVI     A,BD_BSTAR
        ADD     L
        MOV     L,A
        MVI     A,0
        ADC     H
        MOV     H,A
        MOV     E,M
        INX     H
        MOV     D,M             ; DE = buffer base

        ; Get GAPBG offset
        LHLD    CURBDP
        MVI     A,BD_GAPBG
        ADD     L
        MOV     L,A
        MVI     A,0
        ADC     H
        MOV     H,A
        MOV     A,M
        INX     H
        ORA     M               ; check GAPBG == 0
        JZ      FIOVT0          ; empty buffer, skip trim
        DCX     H
        MOV     C,M
        INX     H
        MOV     B,M             ; BC = GAPBG offset

        ; HL = base + GAPBG - 1 (last byte of pre-gap text)
        MOV     H,D
        MOV     L,E             ; HL = base
        DAD     B               ; HL = base + GAPBG
        DCX     H               ; HL = last byte

        ; DE still = base. Scan backward for LF.
        MVI     B,0             ; B = fragment byte count
FIOVSC: MOV     A,H
        CMP     D
        JNZ     FIOVS1
        MOV     A,L
        CMP     E
        JZ      FIOVT0          ; reached base, no LF found, skip
FIOVS1: MOV     A,M
        CPI     LF
        JZ      FIOVLF          ; found last LF
        INR     B
        DCX     H
        JMP     FIOVSC

FIOVLF: ; Found LF at HL. Fragment = B bytes after it.
        MOV     A,B
        ORA     A
        JZ      FIOVT0          ; LF is last byte, no fragment
        STA     FIOVFN          ; save fragment length

        ; Copy fragment bytes to FIOVFRAG
        INX     H               ; HL = first byte after LF
        LXI     D,FIOVFRAG
FIOVCP: MOV     A,M
        STAX    D
        INX     H
        INX     D
        DCR     B
        JNZ     FIOVCP

        ; Adjust GAPBG backward by fragment length
        LHLD    CURBDP
        MVI     A,BD_GAPBG
        ADD     L
        MOV     L,A
        MVI     A,0
        ADC     H
        MOV     H,A
        MOV     E,M
        INX     H
        MOV     D,M             ; DE = old GAPBG
        LDA     FIOVFN
        MOV     C,A
        MVI     B,0             ; BC = fragment length
        MOV     A,E
        SUB     C
        MOV     E,A
        MOV     A,D
        SBB     B
        MOV     D,A             ; DE = new GAPBG
        DCX     H
        MOV     M,E
        INX     H
        MOV     M,D             ; write new GAPBG

        ; Also adjust BD_TXEND
        LHLD    CURBDP
        MVI     A,BD_TXEND
        ADD     L
        MOV     L,A
        MVI     A,0
        ADC     H
        MOV     H,A
        MOV     E,M
        INX     H
        MOV     D,M             ; DE = old TXEND
        LDA     FIOVFN
        MOV     C,A
        MVI     B,0
        MOV     A,E
        SUB     C
        MOV     E,A
        MOV     A,D
        SBB     B
        MOV     D,A             ; DE = new TXEND
        DCX     H
        MOV     M,E
        INX     H
        MOV     M,D             ; write new TXEND

FIOVT0:
        ; Set overflow flags
        MVI     A,1
        STA     VIOVFL
        STA     VIMODE

        ; Set DMA to 0080H for directory ops
        LXI     D,CMDTAIL
        MVI     C,BF_SETDMA
        CALL    BDOS

        ; Build AFTER FCB directly (avoid cross-module EXTRN)
        ; FCB: drive(1) + name(8) + ext(3) + zero(24) = 36 bytes
        LXI     H,FIOAFN        ; local template
        LXI     D,VAFCB
        MVI     B,12
FIOVF1: MOV     A,M
        STAX    D
        INX     H
        INX     D
        DCR     B
        JNZ     FIOVF1
        MVI     B,24
        XRA     A
FIOVF2: STAX    D
        INX     D
        DCR     B
        JNZ     FIOVF2

        ; Override drive byte with VTMPDRV
        LDA     VTMPDRV
        STA     VAFCB

        ; Create the file
        LXI     D,VAFCB
        MVI     C,BF_FMAKE
        CALL    BDOS
        INR     A               ; 0FFH -> 0 means error
        JZ      FIOVFA          ; create failed

        ; Reset current record
        XRA     A
        STA     VAFCB+FCB_CR
        MVI     A,1
        STA     VAFEX

        ; Show overflow status
        LXI     D,OVFLMSG
        CALL    STATMSG

        ; Set up VIWBYT output to AFTER FCB
        LXI     H,VAFCB
        SHLD    VIWFCB
        XRA     A
        STA     VIOPOS

        ; Write partial-line fragment to AFTER temp (if any)
        LDA     FIOVFN
        ORA     A
        JZ      FIOVLP          ; no fragment, skip

        LXI     H,FIOVFRAG
        LDA     FIOVFN
        MOV     B,A
FIOVWF: MOV     A,M
        PUSH    H
        PUSH    B
        CALL    VIWBYT
        POP     B
        POP     H
        INX     H
        DCR     B
        JNZ     FIOVWF

        ; Read remaining source records byte-by-byte via VIWBYT.
        ; Fragment (if any) is already in VIOBUF from above.
        ; Count LFs for VAFLN, detect CPMEOF for end.
FIOVLP:
        LXI     D,DMABUF
        MVI     C,BF_SETDMA
        CALL    BDOS
        LXI     D,WRKFCB
        MVI     C,BF_FREAD
        CALL    BDOS
        ORA     A
        JNZ     FIOVDN          ; non-zero = EOF or error

        ; Process record bytes via VIWBYT
        LXI     H,DMABUF
        MVI     B,RECSIZ
FIOVBL:
        MOV     A,M
        CPI     CPMEOF
        JZ      FIOVDN          ; hit EOF marker
        CPI     LF
        JNZ     FIOVNL
        PUSH    H
        PUSH    B
        LHLD    VAFLN
        INX     H
        SHLD    VAFLN
        POP     B
        POP     H
FIOVNL:
        ; Write byte to AFTER via VIWBYT
        MOV     A,M
        PUSH    H
        PUSH    B
        CALL    VIWBYT
        POP     B
        POP     H
        INX     H
        DCR     B
        JNZ     FIOVBL
        JMP     FIOVLP          ; next record

FIOVDN:
        ; Flush remaining buffered bytes to AFTER temp
        CALL    VIFLUSH
        ; Close AFTER temp
        LXI     D,CMDTAIL
        MVI     C,BF_SETDMA
        CALL    BDOS
        LXI     D,VAFCB
        MVI     C,BF_FCLOSE
        CALL    BDOS
        ; Fall through to FIEOF (source file still open)
        JMP     FIEOF

FIOVFA:
        ; BF_FMAKE failed (directory full?) - fall back to error
        XRA     A
        STA     VIMODE          ; cancel virtual mode
        STA     VIOVFL
        JMP     FIFULL          ; show error, close source

FIWDPOP:
        POP     H               ; balance PUSH H from width check
FIWIDE:
        ; Line too wide - close file, discard buffer, show error
        LXI     D,CMDTAIL
        MVI     C,BF_SETDMA
        CALL    BDOS
        LXI     D,WRKFCB
        MVI     C,BF_FCLOSE
        CALL    BDOS
        CALL    FIRSTUSR        ; restore original user area
        CALL    FIBUFCLR        ; reset gap buffer to empty
        XRA     A
        STA     ISLOAD          ; clear loading flag
        CALL    SYNINIT
        ; Print "Line N is wider than 255 characters"
        LXI     D,FIWDM1        ; "Line "
        CALL    STATMSG         ; positions cursor, resets SGR
        LHLD    FILNUM
        CALL    FIPRNUM         ; print line number
        LXI     D,FIWDM2        ; " is wider than 255 characters"
        CALL    OUTSTR
        MVI     A,0FFH          ; return error code
        RET

FIEOF:
        ; Close source file
        ; Set DMA for directory op (BF_FCLOSE updates directory)
        LXI     D,CMDTAIL
        MVI     C,BF_SETDMA
        CALL    BDOS
        LXI     D,WRKFCB
        MVI     C,BF_FCLOSE
        CALL    BDOS

        ; Restore original user area
        CALL    FIRSTUSR

        ; If virtual mode, rebalance buffer around line 1
        ; so the gap has ~4 KB of editing headroom.
        LDA     VIMODE
        ORA     A
        JZ      FIOOPN
        LXI     H,1             ; target line 1
        CALL    VIGOTO          ; merge-split rebalance

FIOOPN: ; New or loaded: move cursor to top, clear modified
        XRA     A
        STA     ISLOAD          ; clear loading flag
        CALL    GBMVTOP
        CALL    FICLRMOD
        CALL    SYNINIT         ; set BD_SYNMD based on extension
        LXI     D,LOADMSG
        CALL    STATMSG
        XRA     A               ; return success (A=0)
        RET

;=============================================================
; FISAVE - Save current buffer to its file.
; Entry:  CURBDP valid; BD_FNAME holds name.
; Exit:   File written; BD_MODIF cleared.
;         On error: status message displayed, file unchanged.
;         Regs: all clobbered.
; Note:   Old file renamed to .BAK before write.
;=============================================================
FISAVE:
        ; Check modified flag - skip if clean
        CALL    FISMOD
        ORA     A
        JZ      FSVSKP          ; not modified

        ; Switch to file's user area for save
        CALL    FISWUSR

        ; Build FCB from stored filename
        CALL    FIBLDFC

        ; Delete any existing .BAK
        CALL    FIMKBAK

        ; Rename current file to .BAK
        CALL    FIRNMBK

        ; Create new output file
        LXI     D,WRKFCB
        MVI     C,BF_FMAKE
        CALL    BDOS
        INR     A
        JZ      FSVERE          ; create failed (disk full?)

        ; Reset FCB current record
        CALL    FIRCB0

        ; Check if virtual mode - use three-phase save
        LDA     VIMODE
        ORA     A
        JNZ     FSVVRT

        ; Write buffer contents record by record
        CALL    FIWRITE
        ; Check for write errors (disk full, etc)
        LDA     FWERRF
        ORA     A
        JNZ     FSVERE          ; write failed
        JMP     FSVSKP          ; normal save done

FSVVRT:
        ; Virtual mode: use three-phase save (BEFORE + buffer + AFTER)
        CALL    VISAVALL
        JMP     FSVSKP

FSVSKP: ; Restore original user area after save
        CALL    FIRSTUSR
        LXI     D,SAVEMSG
        JMP     STATMSG

FSVERE: CALL    FIRSTUSR        ; restore user area on error too
        LXI     D,ERRMSG
        CALL    STATMSG
        MVI     C,BF_CONIN
        JMP     BDOS            ; wait for any key

;=============================================================
; FIPROMPT - Prompt user for a filename on the status line.
; Entry:  DE = prompt string ($ terminated)
; Exit:   FILNBUF filled with 0-terminated filename string
;         HL = FILNBUF
;         Zero flag set if user pressed ESC (cancelled)
;         Regs: all clobbered.
;=============================================================
FIPROMPT:
        PUSH    D               ; save prompt string pointer
        LDA     RSTAT
        MOV     B,A             ; status row
        MVI     C,1             ; col 1
        CALL    CURGOTO         ; position cursor on status line
        POP     D               ; restore prompt pointer
        CALL    OUTSTR          ; display prompt (DE)

        ; Use BDOS buffered line input into RDLNBUF
        LXI     D,RDLNBUF
        MVI     C,BF_RDLINE
        CALL    BDOS

        ; RDLNBUF+1 = actual length; RDLNBUF+2.. = chars
        LDA     RDLNBUF+1
        ORA     A
        JZ      FPCANC          ; empty input = cancel

        ; Copy to FILNBUF, NUL-terminate (max 17 chars)
        MVI     B,0
        MOV     C,A             ; C = length
        MOV     A,C
        CPI     18
        JC      FPCPOK
        MVI     C,17            ; cap at 17 chars
FPCPOK: LXI     H,RDLNBUF+2    ; source
        LXI     D,FILNBUF       ; dest
FPCPLP: MOV     A,M
        STAX    D
        INX     H
        INX     D
        INR     B
        MOV     A,B
        CMP     C
        JNZ     FPCPLP
        XRA     A
        STAX    D               ; NUL terminator

        ; Parse FILNBUF into WRKFCB
        CALL    FIPARSN

        LXI     H,FILNBUF
        ORA     A               ; clear zero (not cancelled)
        INR     A               ; make NZ
        RET

FPCANC: LXI     H,FILNBUF
        XRA     A               ; set Z (cancelled)
        RET

;=============================================================
; Internal helpers
;=============================================================

;------------------------------------------------------------
; FIBUFCLR - Reset gap buffer to empty using GBINIT.
; Uses CURBDP to get base and size, then calls GBINIT.
;------------------------------------------------------------
FIBUFCLR:
        LHLD    CURBDP          ; HL = descriptor
        PUSH    H               ; save desc ptr

        ; read base: desc + BD_BSTAR
        MOV     A,L
        ADI     BD_BSTAR
        MOV     L,A
        MOV     A,H
        ACI     0
        MOV     H,A
        MOV     E,M
        INX     H
        MOV     D,M             ; DE = buffer base address

        POP     H               ; HL = descriptor again
        PUSH    H
        PUSH    D               ; save base

        ; read size: desc + BD_BSIZE
        MOV     A,L
        ADI     BD_BSIZE
        MOV     L,A
        MOV     A,H
        ACI     0
        MOV     H,A
        MOV     C,M
        INX     H
        MOV     B,M             ; BC = buffer size

        POP     D               ; DE = base
        POP     H               ; HL = descriptor

        JMP     GBINIT

;------------------------------------------------------------
; FISAVFN - Copy FCB drive+name+ext into BD_FNAME field.
; WRKFCB must be populated before calling.
; BD_FNAME layout: [drive(1) + name(8) + ext(3)] = 12 bytes
;------------------------------------------------------------
FISAVFN:
        LHLD    CURBDP          ; HL = descriptor
        MOV     A,L
        ADI     BD_FNAME
        MOV     L,A
        MOV     A,H
        ACI     0
        MOV     H,A             ; HL = &desc.BD_FNAME

        LXI     D,WRKFCB+FCB_DR ; DE = drive+name+ext in FCB
        MVI     B,12            ; 1+8+3 = 12 bytes
FSFNLP: LDAX    D
        MOV     M,A
        INX     H
        INX     D
        DCR     B
        JNZ     FSFNLP
        RET

;------------------------------------------------------------
; FICLRMOD - Clear BD_MODIF flag in current descriptor.
;------------------------------------------------------------
FICLRMOD:
        LHLD    CURBDP
        MOV     A,L
        ADI     BD_MODIF
        MOV     L,A
        MOV     A,H
        ACI     0
        MOV     H,A
        MVI     M,0
        RET

;------------------------------------------------------------
; FISMOD - Read BD_MODIF, return in A.
;------------------------------------------------------------
FISMOD:
        LHLD    CURBDP
        MOV     A,L
        ADI     BD_MODIF
        MOV     L,A
        MOV     A,H
        ACI     0
        MOV     H,A
        MOV     A,M
        RET

;------------------------------------------------------------
; FIRCB0 - Zero FCB control bytes: EX, S2, RC, CR.
;------------------------------------------------------------
FIRCB0:
        XRA     A
        STA     WRKFCB+FCB_EX
        STA     WRKFCB+FCB_S2
        STA     WRKFCB+FCB_RC
        STA     WRKFCB+FCB_CR
        RET

;------------------------------------------------------------
; FIBLDFC - Build WRKFCB from BD_FNAME in descriptor.
; Fills FCB drive (0), name+ext, zeros control fields.
;------------------------------------------------------------
FIBLDFC:
        ; Zero entire FCB first
        LXI     H,WRKFCB
        MVI     B,FCB_SIZ
        XRA     A
FBFCLP: MOV     M,A
        INX     H
        DCR     B
        JNZ     FBFCLP

        ; Copy drive+name+ext from descriptor BD_FNAME (12 bytes)
        LHLD    CURBDP
        MOV     A,L
        ADI     BD_FNAME
        MOV     L,A
        MOV     A,H
        ACI     0
        MOV     H,A             ; HL = BD_FNAME

        LXI     D,WRKFCB+FCB_DR
        MVI     B,12
FBFLP:  MOV     A,M
        STAX    D
        INX     H
        INX     D
        DCR     B
        JNZ     FBFLP
        RET

;------------------------------------------------------------
; FIMKBAK - Delete any existing .BAK file with same name.
; Uses BAKFCB (built from WRKFCB name, .BAK extension).
;------------------------------------------------------------
FIMKBAK:
        CALL    FIBAKFCB        ; build BAKFCB
        LXI     D,BAKFCB
        MVI     C,BF_FDEL
        JMP     BDOS            ; ignore error (may not exist)

;------------------------------------------------------------
; FIRNMBK - Rename WRKFCB file to .BAK using FCB rename.
; CP/M BF_RENAME expects: FCB[0..15] = old name,
;                          FCB[16..31] = new name.
; We build RNMFCB for this.
;------------------------------------------------------------
FIRNMBK:
        ; Build rename FCB: copy WRKFCB name to first 16 bytes
        LXI     H,RNMFCB
        LXI     D,WRKFCB
        MVI     B,16
FRNLP:  LDAX    D
        MOV     M,A
        INX     D
        INX     H
        DCR     B
        JNZ     FRNLP

        ; Copy name portion again to bytes 16-31 (new name)
        ; then overwrite extension with BAK
        LXI     D,WRKFCB
        MVI     B,16
FRNLP2: LDAX    D
        MOV     M,A
        INX     D
        INX     H
        DCR     B
        JNZ     FRNLP2

        ; Overwrite extension in second name (offset 16+9=25)
        LXI     H,RNMFCB+16+FCB_FT
        MVI     M,'B'
        INX     H
        MVI     M,'A'
        INX     H
        MVI     M,'K'

        LXI     D,RNMFCB
        MVI     C,23            ; BF_RENAME = 23
        JMP     BDOS

;------------------------------------------------------------
; FIWRITE - Write gap buffer to currently-open WRKFCB.
; Reads logical bytes 0..TXEND-1 (skipping the gap),
; packs into 128-byte records, writes each to BDOS.
; Appends CPMEOF if last record is partial.
;------------------------------------------------------------
FIWRITE:
        ; Clear write error flag
        XRA     A
        STA     FWERRF
        ; Initialise write state
        MVI     B,0             ; B = position in DMABUF (0..127)
        LXI     H,DMABUF        ; HL = current DMA write ptr

        ; Get descriptor fields we need
        LHLD    CURBDP

        ; Read GAPBG into FWGPBG
        PUSH    H
        MOV     A,L
        ADI     BD_GAPBG
        MOV     L,A
        MOV     A,H
        ACI     0
        MOV     H,A
        MOV     E,M
        INX     H
        MOV     D,M
        XCHG
        SHLD    FWGPBG          ; FWGPBG = gap begin
        POP     H

        ; Read GAPEN into FWGPEN
        PUSH    H
        MOV     A,L
        ADI     BD_GAPEN
        MOV     L,A
        MOV     A,H
        ACI     0
        MOV     H,A
        MOV     E,M
        INX     H
        MOV     D,M
        XCHG
        SHLD    FWGPEN          ; FWGPEN = gap end
        POP     H

        ; Read BSTAR into FWBASE
        PUSH    H
        MOV     A,L
        ADI     BD_BSTAR
        MOV     L,A
        MOV     A,H
        ACI     0
        MOV     H,A
        MOV     E,M
        INX     H
        MOV     D,M
        XCHG
        SHLD    FWBASE          ; FWBASE = buffer base
        POP     H

        ; Read TXEND
        MOV     A,L
        ADI     BD_TXEND
        MOV     L,A
        MOV     A,H
        ACI     0
        MOV     H,A
        MOV     E,M
        INX     H
        MOV     D,M
        XCHG
        SHLD    FWTXEND         ; FWTXEND = text end offset

        ; Logical offset starts at 0
        LXI     H,0
        SHLD    FWOFF           ; FWOFF = current logical offset

FWLOP:
        ; Check if FWOFF >= FWTXEND (done writing?)
        LHLD    FWOFF
        XCHG                    ; DE = FWOFF
        LHLD    FWTXEND         ; HL = FWTXEND
        ; Compare: FWOFF - FWTXEND; if no borrow → done
        MOV     A,E
        SUB     L
        MOV     A,D
        SBB     H               ; FWOFF - FWTXEND
        JNC     FWDONE          ; FWOFF >= FWTXEND: done

FWGET:
        ; Compute physical address: FWBASE + FWOFF, skip gap
        LHLD    FWOFF
        XCHG                    ; DE = logical offset
        LHLD    FWGPBG
        ; if offset < gapbg: physical = base + offset
        MOV     A,H
        CMP     D
        JC      FWBFGP          ; gapbg.H < offset.H: after gap
        JNZ     FWAFGP          ; gapbg.H > offset.H: before gap
        MOV     A,L
        CMP     E
        JZ      FWBFGP          ; gapbg == offset: after gap
        JNC     FWAFGP          ; gapbg > offset: before gap

FWBFGP: ; logical offset is >= gapbg: add gap size
        PUSH    B               ; save DMA position (B)
        LHLD    FWGPEN
        XCHG                    ; DE = gapen
        LHLD    FWGPBG          ; HL = gapbg
        MOV     A,E
        SUB     L
        MOV     C,A
        MOV     A,D
        SBB     H
        MOV     B,A             ; BC = gap size (gapen - gapbg)
        LHLD    FWOFF
        MOV     A,L
        ADD     C
        MOV     L,A
        MOV     A,H
        ADC     B
        MOV     H,A             ; HL = logical + gap size = physical offset
        POP     B               ; restore DMA position
        JMP     FWPHYS

FWAFGP: ; logical offset < gapbg: physical = logical
        LHLD    FWOFF
        ; HL = physical offset (same as logical)

FWPHYS: ; HL = physical offset; add FWBASE
        XCHG
        LHLD    FWBASE
        DAD     D               ; HL = physical address
        MOV     A,M             ; A = byte from buffer

        ; Store byte in DMABUF at position B
        MVI     H,0
        MOV     L,B             ; HL = B (16-bit index)
        LXI     D,DMABUF
        DAD     D               ; HL = &DMABUF[B]
        MOV     M,A             ; store byte

        ; Advance logical offset
        LHLD    FWOFF
        INX     H
        SHLD    FWOFF

        ; Advance DMA position
        INR     B
        MOV     A,B
        CPI     RECSIZ          ; 128 bytes full?
        JNZ     FWLOP

        ; Write one full record
        CALL    FWREC
        LDA     FWERRF
        ORA     A
        JNZ     FWCLOS          ; write error, abort
        MVI     B,0             ; reset DMA position
        JMP     FWLOP

FWDONE:
        ; Write final partial record if any data pending
        MOV     A,B
        ORA     A
        JZ      FWCLOS

        ; Pad remaining bytes with CPMEOF
FWPADL: MOV     A,B
        CPI     RECSIZ
        JZ      FWWLST
        MVI     H,0
        MOV     L,B             ; HL = B (16-bit index)
        LXI     D,DMABUF
        DAD     D               ; HL = &DMABUF[B]
        MVI     M,CPMEOF
        INR     B
        JMP     FWPADL

FWWLST: CALL    FWREC

FWCLOS:
        LXI     D,CMDTAIL
        MVI     C,BF_SETDMA
        CALL    BDOS
        LXI     D,WRKFCB
        MVI     C,BF_FCLOSE
        CALL    BDOS

        ; Only clear modified flag if no write errors
        LDA     FWERRF
        ORA     A
        RNZ                     ; error: keep modified flag
        JMP     FICLRMOD

;------------------------------------------------------------
; FWREC - Write one RECSIZ record from DMABUF to WRKFCB.
; Sets FWERRF on write error (disk full, etc).
;------------------------------------------------------------
FWREC:
        LXI     D,DMABUF
        MVI     C,BF_SETDMA
        CALL    BDOS
        LXI     D,WRKFCB
        MVI     C,BF_FWRITE
        CALL    BDOS
        ORA     A
        RZ                      ; A=0: success
        MVI     A,1
        STA     FWERRF          ; mark write error
        RET

;------------------------------------------------------------
; FIBAKFCB - Build BAKFCB from WRKFCB name with .BAK ext.
;------------------------------------------------------------
FIBAKFCB:
        LXI     H,BAKFCB
        MVI     B,FCB_SIZ
        XRA     A
FBKLP:  MOV     M,A
        INX     H
        DCR     B
        JNZ     FBKLP
        ; Copy 8-char name from WRKFCB
        LXI     D,WRKFCB+FCB_FN
        LXI     H,BAKFCB+FCB_FN
        MVI     B,8
FBKLP2: LDAX    D
        MOV     M,A
        INX     D
        INX     H
        DCR     B
        JNZ     FBKLP2
        ; Set .BAK extension
        MVI     M,'B'
        INX     H
        MVI     M,'A'
        INX     H
        MVI     M,'K'
        RET

;------------------------------------------------------------
; FIPARSN - Parse filename in FILNBUF into WRKFCB.
; Format: [d[u]:] name[.ext]  (CP/M 8.3, upper-cased)
;   d = drive letter A-P
;   u = user number 0-15 (optional)
; Entry:  FILNBUF = NUL-terminated filename string
; Exit:   WRKFCB populated; FILUSR set; FIRCB0 called
;------------------------------------------------------------
FIPARSN:
        ; Reset FILUSR to FFH (unspecified)
        MVI     A,0FFH
        STA     FILUSR
        ; Zero WRKFCB
        LXI     H,WRKFCB
        MVI     B,FCB_SIZ
        XRA     A
FPNCLP: MOV     M,A
        INX     H
        DCR     B
        JNZ     FPNCLP
        ; Space-fill name+ext (CP/M requires 0x20 padding)
        LXI     H,WRKFCB+FCB_FN
        MVI     B,11
        MVI     A,' '
FPNSPL: MOV     M,A
        INX     H
        DCR     B
        JNZ     FPNSPL

        LXI     H,FILNBUF

        ; Check for drive spec: scan first 4 chars for ':'
        ; Formats: X: (drive only), X#: or X##: (drive+user)
        MOV     A,M             ; first char
        ORA     A
        RZ                      ; empty

        ; Scan for ':' in first 4 chars to detect drive spec
        PUSH    H               ; save FILNBUF start
        MVI     B,4             ; check up to 4 chars
        MVI     C,0             ; position counter
FPNCLN: MOV     A,M
        ORA     A
        JZ      FPNCNF          ; NUL before colon - no drive
        CPI     ':'
        JZ      FPNCFD          ; found colon at position C
        INX     H
        INR     C
        DCR     B
        JNZ     FPNCLN
FPNCNF: ; No colon found in first 4 chars - no drive spec
        POP     H               ; restore to FILNBUF start
        JMP     FPNND

FPNCFD: ; Colon found at position C (0-based)
        POP     H               ; HL = FILNBUF start
        MOV     A,C
        ORA     A
        JZ      FPNND           ; colon at pos 0 - no drive, skip

        ; Check first char: letter (A-P) or digit (0-9)?
        MOV     A,M
        CPI     '0'
        JC      FPNND           ; below '0', not valid prefix
        CPI     '9'+1
        JC      FPNUON          ; digit first: user# only, no drive

        ; First char is not a digit - check if letter A-P
        ANI     5FH             ; upper case
        CPI     'A'
        JC      FPNND           ; not a letter, treat as filename
        CPI     'P'+1
        JNC     FPNND           ; past P, treat as filename

        ; First char is a letter (drive). Check what follows.
        MOV     A,C
        CPI     1
        JZ      FPNDRV          ; colon at pos 1: "X:" drive only

        ; Position 2+: "X#:" or "X##:" - drive + user number
        MOV     A,M             ; reload drive letter
        ANI     5FH
        SUI     'A'-1           ; A=1, B=2, ...
        STA     WRKFCB+FCB_DR
        INX     H               ; advance past drive letter
        JMP     FPNUSR          ; parse user digits

        ; --- User# only (first char is digit, no drive letter) ---
        ; Formats: #: or ##: (default drive)
FPNUON: ; HL -> first digit, colon follows after 1-2 digits

        ; --- Parse 1-2 digit user number ---
FPNUSR: MOV     A,M             ; first digit
        SUI     '0'
        JC      FPNND           ; not a digit
        CPI     10
        JNC     FPNND           ; not a digit
        MOV     C,A             ; C = first digit value
        INX     H
        MOV     A,M             ; next char
        CPI     ':'
        JZ      FPNUDN          ; single digit, C = user number
        ; Two-digit user number: C*10 + second digit
        SUI     '0'
        JC      FPNND           ; not a digit
        CPI     10
        JNC     FPNND
        MOV     B,A             ; B = second digit
        MOV     A,C
        ADD     A               ; *2
        ADD     A               ; *4
        ADD     C               ; *5
        ADD     A               ; *10
        ADD     B               ; + second digit
        MOV     C,A             ; C = user number
        INX     H               ; advance to ':'
FPNUDN: ; C = parsed user number, HL points to ':'
        MOV     A,C
        CPI     16
        JNC     FPNND           ; user > 15, invalid
        STA     FILUSR          ; store user number
        INX     H               ; skip ':'
        JMP     FPNND           ; continue with filename

FPNDRV: ; Simple "X:" - drive letter only (no user#)
        MOV     A,M             ; get drive letter
        ANI     5FH             ; upper case
        SUI     'A'-1           ; A=1, B=2, ...
        STA     WRKFCB+FCB_DR
        INX     H
        INX     H               ; skip 'X:'

FPNND:  ; Parse name (up to 8 chars, stop at '.' or NUL)
        LXI     D,WRKFCB+FCB_FN
        MVI     B,8             ; max 8 chars
FPNNLP: MOV     A,M
        ORA     A
        JZ      FPNDNE          ; end of string
        CPI     '.'
        JZ      FPNEXT          ; start of extension
        ; Upper-case the character
        CPI     'a'
        JC      FPNSTC          ; already upper or non-alpha
        CPI     'z'+1
        JNC     FPNSTC
        ANI     5FH             ; to upper
FPNSTC: STAX    D
        INX     H
        INX     D
        DCR     B
        JNZ     FPNNLP
        ; Overflow: skip to '.' or end
FPNSKP: MOV     A,M
        ORA     A
        JZ      FPNDNE
        CPI     '.'
        JZ      FPNEXT
        INX     H
        JMP     FPNSKP

FPNDNE: CALL    FIRCB0
        RET

FPNEXT: ; Parse extension (up to 3 chars)
        INX     H               ; skip '.'
        LXI     D,WRKFCB+FCB_FT
        MVI     B,3
FPNELP: MOV     A,M
        ORA     A
        JZ      FPNDNE
        CPI     'a'
        JC      FPNESC
        CPI     'z'+1
        JNC     FPNESC
        ANI     5FH
FPNESC: STAX    D
        INX     H
        INX     D
        DCR     B
        JNZ     FPNELP
        JMP     FIRCB0

;------------------------------------------------------------
; FISWUSR - Switch to file's user area.
; If FILUSR != FFH, calls BDOS 32 to set user number.
; Exit:   All regs clobbered.
;------------------------------------------------------------
FISWUSR:
        LDA     FILUSR
        CPI     0FFH
        RZ                      ; unspecified, no switch
        MOV     E,A
        MVI     C,BF_USRNUM
        JMP     BDOS

;------------------------------------------------------------
; FIRSTUSR - Restore original user area.
; Always calls BDOS 32 with saved original user number.
; Exit:   All regs clobbered.
;------------------------------------------------------------
FIRSTUSR:
        LDA     ORGUSR
        MOV     E,A
        MVI     C,BF_USRNUM
        JMP     BDOS

;=============================================================
; FIPRNUM - Print HL as decimal number (0-65535).
;           Leading zeros suppressed; at least 1 digit output.
; Entry:  HL = number
; Exit:   Digits output via OUTCHAR; all regs clobbered
;=============================================================
FIPRNUM:
        XRA     A
        STA     FIPFLG          ; 0 = suppress leading zeros
        LXI     D,-10000
        CALL    FIPRDG
        LXI     D,-1000
        CALL    FIPRDG
        LXI     D,-100
        CALL    FIPRDG
        LXI     D,-10
        CALL    FIPRDG
        ; Units digit: always print
        MOV     A,L
        ADI     '0'
        JMP     OUTCHAR         ; tail call

;-------------------------------------------------------------
; FIPRDG - Extract and print one decimal digit.
; Entry:  HL = value, DE = negative power of 10
; Exit:   HL = remainder; FIPFLG updated; DE clobbered
;-------------------------------------------------------------
FIPRDG:
        MVI     B,0             ; digit counter
FIPRLP: DAD     D               ; HL -= |power| (via add negative)
        JNC     FIPRDN          ; underflow -> done
        INR     B
        JMP     FIPRLP
FIPRDN:
        ; Restore HL: negate DE and add back
        MOV     A,D
        CMA
        MOV     D,A
        MOV     A,E
        CMA
        MOV     E,A
        INX     D               ; DE = -DE (positive)
        DAD     D               ; HL = remainder

        ; B = digit value. Print if non-zero or past leading zeros
        MOV     A,B
        ORA     A
        JNZ     FIPRNZ          ; non-zero, always print

        ; Zero digit: suppress if still leading
        LDA     FIPFLG
        ORA     A
        RZ                      ; leading zero, skip

        ; Past leading zeros: print '0'
        MVI     A,'0'
        PUSH    H
        CALL    OUTCHAR
        POP     H
        RET

FIPRNZ:
        ; Non-zero digit: set flag, print
        MOV     A,B
        ADI     '0'
        PUSH    H
        PUSH    PSW             ; save ASCII digit
        MVI     A,1
        STA     FIPFLG          ; no more suppression
        POP     PSW             ; restore digit
        CALL    OUTCHAR
        POP     H
        RET

;=============================================================
; DATA SEGMENT
;=============================================================
        DSEG

; Working FCB for current file operation (36 bytes)
WRKFCB: DS      FCB_SIZ

; FCB for .BAK file
BAKFCB: DS      FCB_SIZ

; Rename FCB (32 bytes: old[16] + new[16])
RNMFCB: DS      32

; 128-byte DMA buffer for record I/O
DMABUF: DS      RECSIZ

; Buffered line input buffer for FIPROMPT
; Format: max_len, actual_len, chars...
RDLNBUF: DB    79              ; max length
         DB    0               ; actual length (filled by BDOS)
         DS    80              ; input buffer

; Parsed filename (NUL-terminated, max d##:XXXXXXXX.XXX + NUL = 17)
FILNBUF: DS    18

; FIWRITE temporaries
FWGPBG: DW     0              ; gap begin (physical offset)
FWGPEN: DW     0              ; gap end   (physical offset)
FWBASE: DW     0              ; buffer base address
FWTXEND: DW    0              ; text end offset
FWOFF:  DW     0              ; current logical write offset
FWERRF: DB     0              ; write error flag (0=ok, 1=error)

; Status messages
LDNGMSG: DB    'Please wait, loading file...$'
LOADMSG: DB    'File loaded.$'
SAVEMSG: DB    'File saved. $'
ERRMSG:  DB    'Disk full or write error! Press any key.$'
FULLMSG: DB    'File is too big.$'
OVFLMSG: DB    'Large file: using virtual buffer...$'
FIOAFN:  DB    0,'SEDIT00A','TMP'       ; AFTER temp FCB template
FIWDM1:  DB    'Line $'
FIWDM2:  DB    ' is wider than 255 characters.$'

; User area tracking
FILUSR: DB      0FFH            ; file's user number (FFH=unspecified)
ORGUSR: DB      0               ; original user number at startup

; File load tracking
FILNUM: DW      0               ; current line number during load
FICOL:  DB      0               ; column counter during load
FITMP:  DB      0               ; saved byte during column check
FIPFLG: DB      0               ; FIPRNUM leading zero suppress

; Partial-line trim for overflow
FIOVFN: DB      0               ; fragment byte count
FIOVFRAG: DS    MAXCOLS         ; fragment buffer (max line width)

        END

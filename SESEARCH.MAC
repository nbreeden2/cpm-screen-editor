;============================================================
; FILE:    SESEARCH.MAC
; PROJECT: SEDIT - Screen Editor for CP/M 2.2
; VERSION: 1.0
; DATE:    1984-01-01
; AUTHOR: Claude Code and RetroTechReboot
;------------------------------------------------------------
; DESCRIPTION:
;   Forward search in the gap buffer.
;   SRFNDNX  - find next occurrence of SRCHSTR starting
;              from current cursor position, wrapping at
;              end of file.
;   Search is case-insensitive when SRCHOPTS bit 0 = 1.
;------------------------------------------------------------
; REVISION HISTORY:
;   1.0  1984-01-01  Initial release
;============================================================

;--- Imports ----------------------------------------------
        EXTRN   CURBDP          ; current buffer descriptor
        EXTRN   GBMVRT          ; move cursor right one char
        EXTRN   GBMVTOP         ; move cursor to file top
        EXTRN   GBINSRT         ; insert char at cursor
        EXTRN   GBDELRT         ; delete char right
        EXTRN   OUTSTR          ; write $-string to console
        EXTRN   OUTCHAR         ; write single char
        EXTRN   CURGOTO         ; position cursor (B=row,C=col)
        EXTRN   STATMSG         ; status bar message
        EXTRN   STATCLR         ; clear status line
        EXTRN   DIRTY           ; screen redraw flag
        EXTRN   RSTAT           ; runtime status row
        EXTRN   SCRDRAW         ; full screen redraw
        EXTRN   INFOBAR         ; update info bar
        EXTRN   CURPOS          ; position hardware cursor

;--- Exports ----------------------------------------------
        PUBLIC  SRFIND          ; find (always prompt)
        PUBLIC  SRFNDNX         ; find next
        PUBLIC  SRREPL          ; find and replace
        PUBLIC  SRJMPM          ; jump to matching brace

;=============================================================
; SRFNDNX - Find next occurrence of SRCHSTR.
; If SRCHSTR is empty, prompt for a new search string first.
; Starts search from byte AFTER current cursor offset.
; Wraps around to file top if not found forward.
; Entry:  CURBDP valid
; Exit:   Cursor moved to match start if found.
;         Status message displayed.
;         DIRTY set.
;         Regs: all clobbered.
;=============================================================
;============================================================
; FILE:    SEDIT.INC
; PROJECT: SEDIT - Screen Editor for CP/M 2.2
; VERSION: 1.0
; DATE:    1984-01-01
; AUTHOR: Claude Code and RetroTechReboot
;------------------------------------------------------------
; DESCRIPTION:
;   Shared equates for all SEDIT modules.
;   INCLUDE this as the first statement of every .MAC file.
;------------------------------------------------------------
; REVISION HISTORY:
;   1.0  1984-01-01  Initial release
;============================================================

;--- CP/M system addresses ----------------------------
BDOS    EQU     0005H       ; BDOS call entry
WBOOT   EQU     0000H       ; warm boot / exit
DFTFCB  EQU     005CH       ; default FCB (arg 1)
CMDTAIL EQU     0080H       ; command tail buffer

;--- BDOS function numbers ----------------------------
BF_CONIN  EQU   1           ; console input (wait)
BF_CONOUT EQU   2           ; console output: E=char
BF_RAWIO  EQU   6           ; direct I/O: E=FFH->in
BF_PRTSTR EQU   9           ; print $-string: DE=addr
BF_RDLINE EQU   10          ; buffered line input
BF_CONST  EQU   11          ; console status
BF_FOPEN  EQU   15          ; open file: DE=FCB
BF_FCLOSE EQU   16          ; close file: DE=FCB
BF_FDEL   EQU   19          ; delete: DE=FCB
BF_FREAD  EQU   20          ; seq read: DE=FCB
BF_FWRITE EQU   21          ; seq write: DE=FCB
BF_FMAKE  EQU   22          ; create: DE=FCB
BF_SETDMA EQU   26          ; set DMA: DE=addr
BF_USRNUM EQU   32          ; get/set user: E=num

;--- ASCII control codes ------------------------------
NUL     EQU     00H
BEL     EQU     07H         ; bell
BS      EQU     08H         ; backspace
TAB     EQU     09H         ; horizontal tab
LF      EQU     0AH         ; line feed
CR      EQU     0DH         ; carriage return
ESC     EQU     1BH         ; escape
DEL     EQU     7FH         ; delete character
CPMEOF  EQU     1AH         ; CP/M EOF marker (Ctrl-Z)
CTRLK   EQU     0BH         ; Ctrl-K (prefix key)
CTRLQ   EQU     11H         ; Ctrl-Q (prefix key)

;--- Screen layout ------------------------------------
SCRROWS EQU     24          ; terminal row count
SCRCOLS EQU     80          ; terminal column count
EDITROW EQU     20          ; edit rows (rows 3-22)
EDITFR  EQU     3           ; first edit row (1-based)
INFOROW EQU     1           ; info bar row
RULRROW EQU     2           ; tab ruler row
SEPRROW EQU     23          ; separator (===) row
STATROW EQU     24          ; status/message row
LNUMWID EQU     5           ; gutter width (4+space)
TXTCOLS EQU     73          ; max text columns/line
MAXCOLS EQU     255         ; max chars per line (raw bytes)
TXTFCOL EQU     6           ; text start col (1-based)
TABWID  EQU     4           ; tab stop interval

;--- SGR attribute byte values ------------------------
ATTR_NRM EQU    00H         ; normal
ATTR_BLD EQU    01H         ; bold
ATTR_DIM EQU    02H         ; dim
ATTR_REV EQU    07H         ; reverse video
ATTR_CYN EQU    36H         ; cyan foreground
ATTR_GRN EQU    32H         ; green foreground
ATTR_YEL EQU    33H         ; yellow foreground
ATTR_MAG EQU    35H         ; magenta foreground

;--- Buffer descriptor field offsets -----------------
BD_BSTAR EQU    0           ; 2: buffer base address
BD_BSIZE EQU    2           ; 2: capacity in bytes
BD_GAPBG EQU    4           ; 2: gap start offset
BD_GAPEN EQU    6           ; 2: gap end offset
BD_TXEND EQU    8           ; 2: text end offset
BD_TOPLN EQU    10          ; 2: top visible line
BD_CSROW EQU    12          ; 1: cursor screen row
BD_CSCOL EQU    13          ; 1: cursor text column
BD_CSOFF EQU    14          ; 2: cursor byte offset
BD_MRKBG EQU    16          ; 2: block mark start
BD_MRKEN EQU    18          ; 2: block mark end
BD_MODIF EQU    20          ; 1: modified flag
BD_SYNMD EQU    21          ; 1: syntax mode
BD_FNAME EQU    22          ; 12: drive+name+ext
BD_SIZE  EQU    34          ; bytes per descriptor

;--- Number of edit buffers ---------------------------
MAXBUFS EQU     1           ; maximum open buffers
MINMEM  EQU     9*1024      ; minimum TPA required

;--- Syntax mode codes --------------------------------
SYN_NONE EQU    0           ; plain text
SYN_ASM  EQU    1           ; 8080/Z80 assembly

;--- Insert / overwrite mode --------------------------
MODE_INS EQU    0           ; insert mode (default)
MODE_OVR EQU    1           ; overwrite mode

;--- Key type codes (B reg from GETKEY) ---------------
KT_NONE EQU     0           ; no key available
KT_ACT  EQU     1           ; C = action code
KT_CHAR EQU     2           ; C = printable char

;--- Key action codes (C reg when B=KT_ACT) ----------
ACT_CURUP EQU   1           ; cursor up
ACT_CURDN EQU   2           ; cursor down
ACT_CURLT EQU   3           ; cursor left
ACT_CURRT EQU   4           ; cursor right
ACT_WRDPV EQU   5           ; previous word
ACT_WRDNX EQU   6           ; next word
ACT_PGUP  EQU   7           ; page up
ACT_PGDN  EQU   8           ; page down
ACT_SCRUP EQU   9           ; scroll screen up
ACT_SCRDN EQU   10          ; scroll screen down
ACT_LINST EQU   11          ; jump to line start
ACT_LINEN EQU   12          ; jump to line end
ACT_FTOP  EQU   13          ; jump to file top
ACT_FEND  EQU   14          ; jump to file end
ACT_DELLF EQU   15          ; delete left (BS)
ACT_DELRT EQU   16          ; delete right (Del)
ACT_DELWD EQU   17          ; delete word right
ACT_DELLN EQU   18          ; delete entire line
ACT_INSTB EQU   19          ; insert tab
ACT_INSNL EQU   20          ; insert newline
ACT_TOGIN EQU   21          ; toggle insert/overwrite
ACT_LITNX EQU   22          ; next char is literal
ACT_FNDNX EQU   23          ; find next
ACT_FSAVE EQU   24          ; save file
ACT_FOPEN EQU   25          ; open file
ACT_FEXIT EQU   26          ; exit editor
ACT_BLKMK EQU   27          ; toggle block mark
ACT_BLKCP EQU   28          ; copy block
ACT_BLKDL EQU   29          ; delete block
ACT_BLKPS EQU   30          ; paste clipboard
ACT_MENU  EQU   31          ; open ESC menu
ACT_MAX   EQU   31          ; highest action code

;--- Block mark sentinel ------------------------------
NO_MARK EQU     0FFFFH      ; marks absent/unset

;--- FCB field offsets --------------------------------
FCB_DR  EQU     0           ; drive (0=default)
FCB_FN  EQU     1           ; filename (8 bytes)
FCB_FT  EQU     9           ; extension (3 bytes)
FCB_EX  EQU     12          ; extent number
FCB_S2  EQU     14          ; extent high
FCB_RC  EQU     15          ; record count
FCB_CR  EQU     32          ; current record
FCB_SIZ EQU     36          ; total FCB size

;--- DMA record size ----------------------------------
RECSIZ  EQU     128         ; 128 bytes per record

;--- Clipboard buffer size ----------------------------
CLIPMAX EQU     2048        ; max paste buffer bytes

;--- Search string size limit -------------------------
SRCHMAX EQU     64          ; max find string length

        CSEG

;=============================================================
; SRFIND - Find with prompt (always asks for search string).
; Entry:  (none)
; Exit:   Cursor moved to match if found; all regs clobbered.
;=============================================================
SRFIND:
        XRA     A
        STA     SRCHSTR         ; clear string to force prompt
        ; Fall through to SRFNDNX

;=============================================================
; SRFNDNX - Find next (repeat last search; prompt if none).
; Entry:  (none)
; Exit:   Cursor moved to match if found; all regs clobbered.
;=============================================================
SRFNDNX:
        ; If search string is empty, prompt for one
        LDA     SRCHSTR
        ORA     A
        JNZ     SRFNDS          ; already have a string

        ; Prompt for search string on status line
        LDA     RSTAT
        MOV     B,A
        MVI     C,1
        CALL    CURGOTO
        LXI     D,SRCHPMT
        CALL    OUTSTR
        LXI     D,SRDINBUF
        MVI     C,BF_RDLINE
        CALL    BDOS
        LDA     SRDINBUF+1
        ORA     A
        RZ                      ; empty input = cancel

        ; Copy to SRCHSTR (NUL-terminated, max SRCHMAX)
        MVI     B,0
        MOV     C,A             ; C = length
        LXI     H,SRDINBUF+2   ; source
        LXI     D,SRCHSTR       ; dest
SRNCPL: MOV     A,M
        STAX    D
        INX     H
        INX     D
        INR     B
        MOV     A,B
        CMP     C
        JNZ     SRNCPL
        XRA     A
        STAX    D               ; NUL

        ; Store length
        MOV     A,C
        STA     SRCHLEN

SRFNDS:
        ; Set start = cursor offset + 1
        LHLD    CURBDP
        PUSH    H

        ; Read CSOFF (cursor byte offset)
        MOV     A,L
        ADI     BD_CSOFF
        MOV     L,A
        MOV     A,H
        ACI     0
        MOV     H,A
        MOV     E,M
        INX     H
        MOV     D,M             ; DE = cursor offset
        MOV     A,E
        ADI     1
        MOV     E,A
        MOV     A,D
        ACI     0
        MOV     D,A             ; DE = cursor+1
        XCHG
        SHLD    SRSTART         ; start of forward search

        POP     H               ; restore descriptor ptr

        ; Read TXEND
        MOV     A,L
        ADI     BD_TXEND
        MOV     L,A
        MOV     A,H
        ACI     0
        MOV     H,A
        MOV     E,M
        INX     H
        MOV     D,M
        XCHG
        SHLD    SRTXEND         ; end of text

        ; Compute search string length
        LDA     SRCHLEN
        MOV     B,A             ; B = pattern length
        ORA     A
        RZ

        ; --- Forward search from SRSTART to SRTXEND-SRCHLEN ---
        LHLD    SRSTART
        SHLD    SRPOS           ; current probe position

SRFLP:
        ; Check if SRPOS + SRCHLEN > SRTXEND
        LHLD    SRPOS
        LDA     SRCHLEN
        MOV     C,A
        MVI     B,0
        DAD     B               ; HL = SRPOS + SRCHLEN
        XCHG
        LHLD    SRTXEND
        ; compare HL (SRTXEND) with DE (SRPOS+len)
        MOV     A,H
        CMP     D
        JC      SRFWRP          ; SRTXEND < SRPOS+len: past end
        JNZ     SRFCHK          ; SRTXEND > SRPOS+len: ok
        MOV     A,L
        CMP     E
        JC      SRFWRP          ; equal means ok, carry means less

SRFCHK:
        ; Try to match at SRPOS
        LHLD    SRPOS
        CALL    SRTRY           ; Z set if match
        JZ      SRFND

        ; Advance SRPOS by 1
        LHLD    SRPOS
        INX     H
        SHLD    SRPOS
        JMP     SRFLP

SRFWRP:
        ; Check if we already wrapped
        LDA     SRWRAP
        ORA     A
        JNZ     SRNFND          ; second time around = not found

        ; Wrap: search from 0 to original SRSTART
        MVI     A,1
        STA     SRWRAP
        LXI     H,0
        SHLD    SRPOS

SRWLP:
        ; Check SRPOS < SRSTART
        LHLD    SRPOS
        XCHG
        LHLD    SRSTART
        ; if HL (SRSTART) <= DE (SRPOS) then stop
        MOV     A,H
        CMP     D
        JC      SRNFND          ; SRSTART < SRPOS: done
        JNZ     SRWCHK
        MOV     A,L
        CMP     E
        JNC     SRNFND          ; SRSTART >= SRPOS: done

SRWCHK:
        LHLD    SRPOS
        CALL    SRTRY
        JZ      SRFND

        LHLD    SRPOS
        INX     H
        SHLD    SRPOS
        JMP     SRWLP

SRFND:
        ; Found at SRPOS: move cursor there
        ; Reset wrap flag
        XRA     A
        STA     SRWRAP

        ; Navigate: move cursor to file top then advance
        ; to logical offset SRPOS
        ; More efficient: use GBMVRT from current position
        ; but simplest is top + advance
        CALL    GBMVTOP

        LHLD    SRPOS
        SHLD    SRNAV           ; target offset

SRNAVL:
        LHLD    SRNAV
        MOV     A,H
        ORA     L
        JZ      SRNAVD
        ; Advance cursor right one position
        CALL    GBMVRT
        LHLD    SRNAV
        DCX     H
        SHLD    SRNAV
        JMP     SRNAVL

SRNAVD:
        MVI     A,1
        STA     DIRTY
        LXI     D,SRFMSG
        JMP     STATMSG

SRNFND:
        XRA     A
        STA     SRWRAP
        LXI     D,SRNFMS
        JMP     STATMSG

;=============================================================
; SRTRY - Try to match SRCHSTR at logical offset HL.
; Entry:  HL = logical start offset to try
; Exit:   Zero flag set if full match, clear if no match.
;         Regs: B, C, D, E, H, L clobbered.
;=============================================================
SRTRY:
        LDA     SRCHLEN
        MOV     B,A             ; B = chars remaining
        LXI     D,SRCHSTR       ; DE = pattern pointer
        ; HL = current logical offset

STRLP:
        MOV     A,B
        ORA     A
        JZ      STRMCH          ; all chars matched

        ; Read logical byte at HL from gap buffer
        PUSH    B
        PUSH    D
        PUSH    H
        CALL    SRGBRD          ; A = byte at logical HL
        POP     H
        POP     D
        POP     B

        ; Compare with pattern char
        MOV     C,A             ; C = text byte
        LDAX    D               ; A = pattern byte

        ; Case-insensitive if SRCHOPTS bit 0 set
        PUSH    H
        LXI     H,SRCHOPTS
        MOV     H,M
        POP     H
        MOV     A,H             ; A = SRCHOPTS value... wrong
        ; Simpler: just read SRCHOPTS directly
        PUSH    B
        PUSH    D
        LDA     SRCHOPTS
        ANI     01H
        POP     D
        POP     B

        MOV     A,C             ; text byte
        JZ      STRNCI          ; not case-insensitive
        ; Upper-case both
        CALL    SRUPR
        MOV     C,A
        LDAX    D
        CALL    SRUPR
        JMP     STRCMP
STRNCI: LDAX    D               ; pattern byte unchanged

STRCMP: CMP     C               ; compare
        RNZ                     ; no match

        INX     D               ; advance pattern
        INX     H               ; advance offset
        DCR     B
        JMP     STRLP

STRMCH: ; Zero flag already set from "ORA A" path
        XRA     A               ; ensure Z set
        RET

;------------------------------------------------------------
; SRUPR - Convert A to upper case.
;------------------------------------------------------------
SRUPR:
        CPI     'a'
        RC
        CPI     'z'+1
        RNC
        ANI     5FH
        RET

;=============================================================
; SRGBRD - Read one byte from gap buffer at logical offset HL.
; Entry:  HL = logical byte offset
; Exit:   A  = byte value
; Reads via descriptor, adjusting for gap position.
;=============================================================
SRGBRD:
        ; Save logical offset (HL) before we clobber it
        SHLD    SROFF2

        ; Read GAPBG from descriptor
        LHLD    CURBDP
        MOV     A,L
        ADI     BD_GAPBG
        MOV     L,A
        MOV     A,H
        ACI     0
        MOV     H,A
        MOV     E,M
        INX     H
        MOV     D,M             ; DE = GAPBG

        ; Compare logical offset with GAPBG
        LHLD    SROFF2          ; HL = logical offset
        MOV     A,H
        CMP     D
        JC      SRGBEF          ; high byte less: before gap
        JNZ     SRGAFT          ; high byte greater: after gap
        MOV     A,L
        CMP     E
        JNC     SRGAFT          ; logical >= GAPBG: after gap

SRGBEF: ; Before gap: physical addr = BSTAR + logical
        LHLD    CURBDP
        MOV     A,L
        ADI     BD_BSTAR
        MOV     L,A
        MOV     A,H
        ACI     0
        MOV     H,A
        MOV     C,M
        INX     H
        MOV     B,M             ; BC = BSTAR
        LHLD    SROFF2          ; HL = logical offset
        DAD     B               ; HL = BSTAR + logical
        MOV     A,M             ; read byte
        RET

SRGAFT: ; After gap: physical addr = BSTAR + logical + (GAPEN - GAPBG)
        ; DE still = GAPBG from above
        PUSH    D               ; save GAPBG on stack
        ; Read GAPEN
        LHLD    CURBDP
        MOV     A,L
        ADI     BD_GAPEN
        MOV     L,A
        MOV     A,H
        ACI     0
        MOV     H,A
        MOV     E,M
        INX     H
        MOV     D,M             ; DE = GAPEN
        ; gapsize = GAPEN(DE) - GAPBG(stack)
        POP     H               ; HL = GAPBG
        MOV     A,E
        SUB     L
        MOV     C,A
        MOV     A,D
        SBB     H
        MOV     B,A             ; BC = gap size
        ; Read BSTAR
        LHLD    CURBDP
        MOV     A,L
        ADI     BD_BSTAR
        MOV     L,A
        MOV     A,H
        ACI     0
        MOV     H,A
        MOV     E,M
        INX     H
        MOV     D,M             ; DE = BSTAR
        ; addr = BSTAR + logical + gapsize
        LHLD    SROFF2          ; HL = logical offset
        DAD     B               ; HL = logical + gapsize
        DAD     D               ; HL = logical + gapsize + BSTAR
        MOV     A,M             ; read byte
        RET

;=============================================================
; SRREPL - Find and replace (interactive).
; Prompts for search string, then replacement string.
; For each match found: redraws screen, shows cursor at match,
; prompts "Replace? (Y/N/A/Esc)" on status line.
;   Y = replace this one and continue
;   N = skip this one and continue
;   A = replace all remaining without asking
;   Esc = stop
; Entry:  (none)
; Exit:   Status message shows count; DIRTY set.
;=============================================================
SRREPL:
        ; Prompt for search string
        CALL    STATCLR
        LDA     RSTAT
        MOV     B,A
        MVI     C,1
        CALL    CURGOTO
        LXI     D,SRCHPMT
        CALL    OUTSTR
        LXI     D,SRDINBUF
        MVI     C,BF_RDLINE
        CALL    BDOS
        LDA     SRDINBUF+1
        ORA     A
        JZ      SRRCAN          ; empty = cancel

        ; Copy to SRCHSTR
        MVI     B,0
        MOV     C,A
        LXI     H,SRDINBUF+2
        LXI     D,SRCHSTR
SRRCPL: MOV     A,M
        STAX    D
        INX     H
        INX     D
        INR     B
        MOV     A,B
        CMP     C
        JNZ     SRRCPL
        XRA     A
        STAX    D               ; NUL terminate
        MOV     A,C
        STA     SRCHLEN

        ; Prompt for replacement string
        CALL    STATCLR
        LDA     RSTAT
        MOV     B,A
        MVI     C,1
        CALL    CURGOTO
        LXI     D,SRRLPMT
        CALL    OUTSTR
        LXI     D,SRRDINBUF
        MVI     C,BF_RDLINE
        CALL    BDOS
        ; Empty replacement is valid (means delete matches)
        LDA     SRRDINBUF+1
        STA     SRRLEN

        ; Copy to SRREPSTR
        ORA     A
        JZ      SRRNUL          ; zero-length: just NUL terminate
        MVI     B,0
        MOV     C,A
        LXI     H,SRRDINBUF+2
        LXI     D,SRREPSTR
SRRCP2: MOV     A,M
        STAX    D
        INX     H
        INX     D
        INR     B
        MOV     A,B
        CMP     C
        JNZ     SRRCP2
SRRNUL: LXI     H,SRREPSTR
        LDA     SRRLEN
        MOV     C,A
        MVI     B,0
        DAD     B
        MVI     M,0             ; NUL terminate

        ; Initialize: start from top of file
        XRA     A
        STA     SRWRAP
        STA     SRRALL          ; not "replace all" mode
        STA     SRRCNT          ; replacement count = 0
        STA     SRRCNT+1
        CALL    GBMVTOP

        ; Set SRSTART = 0 (search from top)
        LXI     H,0
        SHLD    SRSTART

        ; Cache TXEND
        LHLD    CURBDP
        MOV     A,L
        ADI     BD_TXEND
        MOV     L,A
        MOV     A,H
        ACI     0
        MOV     H,A
        MOV     E,M
        INX     H
        MOV     D,M
        XCHG
        SHLD    SRTXEND

        ; Start search at offset 0
        LXI     H,0
        SHLD    SRPOS

        ; --- Main replace loop ---
SRRLP:
        ; Check if SRPOS + SRCHLEN > SRTXEND
        LHLD    SRPOS
        LDA     SRCHLEN
        MOV     C,A
        MVI     B,0
        DAD     B
        XCHG                    ; DE = SRPOS + len
        LHLD    SRTXEND
        MOV     A,H
        CMP     D
        JC      SRRDON          ; past end
        JNZ     SRRCHK
        MOV     A,L
        CMP     E
        JC      SRRDON

SRRCHK:
        ; Try match at SRPOS
        LHLD    SRPOS
        CALL    SRTRY
        JNZ     SRRADV          ; no match, advance

        ; Match found — navigate cursor to SRPOS
        CALL    GBMVTOP
        LHLD    SRPOS
        SHLD    SRNAV
SRRNAVL:
        LHLD    SRNAV
        MOV     A,H
        ORA     L
        JZ      SRRNAVD
        CALL    GBMVRT
        LHLD    SRNAV
        DCX     H
        SHLD    SRNAV
        JMP     SRRNAVL
SRRNAVD:
        ; Redraw screen to show cursor at match
        CALL    SCRDRAW
        CALL    INFOBAR
        CALL    CURPOS

        ; Highlight matched text in reverse video
        LXI     D,SRHLRV        ; ESC[7m — reverse on
        CALL    OUTSTR
        LDA     SRCHLEN
        STA     SRHLCNT
        LHLD    SRPOS
        SHLD    SRHLOFF
SRHLLP: LDA     SRHLCNT
        ORA     A
        JZ      SRHLDN
        LHLD    SRHLOFF
        CALL    SRGBRD          ; A = byte at logical offset
        MOV     E,A
        PUSH    H
        MVI     C,BF_RAWIO
        CALL    BDOS
        POP     H
        LHLD    SRHLOFF
        INX     H
        SHLD    SRHLOFF
        LDA     SRHLCNT
        DCR     A
        STA     SRHLCNT
        JMP     SRHLLP
SRHLDN: LXI     D,SRHLNR        ; ESC[0m — reset
        CALL    OUTSTR

        ; Check "replace all" mode
        LDA     SRRALL
        ORA     A
        JNZ     SRRYES          ; auto-replace

        ; Prompt: Replace? (Y/N/A/Esc)
        LDA     RSTAT
        MOV     B,A
        MVI     C,1
        CALL    CURGOTO
        LXI     D,SRRQPMT
        CALL    OUTSTR

        ; Wait for response
SRRKEY: MVI     E,0FFH
        MVI     C,BF_RAWIO
        CALL    BDOS
        ORA     A
        JZ      SRRKEY
        ; Check response
        CPI     'Y'
        JZ      SRRYES
        CPI     'y'
        JZ      SRRYES
        CPI     'N'
        JZ      SRRNO
        CPI     'n'
        JZ      SRRNO
        CPI     'A'
        JZ      SRRALL1
        CPI     'a'
        JZ      SRRALL1
        CPI     ESC
        JZ      SRRDON
        JMP     SRRKEY          ; unrecognised, try again

SRRALL1:
        MVI     A,1
        STA     SRRALL          ; enable replace-all mode
        ; Fall through to replace

SRRYES:
        ; Delete SRCHLEN bytes at cursor
        LDA     SRCHLEN
        STA     SRRDCNT
SRRYDL: LDA     SRRDCNT
        ORA     A
        JZ      SRRYINS
        CALL    GBDELRT
        LDA     SRRDCNT
        DCR     A
        STA     SRRDCNT
        JMP     SRRYDL

SRRYINS:
        ; Insert replacement string
        LDA     SRRLEN
        ORA     A
        JZ      SRRYDN          ; empty replacement
        STA     SRRICNT
        LXI     H,SRREPSTR
        SHLD    SRRIPTR
SRRYILP:
        LHLD    SRRIPTR
        MOV     A,M
        PUSH    H
        CALL    GBINSRT
        POP     H
        INX     H
        SHLD    SRRIPTR
        LDA     SRRICNT
        DCR     A
        STA     SRRICNT
        JNZ     SRRYILP

SRRYDN:
        ; Increment replacement count
        LHLD    SRRCNT
        INX     H
        SHLD    SRRCNT

        ; Re-cache TXEND (length changed)
        LHLD    CURBDP
        MOV     A,L
        ADI     BD_TXEND
        MOV     L,A
        MOV     A,H
        ACI     0
        MOV     H,A
        MOV     E,M
        INX     H
        MOV     D,M
        XCHG
        SHLD    SRTXEND

        ; Read new CSOFF as next SRPOS (cursor is past replacement)
        LHLD    CURBDP
        MOV     A,L
        ADI     BD_CSOFF
        MOV     L,A
        MOV     A,H
        ACI     0
        MOV     H,A
        MOV     E,M
        INX     H
        MOV     D,M
        XCHG
        SHLD    SRPOS
        JMP     SRRLP

SRRNO:
        ; Skip: advance SRPOS past this match
        LHLD    SRPOS
        INX     H
        SHLD    SRPOS
        JMP     SRRLP

SRRADV:
        ; No match: advance by 1
        LHLD    SRPOS
        INX     H
        SHLD    SRPOS
        JMP     SRRLP

SRRDON:
        ; Done — show result
        MVI     A,1
        STA     DIRTY
        LHLD    SRRCNT
        MOV     A,H
        ORA     L
        JZ      SRRD0
        ; Show "N replacements."
        CALL    STATCLR
        LDA     RSTAT
        MOV     B,A
        MVI     C,1
        CALL    CURGOTO
        LHLD    SRRCNT
        CALL    SRDECHL         ; print count as decimal
        LXI     D,SRRPMSG
        JMP     OUTSTR

SRRD0:  LXI     D,SRNFMS        ; "Not found."
        JMP     STATMSG

SRRCAN: ; Cancel from prompts
        JMP     STATCLR

;------------------------------------------------------------
; SRDECHL - Print HL as decimal, no leading zeros.
; Clobbers all regs.
;------------------------------------------------------------
SRDECHL:
        LXI     D,10000
        MVI     B,0             ; leading zero suppress
        CALL    SRDDIG
        LXI     D,1000
        CALL    SRDDIG
        LXI     D,100
        CALL    SRDDIG
        LXI     D,10
        CALL    SRDDIG
        MOV     A,L
        ADI     '0'
        MOV     E,A
        MVI     C,BF_RAWIO
        JMP     BDOS
SRDDIG: MVI     C,0
SRDDLP: MOV     A,L
        SUB     E
        MOV     L,A
        MOV     A,H
        SBB     D
        MOV     H,A
        JC      SRDDR
        INR     C
        JMP     SRDDLP
SRDDR:  MOV     A,L
        ADD     E
        MOV     L,A
        MOV     A,H
        ADC     D
        MOV     H,A
        MOV     A,C
        ORA     A
        JNZ     SRDDO
        MOV     A,B
        ORA     A
        RZ                      ; leading zero, skip
SRDDO:  MVI     B,1
        MOV     A,C
        ADI     '0'
        MOV     E,A
        MVI     C,BF_RAWIO
        JMP     BDOS

;=============================================================
; SRJMPM - Jump to matching brace { or }.
; If cursor is on {, scan forward for matching }.
; If cursor is on }, scan backward for matching {.
; Otherwise ring bell. Scans within buffer bounds only.
; Entry:  CURBDP valid
; Exit:   Cursor moved if match found. DIRTY set.
;         Bell if no match or not on a brace.
;=============================================================
SRJMPM:
        ; Read CSOFF from descriptor
        LHLD    CURBDP
        MOV     A,L
        ADI     BD_CSOFF
        MOV     L,A
        MOV     A,H
        ACI     0
        MOV     H,A
        MOV     E,M
        INX     H
        MOV     D,M             ; DE = cursor offset
        XCHG
        SHLD    SJMPOS          ; save cursor offset

        ; Read TXEND
        LHLD    CURBDP
        MOV     A,L
        ADI     BD_TXEND
        MOV     L,A
        MOV     A,H
        ACI     0
        MOV     H,A
        MOV     E,M
        INX     H
        MOV     D,M
        XCHG
        SHLD    SJMEND          ; save text end

        ; Read byte at cursor
        LHLD    SJMPOS
        CALL    SRGBRD          ; A = byte at cursor
        CPI     '{'
        JZ      SJMFWD          ; scan forward for }
        CPI     '}'
        JZ      SJMBWD          ; scan backward for {
        ; Not on a brace — silently ignore
        RET

SJMFWD: ; Scan forward from CSOFF+1 for matching }
        ; depth = 1 (we're on the opening {)
        MVI     A,1
        STA     SJMDEP
        LHLD    SJMPOS
        INX     H               ; start at CSOFF+1
SJMFLP: ; Check if past end
        XCHG
        LHLD    SJMEND
        MOV     A,H
        CMP     D
        JC      SJMNOMATCH      ; past end
        JNZ     SJMFOK
        MOV     A,L
        CMP     E
        JC      SJMNOMATCH
        JZ      SJMNOMATCH      ; at end
SJMFOK: XCHG                    ; HL = current offset
        PUSH    H
        CALL    SRGBRD          ; A = byte
        POP     H
        CPI     '{'
        JZ      SJMFINC
        CPI     '}'
        JZ      SJMFDEC
        INX     H
        JMP     SJMFLP
SJMFINC: ; Deeper nesting
        LDA     SJMDEP
        INR     A
        STA     SJMDEP
        INX     H
        JMP     SJMFLP
SJMFDEC: ; Closing brace
        LDA     SJMDEP
        DCR     A
        STA     SJMDEP
        ORA     A
        JZ      SJMFND          ; depth 0 = found match
        INX     H
        JMP     SJMFLP

SJMBWD: ; Scan backward from CSOFF-1 for matching {
        ; depth = 1 (we're on the closing })
        MVI     A,1
        STA     SJMDEP
        LHLD    SJMPOS
        MOV     A,H
        ORA     L
        JZ      SJMNOMATCH      ; at offset 0, can't go back
        DCX     H               ; start at CSOFF-1
SJMBLP: PUSH    H
        CALL    SRGBRD          ; A = byte
        POP     H
        CPI     '}'
        JZ      SJMBINC
        CPI     '{'
        JZ      SJMBDEC
        ; Check if at offset 0
        MOV     A,H
        ORA     L
        JZ      SJMNOMATCH
        DCX     H
        JMP     SJMBLP
SJMBINC: ; Deeper nesting
        LDA     SJMDEP
        INR     A
        STA     SJMDEP
        MOV     A,H
        ORA     L
        JZ      SJMNOMATCH
        DCX     H
        JMP     SJMBLP
SJMBDEC: ; Opening brace
        LDA     SJMDEP
        DCR     A
        STA     SJMDEP
        ORA     A
        JZ      SJMFND          ; depth 0 = found match
        MOV     A,H
        ORA     L
        JZ      SJMNOMATCH
        DCX     H
        JMP     SJMBLP

SJMFND: ; Match found at HL — navigate cursor there
        SHLD    SJMTGT          ; save target offset
        CALL    GBMVTOP         ; move to top
        LHLD    SJMTGT
        SHLD    SRNAV
SJMNVL: LHLD    SRNAV
        MOV     A,H
        ORA     L
        JZ      SJMNVD
        CALL    GBMVRT
        LHLD    SRNAV
        DCX     H
        SHLD    SRNAV
        JMP     SJMNVL
SJMNVD: MVI     A,1
        STA     DIRTY
        RET

SJMNOMATCH:
        LXI     D,SJMNMSG
        CALL    STATMSG
SJMBELL:
        MVI     E,BEL
        MVI     C,BF_RAWIO
        JMP     BDOS

;=============================================================
; DATA SEGMENT
;=============================================================
        DSEG

; Search string (NUL terminated)
SRCHSTR: DS     SRCHMAX+1

; Search string length
SRCHLEN: DB     0

; Search options: bit 0 = case-insensitive
SRCHOPTS: DB    01H             ; default: case-insensitive

; Search state
SRSTART: DW     0               ; start offset for this search
SRTXEND: DW     0               ; cached text end
SRPOS:   DW     0               ; current probe position
SRNAV:   DW     0               ; navigation target
SRWRAP:  DB     0               ; 1 = wrapped around
SROFF2:  DW     0               ; logical offset for SRGBRD

; Input buffers for prompts
SRDINBUF: DB   SRCHMAX          ; max len
          DB   0                ; actual len
          DS   SRCHMAX+2        ; chars

; Replacement string (NUL terminated)
SRREPSTR: DS   SRCHMAX+1
SRRLEN:  DB    0               ; replacement string length

; Replace state
SRRALL:  DB    0               ; 1 = replace all without asking
SRRCNT:  DW    0               ; replacement count
SRRDCNT: DB    0               ; delete counter (working)
SRRICNT: DB    0               ; insert counter (working)
SRRIPTR: DW    0               ; insert pointer (working)

; Replacement input buffer
SRRDINBUF: DB  SRCHMAX         ; max len
           DB  0               ; actual len
           DS  SRCHMAX+2       ; chars

; Highlight working variables
SRHLCNT: DB    0               ; highlight byte counter
SRHLOFF: DW    0               ; highlight logical offset

; Highlight SGR strings
SRHLRV: DB     ESC,'[','0',';','7','m','$'  ; reverse video on
SRHLNR: DB     ESC,'[','0','m','$'          ; reset attributes

; Status messages
SRCHPMT: DB    'Search: $'
SRRLPMT: DB    'Replace: $'
SRRQPMT: DB    'Replace? (Y/N/A/Esc) $'
SRRPMSG: DB    ' replacement(s).$'
SRFMSG:  DB    'Found.  $'
SRNFMS:  DB    'Not found.$'
SJMNMSG: DB    'No match.$'

; Jump-to-match working variables
SJMPOS:  DW    0               ; cursor offset
SJMEND:  DW    0               ; text end
SJMDEP:  DB    0               ; nesting depth counter
SJMTGT:  DW    0               ; target offset (match location)

        END

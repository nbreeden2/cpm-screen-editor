;============================================================
; FILE:    SEDIT.MAC
; PROJECT: SEDIT - Screen Editor for CP/M 2.2
; VERSION: 1.0
; DATE:    1984-01-01
; AUTHOR: Claude Code and RetroTechReboot
;------------------------------------------------------------
; DESCRIPTION:
;   Root module. Contains START: entry point, TPA memory
;   detection, module initialization, and main edit loop.
;------------------------------------------------------------
; BUILD INSTRUCTIONS:
;   Assemble each module:
;     M80 =SEDIT
;     M80 =SESCREEN
;     M80 =SEKEY
;     M80 =SEGAPBUF
;     M80 =SEFILEIO
;     M80 =SEMENU
;     M80 =SESEARCH
;     M80 =SEBLOCK
;     M80 =SESYNTAX
;     M80 =SEKEYBND
;     M80 =SEHELP
;   Link (one command, split here for readability):
;     L80 SEDIT,SESCREEN,SEKEY,SEGAPBUF,SEFILEIO,
;         SEMENU,SESEARCH,SEBLOCK,SESYNTAX,
;         SEKEYBND,SEVIRTIO,SEHELP,SEDIT/N/E
;   Or run: SUBMIT BUILD
;------------------------------------------------------------
; REVISION HISTORY:
;   1.0  1984-01-01  Initial release
;============================================================
        INCLUDE SEDIT.INC


;--- Cross-module entry points ------------------------
        EXTRN   BMDATEND        ; end-of-DSEG marker (SEHELP)
        EXTRN   GBINIT          ; initialise gap buffer
        EXTRN   KBINIT          ; key binding init
        EXTRN   GETKEY          ; read next key
        EXTRN   SCRINIT         ; screen init/clear
        EXTRN   SCRDRAW         ; full screen redraw
        EXTRN   SCREDCL         ; redraw current line only
        EXTRN   STATMSG         ; status bar message
        EXTRN   INFOBAR         ; update info bar
        EXTRN   CURPOS          ; position hw cursor
        EXTRN   GBINSRT         ; insert char at gap
        EXTRN   GBBASE          ; DE = buffer base address
        EXTRN   GBBSIZ          ; DE = buffer size
        EXTRN   GBGAPBG         ; HL = gap start offset
        EXTRN   GBGAPEN         ; HL = gap end offset
        EXTRN   GBDLFT         ; delete left (BS)
        EXTRN   GBDELRT         ; delete right (Del)
        EXTRN   GBTMP           ; last deleted/inserted char
        EXTRN   GBMVUP          ; cursor up one line
        EXTRN   GBMVDN          ; cursor down one line
        EXTRN   GBMVLT          ; cursor left one char
        EXTRN   GBMVRT          ; cursor right one char
        EXTRN   GBMLNS         ; cursor to line start
        EXTRN   GBMLNE         ; cursor to line end
        EXTRN   GBMVTOP         ; cursor to file top
        EXTRN   GBMVEND         ; cursor to file end
        EXTRN   GBPGUP          ; page up
        EXTRN   GBPGDN          ; page down
        EXTRN   GBDLLN         ; delete current line
        EXTRN   GBWRDPV         ; move to prev word
        EXTRN   GBWRDNX         ; move to next word
        EXTRN   GBCURLN         ; get current line text
        EXTRN   FIOPEN          ; load file to buffer
        EXTRN   FISAVE          ; save buffer to file
        EXTRN   FISAVFN         ; copy WRKFCB name to BD_FNAME
        EXTRN   FISMOD          ; read BD_MODIF flag
        EXTRN   FIPROMPT        ; prompt for filename
        EXTRN   SYNINIT         ; detect syntax mode from filename
        EXTRN   CURGOTO         ; position cursor (B=row, C=col)
        EXTRN   MNUSHOW         ; run ESC menu
        EXTRN   SRFIND          ; find (always prompt)
        EXTRN   SRFNDNX         ; find next
        EXTRN   SRREPL          ; find and replace
        EXTRN   SRJMPM          ; jump to matching brace
        EXTRN   BLMARK          ; toggle block mark
        EXTRN   BLCOPY          ; copy block
        EXTRN   BLDEL           ; delete block
        EXTRN   BLPASTE         ; paste clipboard
        EXTRN   HLPSHOW         ; show help screen
        EXTRN   VIINIT          ; init virtual I/O (SEVIRTIO)
        EXTRN   VICLEAN         ; cleanup virtual I/O

;--- Exported symbols ---------------------------------
        PUBLIC  INSMODE         ; insert/overwrite flag
        PUBLIC  DIRTY           ; screen redraw needed
        PUBLIC  SAVWMSG         ; "Saving file" message
        PUBLIC  CURBDP          ; current buf desc ptr
        PUBLIC  TPATOP          ; TPA top address
        PUBLIC  DOEXIT          ; exit handler (for SEMENU)
        PUBLIC  HSCROL          ; horizontal scroll offset
        PUBLIC  COLMOD          ; column mode (0=80, 1=132)
        PUBLIC  RTXTCL          ; runtime text columns
        PUBLIC  RSCRCL          ; runtime screen columns
        PUBLIC  RTXTTB          ; runtime TXTCOLS-TABWID
        PUBLIC  VTMPDRV         ; virtual temp file drive (0=default)
        PUBLIC  REROWS          ; runtime edit rows
        PUBLIC  RSEPR           ; runtime separator row
        PUBLIC  RSTAT           ; runtime status row
        PUBLIC  INITCOL         ; initial column mode at startup
        PUBLIC  DSROWS          ; detected terminal rows
        PUBLIC  DSCOLS          ; detected terminal columns
        PUBLIC  DSCPBUF         ; DSR collect buffer
        PUBLIC  DSCPWR          ; DSR collect write index
        PUBLIC  DSCPTM          ; DSR temp byte

        EXTRN   FILUSR          ; file's user number (FFH=unset)
        EXTRN   ORGUSR          ; original user number at startup
        EXTRN   FISWUSR         ; switch to file's user area
        EXTRN   FIRSTUSR        ; restore original user area
        EXTRN   FILNBUF         ; filename buffer (SEFILEIO)
        EXTRN   WRKFCB          ; working FCB (SEFILEIO)
        EXTRN   FIPARSN         ; parse filename with drive+user
        EXTRN   DETSIZ          ; terminal size detection (driver)

;=============================================================
; CODE SEGMENT
;=============================================================
        CSEG

;------------------------------------------------------------
; START - CP/M loads .COM at 0100H and jumps here.
; Entry:  SP near TPA top; FCB at 005CH may hold filename
; Exit:   Never returns (warm boots on exit)
;------------------------------------------------------------
START:
        LXI     H,0             ; capture incoming SP
        DAD     SP
        SHLD    OLDSP           ; save for TPA calc
        LXI     SP,STKTOP       ; set our own stack

        ; Save original user number
        MVI     C,BF_USRNUM
        MVI     E,0FFH          ; E=FFH = get current user
        CALL    BDOS
        STA     ORGUSR          ; save for restore on exit

        ; TPA top = BDOS handler address (operand of JMP at 0005H)
        LHLD    0006H           ; HL = BDOS address = TPA top
        SHLD    TPATOP          ; save it

        ; Initialize single gap buffer (full TPA)
        ; available = TPATOP - BMDATEND
        LXI     D,BMDATEND
        MOV     A,L
        SUB     E
        MOV     C,A
        MOV     A,H
        SBB     D
        MOV     B,A             ; BC = available bytes

        ; Check >= MINMEM
        LXI     H,MINMEM
        MOV     A,B
        CMP     H
        JC      MEMFAIL         ; high byte less
        JNZ     BMOK1           ; high byte greater, ok
        MOV     A,C
        CMP     L
        JC      MEMFAIL         ; equal high, low byte less
BMOK1:
        ; BC = buffer size, DE = base address (BMDATEND)
        LXI     H,BDESC0        ; HL = descriptor
        CALL    GBINIT

        ; Set CURBDP
        LXI     H,BDESC0
        SHLD    CURBDP

        ; Fill BD_FNAME with spaces (12 bytes)
        LXI     H,BDESC0+BD_FNAME
        MVI     B,12
BFINLP: MVI     M,' '
        INX     H
        DCR     B
        JNZ     BFINLP

        ; Initialize key bindings table
        CALL    KBINIT

        ; Detect terminal size and set column mode
        CALL    DETSIZ

        ; Initialize and clear screen, draw chrome
        CALL    SCRINIT

        ; Parse command tail for filename and optional temp drive
        ; Format: SEDIT [d[u]:]name[.ext] [d:]
        ;   d = drive letter, u = user number (0-15)
        ;   Second arg = virtual temp file drive (no user#)
        ; Example: SEDIT C11:FILE.TXT F:
        CALL    CLPARSE         ; parse command tail

        ; Initialize virtual buffer I/O (delete leftover temps)
        CALL    VIINIT

        ; Load file from command line arg if present
        LDA     CLHASF          ; did we find a filename?
        ORA     A
        JZ      MAINLP          ; no file, skip load
        LXI     D,0             ; DE=0: WRKFCB already set
        CALL    FIOPEN          ; load into buffer 0
        INR     A               ; FFH -> 0 = error
        JZ      FILFAIL         ; file too large, exit
        MVI     A,1
        STA     DIRTY           ; force full screen redraw

;------------------------------------------------------------
; MAINLP - Main edit loop
;------------------------------------------------------------
MAINLP:
        ; Auto-scroll horizontally if cursor outside viewport
        CALL    AUTOSCR

        ; Force redraw if marking in progress (highlight tracks cursor)
        MVI     A,BD_MRKEN
        CALL    BDFLD           ; HL -> BD_MRKEN
        MOV     A,M
        INX     H
        ANA     M               ; A = low AND high
        INR     A               ; Z if FFFF
        JNZ     MLNOMK          ; MRKEN != FFFF -> not marking
        ; MRKEN==FFFF; check MRKBG != FFFF
        MVI     A,BD_MRKBG
        CALL    BDFLD           ; HL -> BD_MRKBG
        MOV     A,M
        INX     H
        ANA     M
        INR     A
        JZ      MLNOMK          ; MRKBG == FFFF -> no mark
        ; Marking mode: force full redraw (highlight tracks cursor)
        MVI     A,1
        STA     DIRTY
MLNOMK:
        ; Check redraw level: DIRTY=full, DRTLINE=current line only
        LDA     DIRTY
        ORA     A
        JNZ     MLFULL          ; full redraw takes priority
        LDA     DRTLINE
        ORA     A
        JZ      MLDONE          ; no redraw needed
        ; Line-only redraw
        XRA     A
        STA     DRTLINE
        CALL    SCREDCL         ; redraw current line + info bar
        JMP     MLDONE
MLFULL:
        XRA     A
        STA     DIRTY           ; clear both flags
        STA     DRTLINE
        CALL    SCRDRAW         ; full screen redraw
MLDONE:
        CALL    INFOBAR         ; always update info bar (row/col)
        CALL    CURPOS          ; place HW cursor

        ; Save current row for marking mode line-change detection
        MVI     A,BD_CSROW
        CALL    BDFLD
        MOV     A,M
        STA     MLSROW

        ; Get next key (blocking)
        CALL    GETKEY          ; B=type, C=code/char
        MOV     A,B
        ORA     A
        JZ      MAINLP          ; KT_NONE, try again

        ; Rotate GOALCOL -> PVGOAL, then clear GOALCOL.
        ; Vertical move handlers (DO_CUU/DO_CUD) will restore it.
        PUSH    B               ; save key type+code
        LDA     GOALCOL
        STA     PVGOAL
        MVI     A,0FFH
        STA     GOALCOL
        POP     B
        MOV     A,B             ; restore key type

        CPI     KT_CHAR         ; printable character?
        JZ      DOCHAR

        ; Action code in C - range check then dispatch
        MOV     A,C
        ORA     A
        JZ      MAINLP          ; ACT_NONE
        CPI     ACT_MAX+1
        JNC     MAINLP          ; out of range, ignore

        ; Index into jump table: each entry = 2 bytes
        MOV     L,A
        MVI     H,0
        DAD     H               ; HL = index * 2
        LXI     D,ACTTBL
        DAD     D               ; HL = &ACTTBL[i*2]
        MOV     E,M
        INX     H
        MOV     D,M             ; DE = handler address
        XCHG
        PCHL                    ; jump to handler

        ; Insert/overwrite a printable character (KT_CHAR)
DOCHAR:
        ; Reject insert if cursor already at column limit
        PUSH    B               ; save char in C
        MVI     A,BD_CSCOL
        CALL    BDFLD           ; HL -> BD_CSCOL
        MOV     A,M
        POP     B               ; restore C = char
        CPI     MAXCOLS
        JNC     MAINLP          ; at/past limit, ignore keystroke

        LDA     INSMODE
        CPI     MODE_OVR
        JNZ     DCINS           ; insert mode: skip delete
        ; Overstrike: delete char at cursor unless at EOL/EOF
        CALL    GBGAPEN         ; HL = GAPEN
        PUSH    H
        CALL    GBBSIZ          ; DE = BSIZE
        POP     H
        MOV     A,L
        SUB     E
        MOV     A,H
        SBB     D
        JNC     DCINS           ; at EOF: just insert
        CALL    GBBASE          ; DE = base
        CALL    GBGAPEN         ; HL = GAPEN
        DAD     D               ; HL = abs addr of char at cursor
        MOV     A,M
        CPI     LF
        JZ      DCINS           ; at EOL: just insert
        CALL    GBDELRT         ; delete char at cursor
DCINS:  MOV     A,C             ; character value (C preserved)
        CALL    GBINSRT         ; insert at cursor
        JMP     MLDRTL          ; redraw current line only

;------------------------------------------------------------
; Action handlers - each dispatched from ACTTBL
;------------------------------------------------------------
DO_CUU: CALL    VRTCAP          ; capture goal column
        CALL    SVTOPLN         ; save TOPLN before move
        CALL    GBMVUP
        CALL    VRTADV          ; advance to goal column
        CALL    CHKSCRL         ; full redraw only if scrolled
        JMP     MAINLP
DO_CUD: CALL    VRTCAP
        CALL    SVTOPLN
        CALL    GBMVDN
        CALL    VRTADV
        CALL    CHKSCRL         ; full redraw only if scrolled
        JMP     MAINLP
DO_CUL: CALL    GBMVLT
        JMP     MAINLP          ; cursor-only: no redraw
DO_CUR: CALL    GBMVRT
        JMP     MAINLP          ; cursor-only: no redraw
DO_WPV: CALL    SVTOPLN
        CALL    GBWRDPV
        CALL    CHKSCRL
        JMP     MAINLP
DO_WNX: CALL    SVTOPLN
        CALL    GBWRDNX
        CALL    CHKSCRL
        JMP     MAINLP
DO_PGU: CALL    GBPGUP
        JMP     MLDIRT
DO_PGD: CALL    GBPGDN
        JMP     MLDIRT
        ; DO_SCU/DO_SCD removed: identical to DO_CUU/DO_CUD, merged via ACTTBL
DO_LST: CALL    GBMLNS
        JMP     MAINLP          ; cursor-only: no redraw
DO_LEN: CALL    GBMLNE
        JMP     MAINLP          ; cursor-only: no redraw
DO_FTP: CALL    GBMVTOP
        JMP     MLDIRT
DO_FEN: CALL    GBMVEND
        JMP     MLDIRT
DO_DLF: CALL    GBDLFT
        ORA     A
        JZ      DODLF1          ; A=0: deleted ok
        CPI     0FEH
        JZ      DOJNLG          ; A=FEH: line too long
        JMP     MAINLP          ; A=FFH: at BOF
DODLF1: LDA     GBTMP
        CPI     LF
        JZ      MLDIRT          ; LF deleted: full redraw
        JMP     MLDRTL          ; same line: redraw current only
DO_DRT: CALL    GBDELRT
        ORA     A
        JZ      DODRT1          ; A=0: deleted ok
        CPI     0FEH
        JZ      DOJNLG          ; A=FEH: line too long
        JMP     MAINLP          ; A=FFH: at EOF
DODRT1: LDA     GBTMP
        CPI     LF
        JZ      MLDIRT          ; LF deleted: full redraw
        JMP     MLDRTL          ; same line: redraw current only
DOJNLG: LXI     D,JNLMSG        ; "Line too long"
        CALL    STATMSG
        JMP     MAINLP
DO_DWD: CALL    GBWRDNX         ; move to next word
        CALL    GBDLFT         ; then delete back
        JMP     MLDIRT
DO_DLN: CALL    GBDLLN
        JMP     MLDIRT
DO_TAB: MVI     A,TAB
        CALL    GBINSRT
        JMP     MLDRTL          ; redraw current line only
DO_NLN:
        ; Auto-indent: capture leading whitespace before newline
        CALL    GBCURLN         ; HL = GGLBUF, A = length
        MVI     B,0             ; B = indent char count
        ORA     A
        JZ      DONLCR          ; empty line, skip scan
        MOV     C,A             ; C = line length
        LXI     D,NLIBUF        ; DE = indent buffer
DONLSC: MOV     A,M
        CPI     ' '
        JZ      DONLWS
        CPI     TAB
        JZ      DONLWS
        JMP     DONLCR          ; non-whitespace, done scanning
DONLWS: STAX    D               ; save whitespace byte
        INX     H
        INX     D
        INR     B
        DCR     C
        JZ      DONLCR          ; end of line
        MOV     A,B
        CPI     64              ; cap at 64 chars
        JC      DONLSC
DONLCR: MOV     A,B
        STA     NLICNT          ; save indent count
        ; Insert CR+LF
        MVI     A,CR
        CALL    GBINSRT
        MVI     A,LF
        CALL    GBINSRT
        ; Insert saved indent
        LDA     NLICNT
        ORA     A
        JZ      DONLDN          ; no indent to insert
        MOV     B,A
        LXI     H,NLIBUF
DONLIL: MOV     A,M
        PUSH    H
        PUSH    B
        CALL    GBINSRT
        POP     B
        POP     H
        INX     H
        DCR     B
        JNZ     DONLIL
DONLDN: JMP     MLDIRT
DO_TIN: LDA     INSMODE         ; toggle insert mode
        XRI     1
        STA     INSMODE
        CALL    INFOBAR         ; update mode display
        JMP     MAINLP
DO_LIT: JMP     MAINLP          ; literal next - unused
DO_FNX: CALL    SRFNDNX
        JMP     MLDIRT
DO_FND: CALL    SRFIND
        JMP     MLDIRT
DO_RPL: CALL    SRREPL
        JMP     MLDIRT
DO_JMP: CALL    SRJMPM
        JMP     MAINLP          ; SRJMPM sets DIRTY if needed
DO_SAV:
        ; Check if filename exists (BD_FNAME[1] != space)
        MVI     A,BD_FNAME+1
        CALL    BDFLD
        MOV     A,M
        ANI     7FH
        CPI     ' '
        JNZ     DSAVGO          ; has name, save directly
        ; No name - prompt for one
        LXI     D,EXTASPMT      ; "Save as: "
        CALL    FIPROMPT
        JZ      DSAVDN          ; user cancelled
        CALL    FISAVFN         ; copy WRKFCB name to BD_FNAME
        CALL    SYNINIT         ; update syntax mode for new ext
DSAVGO: LXI     D,SAVWMSG
        CALL    STATMSG
        CALL    FISAVE
DSAVDN: CALL    INFOBAR
        JMP     MAINLP
        ; DO_OPN removed: identical to DO_MNU, merged via ACTTBL
DO_EXT: CALL    DOEXIT          ; save & exit
        JMP     MAINLP          ; returns if cancelled
DO_BMK: CALL    BLMARK
        JMP     MLDIRT
DO_BCP: CALL    BLCOPY
        JMP     MLDIRT
DO_BDL: CALL    BLDEL
        JMP     MLDIRT
DO_BPS: CALL    BLPASTE
        JMP     MLDIRT
DO_MNU: CALL    MNUSHOW
        ; fall through to MLDIRT

;------------------------------------------------------------
; Shared exit points for action handlers
;------------------------------------------------------------
MLDIRT: MVI     A,1
        STA     DIRTY
        CALL    CHKLOW
        JMP     MAINLP
MLDRTL: MVI     A,1
        STA     DRTLINE
        CALL    CHKLOW
        JMP     MAINLP

;------------------------------------------------------------
; CHKLOW - Warn if free buffer space < 256 bytes.
; Only warns in non-virtual mode (virtual mode has disk).
; Entry:  (none)
; Exit:   Warning displayed if low; all regs clobbered
;------------------------------------------------------------
CHKLOW:
        ; Gap size = GAPEN - GAPBG
        CALL    GBGAPEN         ; HL = GAPEN
        XCHG                    ; DE = GAPEN
        CALL    GBGAPBG         ; HL = GAPBG
        MOV     A,E
        SUB     L
        MOV     L,A
        MOV     A,D
        SBB     H
        MOV     H,A             ; HL = gap size
        ; Check if gap < 256: H must be 0
        MOV     A,H
        ORA     A
        JNZ     CHKOK           ; H >= 1, gap >= 256, OK
        LXI     D,LOWMSG
        JMP     STATMSG

CHKOK:  RET

LOWMSG: DB      'Low memory! Save file and restart.$'

;------------------------------------------------------------
; DOEXIT - Prompt to save, handle unnamed files, exit.
; If buffer is unmodified: exits immediately.
; If modified: asks "Save? (Y/N/Esc)".
;   Y = save (prompts for name if unnamed), then exit.
;   N = discard changes, exit.
;   Esc = cancel, returns to editor.
; Exit: Warm boots CP/M (does not return) unless cancelled.
;------------------------------------------------------------
DOEXIT:
        ; Check if buffer modified
        CALL    FISMOD
        ORA     A
        JZ      DXEXIT          ; not modified, just exit

        ; Buffer is modified - ask user
        LXI     D,EXTSAVQ       ; "Save changes? (Y/N/Esc) "
        CALL    STATMSG
        MVI     C,BF_CONIN
        CALL    BDOS

        ; Check response
        CPI     'Y'
        JZ      DXYES
        CPI     'y'
        JZ      DXYES
        CPI     'N'
        JZ      DXEXIT          ; discard changes, exit
        CPI     'n'
        JZ      DXEXIT
        ; Any other key = cancel (return to editor)
        JMP     DXRET

DXYES:
        ; Check if filename exists (BD_FNAME[1] != space)
        MVI     A,BD_FNAME+1
        CALL    BDFLD
        MOV     A,M
        ANI     7FH
        CPI     ' '
        JNZ     DXSAVE          ; has name, save directly

        ; No name - clear status bar and prompt for filename
        LXI     D,CLRMSG
        CALL    STATMSG         ; clear status bar
        LDA     RSTAT
        MOV     B,A
        MVI     C,1
        CALL    CURGOTO
        LXI     D,EXTASPMT      ; "Save as: "
        CALL    FIPROMPT
        JZ      DXRET           ; user cancelled filename entry
        CALL    FISAVFN         ; copy WRKFCB name to BD_FNAME

DXSAVE:
        LXI     D,SAVWMSG
        CALL    STATMSG
        CALL    FISAVE

DXEXIT:
        CALL    VICLEAN
        ; Restore original user area
        CALL    FIRSTUSR
        ; Restore terminal to initial column mode
        LDA     INITCOL
        ORA     A
        JZ      DXRS80
        ; Restore to 132-col
        LXI     H,DXWIDE
        CALL    DSOUT
        JMP     DXRSD
DXRS80: ; Restore to 80-col
        LXI     H,DXNORM
        CALL    DSOUT
DXRSD:  LXI     D,CLRMSG
        CALL    STATMSG
        JMP     WBOOT           ; return to CP/M

DXRET:  LXI     D,CLRMSG
        JMP     STATMSG         ; clear leftover prompt

;------------------------------------------------------------
; FILFAIL - File too large or too wide to load.
; STATMSG already shown by FIOPEN; wait for keypress, exit.
;------------------------------------------------------------
FILFAIL:
        CALL    GETKEY          ; wait for any key
        JMP     WBOOT

;------------------------------------------------------------
; MEMFAIL - Not enough memory to run.
;------------------------------------------------------------
MEMFAIL:
        LXI     D,NOMEMSG
        MVI     C,BF_PRTSTR
        CALL    BDOS
        JMP     WBOOT

;------------------------------------------------------------
; SVTOPLN - Save current TOPLN for scroll detection.
; Called before a cursor movement that may scroll.
; Exit:   OLDTPLN filled; AF HL clobbered
;------------------------------------------------------------
SVTOPLN:
        MVI     A,BD_TOPLN
        CALL    BDFLD           ; HL -> BD_TOPLN
        MOV     A,M
        STA     OLDTPLN
        INX     H
        MOV     A,M
        STA     OLDTPLN+1
        RET

;------------------------------------------------------------
; CHKSCRL - Compare TOPLN with saved value.
; If changed, set DIRTY=1 for full redraw.
; If unchanged, leave flags alone (cursor-only update).
; Exit:   AF HL clobbered
;------------------------------------------------------------
CHKSCRL:
        MVI     A,BD_TOPLN
        CALL    BDFLD           ; HL -> BD_TOPLN
        LDA     OLDTPLN
        CMP     M
        JNZ     CHKYES          ; low byte differs - scrolled
        INX     H
        LDA     OLDTPLN+1
        CMP     M
        RZ                      ; both match - no scroll
CHKYES: MVI     A,1
        STA     DIRTY           ; viewport scrolled, full redraw
        RET

;------------------------------------------------------------
; VRTCAP - Capture goal column for vertical cursor move.
; If PVGOAL != FFH (consecutive vertical), reuse it.
; Otherwise, read current BD_CSCOL as the new goal.
; Exit:   GOALCOL set; AF HL clobbered
;------------------------------------------------------------
VRTCAP:
        LDA     PVGOAL
        CPI     0FFH
        JNZ     VRTCPS          ; consecutive vertical: reuse
        ; First vertical move: capture current column
        MVI     A,BD_CSCOL
        CALL    BDFLD
        MOV     A,M
VRTCPS: STA     GOALCOL
        RET

;------------------------------------------------------------
; VRTADV - Advance cursor from line start to goal column.
; After GBMVUP/DN the cursor is at col 0. Advance right
; to min(GOALCOL, line_length).
; Exit:   All regs clobbered
;------------------------------------------------------------
VRTADV:
        ; Get current line length
        CALL    GBCURLN         ; A = line length, HL = buffer
        MOV     B,A             ; B = line length
        LDA     GOALCOL         ; A = target column
        CMP     B
        JC      VRTAD1          ; GOALCOL < length: use GOALCOL
        MOV     A,B             ; clamp to line length
VRTAD1: ORA     A
        RZ                      ; target = 0, already there
        MOV     B,A             ; B = columns to advance
VRTADL: CALL    GBMVRT
        DCR     B
        JNZ     VRTADL
        RET

;------------------------------------------------------------
; DETSIZ is now provided by the terminal driver module.
; (See SESCREEN.MAC for VT100 DSR, or SEVT52/SEADM31/SEC3102
;  for fixed 80x24 stubs.)
;------------------------------------------------------------

;------------------------------------------------------------
; DSOUT - Output NUL-terminated string at HL via BDOS RAWIO.
; Entry:  HL = NUL-terminated string
; Exit:   HL past NUL; AF DE clobbered
;------------------------------------------------------------
DSOUT:
        MOV     A,M
        ORA     A
        RZ                      ; NUL = done
        MOV     E,A
        PUSH    H
        MVI     C,BF_RAWIO
        CALL    BDOS
        POP     H
        INX     H
        JMP     DSOUT

;--- Exit column restore strings (NUL-terminated) ---
DXWIDE: DB      ESC,'[','?','3','h',0           ; DECCOLM 132
DXNORM: DB      ESC,'[','?','3','l',0           ; DECCOLM 80

;------------------------------------------------------------
; AUTOSCR - Auto-adjust HSCROL so cursor stays visible.
; Uses tab-aligned (multiple of 4) scroll offsets.
; Snap-to-zero: if CSCOL < TXTCOLS-TABWID, HSCROL=0.
; Entry:  (none)
; Exit:   AF HL clobbered; DIRTY set if HSCROL changed
;------------------------------------------------------------
AUTOSCR:
        ; Compute visual column (expand tabs in current line)
        ; Read BD_CSCOL (byte offset)
        MVI     A,BD_CSCOL
        CALL    BDFLD           ; HL -> BD_CSCOL
        MOV     C,M             ; C = byte col (0-based)
        ; Scan current line for tabs
        PUSH    B
        CALL    GBCURLN         ; HL = GGLBUF, A = len
        POP     B               ; C = byte col
        MVI     D,0             ; D = visual column
        MOV     A,C
        ORA     A
        JZ      ASVDN           ; byte col = 0
        MOV     E,C             ; E = bytes to walk
ASVLP:  MOV     A,M
        CPI     TAB
        JZ      ASVTAB
        INR     D               ; normal char: visual++
        JMP     ASVNXT
ASVTAB: MOV     A,D
        ANI     TABWID-1
        MOV     B,A
        MVI     A,TABWID
        SUB     B
        ADD     D
        MOV     D,A             ; D = next tab stop
ASVNXT: INX     H
        DCR     E
        JNZ     ASVLP
ASVDN:  MOV     A,D             ; A = visual column

        ; Snap-to-zero: if visual_col < RTXTTB, HSCROL = 0
        MOV     B,A             ; B = CSCOL
        LDA     RTXTTB          ; A = runtime threshold
        CMP     B               ; RTXTTB - CSCOL: carry if CSCOL > RTXTTB
        MOV     A,B             ; A = CSCOL (restore)
        JC      ASNOCHK         ; CSCOL > threshold
        JZ      ASNOCHK         ; CSCOL == threshold
        ; Cursor in safe zone: snap HSCROL to 0
        LDA     HSCROL
        ORA     A
        RZ                      ; already 0, no change
        XRA     A
        STA     HSCROL
        MVI     A,1
        STA     DIRTY
        RET

ASNOCHK:
        ; CSCOL >= 69. Check if cursor past right edge of viewport.
        ; Right edge = HSCROL + RTXTCL
        MOV     L,A             ; L = CSCOL (save)
        LDA     HSCROL
        MOV     H,A             ; H = old HSCROL
        MOV     B,A             ; B = HSCROL
        LDA     RTXTCL
        ADD     B               ; A = HSCROL + RTXTCL
        JC      ASCHKLF         ; overflow means cursor can't be past it
        CMP     L               ; right_edge - CSCOL
        JC      ASRGHT          ; right_edge < CSCOL, need scroll right
        JZ      ASRGHT          ; right_edge == CSCOL, need scroll right
        JMP     ASCHKLF         ; right_edge > CSCOL, cursor visible

ASRGHT: ; Cursor at or past right edge: scroll right
        ; HSCROL = round_up(CSCOL - RTXTCL + 1, 4)
        LDA     RTXTCL
        DCR     A               ; A = RTXTCL - 1
        MOV     B,A             ; B = RTXTCL - 1
        MOV     A,L             ; A = CSCOL
        SUB     B               ; A = CSCOL - (RTXTCL - 1)
        ADI     TABWID-1        ; round up: add 3
        ANI     0FCH            ; align to multiple of 4
        JMP     ASUPDAT         ; store new HSCROL

ASCHKLF:
        ; Check if cursor left of viewport (CSCOL < HSCROL)
        MOV     A,L             ; A = CSCOL
        CMP     H               ; compare CSCOL vs HSCROL
        RNC                     ; CSCOL >= HSCROL, no change needed

        ; Cursor left of viewport: scroll left
        ; HSCROL = round_down(CSCOL, 4)
        MOV     A,L             ; A = CSCOL
        ANI     0FCH            ; align to multiple of 4

ASUPDAT:
        ; A = new HSCROL value. Only update if changed.
        MOV     L,A             ; L = new HSCROL
        LDA     HSCROL
        CMP     L
        RZ                      ; no change
        MOV     A,L
        STA     HSCROL
        MVI     A,1
        STA     DIRTY
        RET

;------------------------------------------------------------
; BDFLD - Compute pointer to buffer descriptor field.
; Entry:  A = field offset (BD_xxx constant)
; Exit:   HL -> field in current descriptor; A clobbered
;------------------------------------------------------------
BDFLD:
        LHLD    CURBDP
        ADD     L
        MOV     L,A
        MVI     A,0
        ADC     H
        MOV     H,A
        RET

;------------------------------------------------------------
; Action dispatch table - word (address) per action code.
; Index 0 = ACT_NONE (unused), 1..ACT_MAX = handlers.
;------------------------------------------------------------
ACTTBL:
        DW      MAINLP          ;  0 ACT_NONE
        DW      DO_CUU          ;  1 ACT_CURUP
        DW      DO_CUD          ;  2 ACT_CURDN
        DW      DO_CUL          ;  3 ACT_CURLT
        DW      DO_CUR          ;  4 ACT_CURRT
        DW      DO_WPV          ;  5 ACT_WRDPV
        DW      DO_WNX          ;  6 ACT_WRDNX
        DW      DO_PGU          ;  7 ACT_PGUP
        DW      DO_PGD          ;  8 ACT_PGDN
        DW      DO_CUU          ;  9 ACT_SCRUP (=cursor up)
        DW      DO_CUD          ; 10 ACT_SCRDN (=cursor down)
        DW      DO_LST          ; 11 ACT_LINST
        DW      DO_LEN          ; 12 ACT_LINEN
        DW      DO_FTP          ; 13 ACT_FTOP
        DW      DO_FEN          ; 14 ACT_FEND
        DW      DO_DLF          ; 15 ACT_DELLF
        DW      DO_DRT          ; 16 ACT_DELRT
        DW      DO_DWD          ; 17 ACT_DELWD
        DW      DO_DLN          ; 18 ACT_DELLN
        DW      DO_TAB          ; 19 ACT_INSTB
        DW      DO_NLN          ; 20 ACT_INSNL
        DW      DO_TIN          ; 21 ACT_TOGIN
        DW      DO_LIT          ; 22 ACT_LITNX
        DW      DO_FNX          ; 23 ACT_FNDNX
        DW      DO_SAV          ; 24 ACT_FSAVE
        DW      DO_MNU          ; 25 ACT_FOPEN (=menu)
        DW      DO_EXT          ; 26 ACT_FEXIT
        DW      DO_BMK          ; 27 ACT_BLKMK
        DW      DO_BCP          ; 28 ACT_BLKCP
        DW      DO_BDL          ; 29 ACT_BLKDL
        DW      DO_BPS          ; 30 ACT_BLKPS
        DW      DO_MNU          ; 31 ACT_MENU
        DW      DO_FND          ; 32 ACT_FIND
        DW      DO_RPL          ; 33 ACT_REPL
        DW      DO_JMP          ; 34 ACT_JMPM

;--- String constants ---------------------------------
NOMEMSG: DB    'Insufficient memory',CR,LF,'$'
CLRMSG:  DB    ' $'
SAVWMSG: DB    'Saving file, please wait...$'
EXTSAVQ: DB    'Save changes? (Y/N/Esc) $'
EXTASPMT: DB   'Save as: $'
JNLMSG:  DB    'Line too long to join.$'
CLUERR:  DB    'Error: cannot specify user# for temp drive.',CR,LF,'$'

;------------------------------------------------------------
; CLPARSE - Parse raw command tail into filename + temp drive.
; Reads 0080H/0081H. Copies first arg to FILNBUF and calls
; FIPARSN (which handles d[u]: prefix). Parses second arg
; for virtual temp drive (drive only, no user#).
; Exit:   CLHASF = 1 if filename found, 0 if not
;         WRKFCB populated via FIPARSN
;         FILUSR set if user# in first arg
;         VTMPDRV set if second arg present
;------------------------------------------------------------
CLPARSE:
        XRA     A
        STA     CLHASF          ; no filename yet
        STA     VTMPDRV         ; no temp drive yet

        LDA     CMDTAIL         ; command tail length
        ORA     A
        RZ                      ; empty tail, nothing to do
        MOV     B,A             ; B = remaining chars
        LXI     H,CMDTAIL+1     ; HL = start of tail

        ; Skip leading spaces
CLSKP1: MOV     A,M
        CPI     ' '
        JNZ     CLARG1
        INX     H
        DCR     B
        JNZ     CLSKP1
        RET                     ; all spaces

        ; --- First arg: filename ---
CLARG1: MOV     A,B
        ORA     A
        RZ                      ; no more chars
        ; Copy first arg to FILNBUF (up to 15 chars, stop at space/NUL)
        LXI     D,FILNBUF
        MVI     C,0             ; char count
CLA1LP: MOV     A,B
        ORA     A
        JZ      CLA1DN          ; end of tail
        MOV     A,M
        CPI     ' '
        JZ      CLA1DN          ; end of first arg
        MOV     A,C
        CPI     17              ; max FILNBUF chars (leave room for NUL)
        JNC     CLA1SK          ; overflow, skip rest
        MOV     A,M
        STAX    D
        INX     D
        INR     C
CLA1SK: INX     H
        DCR     B
        JMP     CLA1LP
CLA1DN: XRA     A
        STAX    D               ; NUL-terminate FILNBUF

        ; Parse filename (sets WRKFCB, FILUSR)
        CALL    FIPARSN
        CALL    FISAVFN         ; copy WRKFCB to BD_FNAME

        MVI     A,1
        STA     CLHASF          ; we have a filename

        ; --- Second arg: temp drive ---
        ; Skip spaces between args
CLSKP2: MOV     A,B
        ORA     A
        RZ                      ; no second arg
        MOV     A,M
        CPI     ' '
        JNZ     CLARG2
        INX     H
        DCR     B
        JMP     CLSKP2

CLARG2: ; Second arg present - must be d: (drive only)
        ; Check for letter followed by ':'
        MOV     A,M             ; first char of second arg
        ANI     5FH             ; upper case
        CPI     'A'
        JC      CLRET           ; not a letter, ignore
        CPI     'P'+1
        JNC     CLRET           ; past P, ignore
        SUI     'A'-1           ; A=1, B=2, ...
        STA     CLTDRV          ; save drive temporarily
        INX     H
        DCR     B
        JZ      CLRET           ; only one char, ignore
        MOV     A,M             ; second char
        CPI     ':'
        JNZ     CLUSRE          ; digit before colon = user# = error
        ; Valid "X:" temp drive
        LDA     CLTDRV
        STA     VTMPDRV
CLRET:  RET

CLUSRE: ; Check if it's a digit (user# on temp drive = error)
        CPI     '0'
        JC      CLRET           ; not digit, just ignore
        CPI     '9'+1
        JNC     CLRET           ; not digit, just ignore
        ; User# specified on temp drive - error
        LXI     D,CLUERR
        MVI     C,BF_PRTSTR
        CALL    BDOS
        JMP     WBOOT

;=============================================================
; DATA SEGMENT
;=============================================================
        DSEG

OLDSP:  DW      0               ; saved entry SP
TPATOP: DW      0               ; BDOS address / TPA top
INSMODE: DB     MODE_INS        ; insert/overwrite mode
DIRTY:  DB      1               ; 1 = full screen redraw needed
DRTLINE: DB     0               ; 1 = redraw current line only
HSCROL: DB      0               ; horizontal scroll offset (tab-aligned)
COLMOD: DB      0               ; column mode: 0=80, 1=132
INITCOL: DB     0               ; initial column mode at startup
DSROWS: DW      0               ; detected terminal rows
DSCOLS: DW      0               ; detected terminal columns
DSCPWR: DB      0               ; collect buffer write index
DSCPTM: DB      0               ; temp byte for collect
DSDCNT: DB      0               ; debug: saved byte count
DSCPBUF: DS     16              ; collect buffer (DSR response max ~12 bytes)
REROWS: DB      EDITROW         ; runtime edit rows (default 20)
RSEPR:  DB      SEPRROW         ; runtime separator row (default 23)
RSTAT:  DB      STATROW         ; runtime status row (default 24)
RTXTCL: DB      TXTCOLS         ; runtime text columns (73 or 125)
RSCRCL: DB      SCRCOLS         ; runtime screen columns (80 or 132)
RTXTTB: DB      TXTCOLS-TABWID  ; runtime TXTCOLS-TABWID (69 or 121)
VTMPDRV: DB     0               ; virtual temp file drive (0=default)
CLHASF: DB      0               ; command line: has filename flag
CLTDRV: DB      0               ; command line: temp drive scratch
MLSROW: DB      0               ; saved CSROW for marking mode
OLDTPLN: DW     0               ; saved TOPLN for scroll detect
GOALCOL: DB     0FFH            ; target col for vertical moves (FF=unset)
PVGOAL: DB      0FFH            ; previous GOALCOL (for sticky detection)
NLICNT: DB      0               ; auto-indent char count
NLIBUF: DS      64              ; auto-indent whitespace buffer
CURBDP: DW      0               ; ptr to active buf desc
BDESC0: DS      BD_SIZE         ; single buffer descriptor (34 bytes)

;--- Stack (64 words) ---------------------------------
        DS      128
STKTOP  EQU     $               ; SP points here

        END     START

;============================================================
; FILE:    SEGAPBUF.MAC
; PROJECT: SEDIT - Screen Editor for CP/M 2.2
; VERSION: 1.0
; DATE:    1984-01-01
; AUTHOR: Claude Code and RetroTechReboot
;------------------------------------------------------------
; DESCRIPTION:
;   Gap buffer text engine. All routines operate on the
;   buffer identified by CURBDP (current buffer descriptor
;   pointer).  Text is stored as flat bytes with CR+LF
;   (0DH 0AH) line separators. The gap sits at the cursor
;   insertion point, allowing O(1) insert/delete there.
;
;   Descriptor layout (offsets from BD_xxx in SEDIT.INC):
;     BD_BSTAR: base address of RAM buffer
;     BD_BSIZE: total capacity in bytes
;     BD_GAPBG: offset of first gap byte
;     BD_GAPEN: offset of first text byte after gap
;     BD_TXEND: number of text bytes in buffer
;     BD_TOPLN: line number at top of screen (0-based)
;     BD_CSROW: cursor screen row (0-based)
;     BD_CSCOL: cursor text column (0-based)
;     BD_CSOFF: cursor logical text offset
;     BD_MRKBG: block mark start offset (NO_MARK=none)
;     BD_MRKEN: block mark end offset
;     BD_MODIF: non-zero if buffer is modified
;------------------------------------------------------------
; REVISION HISTORY:
;   1.0  1984-01-01  Initial release
;============================================================
        INCLUDE SEDIT.INC


        EXTRN   CURBDP          ; ptr to active descriptor
        EXTRN   VIMODE          ; virtual mode flag (SEVIRTIO)
        EXTRN   VBFLN           ; lines in BEFORE temp
        EXTRN   VAFLN           ; lines in AFTER temp
        EXTRN   VIGOTO          ; merge-split at target line
        EXTRN   REROWS          ; runtime edit rows

        PUBLIC  GBINIT          ; init an empty buffer
        PUBLIC  GBINSRT         ; insert char at cursor
        PUBLIC  GBDLFT         ; delete char left (BS)
        PUBLIC  GBDELRT         ; delete char right
        PUBLIC  GBTMP           ; last deleted/inserted char
        PUBLIC  GBMVUP          ; cursor up one line
        PUBLIC  GBMVDN          ; cursor down one line
        PUBLIC  GBMVLT          ; cursor left one char
        PUBLIC  GBMVRT          ; cursor right one char
        PUBLIC  GBMLNS         ; cursor to line start
        PUBLIC  GBMLNE         ; cursor to line end
        PUBLIC  GBMVTOP         ; cursor to file top
        PUBLIC  GBMVEND         ; cursor to file end
        PUBLIC  GBPGUP          ; page up (REROWS lines)
        PUBLIC  GBPGDN          ; page down
        PUBLIC  GBDLLN         ; delete current line
        PUBLIC  GBWRDPV         ; move to previous word
        PUBLIC  GBWRDNX         ; move to next word
        PUBLIC  GBGETLN         ; get ptr to line N text
        PUBLIC  GBCURLN         ; get current cursor line (fast)
        PUBLIC  GBCNTLN         ; count lines in buffer
        PUBLIC  GBFNDLN         ; find logical offset of line N (fast)
        PUBLIC  GBFNDCS         ; find TOPLN offset via backward scan
        PUBLIC  GBRDLNO         ; read line at given logical offset
        PUBLIC  GBGOTOL         ; go to line N (fast bulk move)
        PUBLIC  GBBASE          ; DE = buffer base address
        PUBLIC  GBBSIZ          ; DE = buffer size
        PUBLIC  GBGAPBG         ; HL = gap start offset
        PUBLIC  GBGAPEN         ; HL = gap end offset
        PUBLIC  GBLOGRD         ; read byte at logical offset

;=============================================================
; Internal helper: load descriptor fields into registers.
; After LDDESC:
;   BBASE = buffer base address (in DSEG)
;   BGAPBG, BGAPEN, BTXEND = gap/text state
;   BC = GAPBEG (gap start offset)
;   DE = GAPEN  (gap end offset)
;   HL = TXEND  (text end offset) -- logical text length
; All from current descriptor at CURBDP.
;=============================================================
        CSEG

; Macro-like helper: load HL = address of field in desc
; Uses A as scratch.  Entry: A = field offset constant.
; Result: HL = &desc[offset]
; (Implemented inline where needed for clarity)

;=============================================================
; GBINIT - Initialise a buffer descriptor for empty file.
; Entry:  HL = buffer descriptor address
;         DE = RAM buffer base address
;         BC = RAM buffer size in bytes
; Exit:   Descriptor zeroed and gap set to full capacity
;         All regs clobbered
;=============================================================
GBINIT:
        ; Invalidate line count cache
        XRA     A
        STA     GLNVAL
        PUSH    H               ; save descriptor address
        ; Store base address
        MOV     M,E             ; BD_BSTAR low
        INX     H
        MOV     M,D             ; BD_BSTAR high
        INX     H
        ; Store size
        MOV     M,C             ; BD_BSIZE low
        INX     H
        MOV     M,B             ; BD_BSIZE high
        INX     H
        ; GAPBG = 0 (gap at start)
        MVI     M,0
        INX     H
        MVI     M,0
        INX     H
        ; GAPEN = BC (gap end = full buffer)
        POP     H
        PUSH    H
        MVI     A,BD_GAPEN
        ADD     L
        MOV     L,A
        MVI     A,0
        ADC     H
        MOV     H,A
        MOV     M,C
        INX     H
        MOV     M,B
        ; TXEND = 0 (no text)
        POP     H
        PUSH    H
        MVI     A,BD_TXEND
        ADD     L
        MOV     L,A
        MVI     A,0
        ADC     H
        MOV     H,A
        MVI     M,0
        INX     H
        MVI     M,0
        ; TOPLN=0, CSROW=0, CSCOL=0, CSOFF=0,
        ; MRKBG=FFFF, MRKEN=FFFF, MODIF=0, SYNMD=0
        POP     H
        PUSH    H
        MVI     A,BD_TOPLN
        ADD     L
        MOV     L,A
        MVI     A,0
        ADC     H
        MOV     H,A
        MVI     M,0             ; TOPLN low
        INX     H
        MVI     M,0             ; TOPLN high
        INX     H
        MVI     M,0             ; CSROW
        INX     H
        MVI     M,0             ; CSCOL
        INX     H
        MVI     M,0             ; CSOFF low
        INX     H
        MVI     M,0             ; CSOFF high
        INX     H
        MVI     M,0FFH          ; MRKBG low = NO_MARK
        INX     H
        MVI     M,0FFH          ; MRKBG high
        INX     H
        MVI     M,0FFH          ; MRKEN low
        INX     H
        MVI     M,0FFH          ; MRKEN high
        INX     H
        MVI     M,0             ; MODIF = clean
        INX     H
        MVI     M,SYN_NONE      ; SYNMD = plain text
        POP     H
        RET

;=============================================================
; GBINSRT - Insert byte A at current cursor position.
; Entry:  A = byte to insert
; Exit:   A=0 ok; A=0FFH buffer full; all regs clobbered
;=============================================================
GBINSRT:
        STA     GBTMP           ; save char to insert
        ; Check gap is non-empty
        CALL    GBGAPLN         ; HL = gap size
        MOV     A,H
        ORA     L
        JZ      GBIFULL         ; gap=0 means full

        ; Get descriptor fields
        CALL    GBBASE          ; DE = buffer base
        CALL    GBGAPBG         ; HL = GAPBG offset
        ; Compute absolute address: DE+HL
        DAD     D               ; HL = base + GAPBG
        ; Write character
        LDA     GBTMP
        MOV     M,A

        ; Advance GAPBG by 1
        CALL    GBGAPBG         ; HL = GAPBG offset
        INX     H               ; +1
        CALL    GBSETGAPBG      ; store new GAPBG

        ; Advance TXEND by 1
        CALL    GBTXEND         ; HL = TXEND
        INX     H
        CALL    GBSETTXEND

        ; Update cursor column and offset
        LDA     GBTMP
        CPI     CR
        JZ      GBISKPC         ; CR is invisible, skip col increment
        CALL    GBCSCOL         ; HL = cursor col
        INX     H
        CALL    GBSETCSCOL
GBISKPC:
        CALL    GBCSOFF         ; HL = cursor offset
        INX     H
        CALL    GBSETCSOFF

        ; Mark buffer modified
        CALL    GBSETMOD

        ; Handle newline: reset column, advance row
        LDA     GBTMP
        CPI     LF
        JNZ     GBIDONE
        ; LF inserted: update line count cache
        LDA     GLNVAL
        ORA     A
        JZ      GBILCS          ; cache not valid, skip
        LHLD    GLNCNT
        INX     H
        SHLD    GLNCNT
GBILCS: ; After LF: col=0, row++
        LXI     H,0
        CALL    GBSETCSCOL
        CALL    GBCSROW         ; HL = screen row
        INX     H
        MOV     A,L
        PUSH    B
        PUSH    H
        LDA     REROWS
        MOV     B,A
        MOV     A,L
        CMP     B               ; compare row vs REROWS
        POP     H
        POP     B
        JNC     GBISCRL
        CALL    GBSETCSROW
        JMP     GBIDONE
GBISCRL:
        ; Scroll: increment TOPLN, keep row at REROWS-1
        CALL    GBTOPLN         ; HL = TOPLN
        INX     H
        CALL    GBSETTOPLN
        LDA     REROWS
        DCR     A
        MOV     L,A
        MVI     H,0
        CALL    GBSETCSROW

GBIDONE:
        XRA     A               ; A=0 = ok
        RET

GBIFULL:
        MVI     A,0FFH          ; A=FFH = error
        RET

;=============================================================
; GBDLFT - Delete char to the left of cursor (backspace).
; Entry:  (none)
; Exit:   A=0 ok (deleted); A=FFH at beginning of buffer
;=============================================================
GBDLFT:
        CALL    GBGAPBG         ; HL = GAPBG
        MOV     A,H
        ORA     L
        JZ      GBDLBER         ; at BOF, nothing to del

        ; Check if char before gap is LF
        CALL    GBBASE          ; DE = buffer base
        CALL    GBGAPBG         ; HL = GAPBG
        DCX     H               ; HL = GAPBG - 1
        DAD     D               ; abs address
        MOV     A,M             ; byte before cursor
        STA     GBTMP           ; save it

        ; If deleting LF, check combined line length
        CPI     LF
        JNZ     GBDLGO          ; not LF, safe to delete
        ; Set up GBJLCHK params:
        ;   HL = base+GAPBG-2 (left side, byte before LF)
        ;   DE = base+GAPEN   (right side, current line)
        CALL    GBBASE          ; DE = base
        PUSH    D               ; save base
        CALL    GBGAPBG         ; HL = GAPBG (DE=base ok)
        DCX     H
        DCX     H               ; HL = GAPBG-2
        DAD     D               ; HL = base+GAPBG-2 (left)
        POP     D               ; DE = base
        PUSH    H               ; save left start
        CALL    GBGAPEN         ; HL = GAPEN (DE=base ok)
        DAD     D               ; HL = base+GAPEN (right)
        XCHG                    ; DE = base+GAPEN
        POP     H               ; HL = base+GAPBG-2
        CALL    GBJLCHK         ; A=0 ok, A=FFH too long
        ORA     A
        JNZ     GBDLONG         ; line too long, refuse
GBDLGO:
        ; Shrink gap leftward: GAPBG -= 1
        CALL    GBGAPBG
        DCX     H
        CALL    GBSETGAPBG

        ; Shrink TXEND by 1
        CALL    GBTXEND
        DCX     H
        CALL    GBSETTXEND

        ; Update cursor: offset -= 1
        CALL    GBCSOFF
        DCX     H
        CALL    GBSETCSOFF

        ; Update column
        LDA     GBTMP
        CPI     LF
        JNZ     GBDLBCL         ; not a newline
        ; LF deleted: update line count cache
        LDA     GLNVAL
        ORA     A
        JZ      GBDLCS          ; cache not valid, skip
        LHLD    GLNCNT
        DCX     H
        SHLD    GLNCNT
GBDLCS: ; Deleted a newline: move up, recalc column
        CALL    GBCSROW
        MOV     A,L
        ORA     A
        JZ      GBDLBTL         ; was on row 0 of screen
        DCX     H
        CALL    GBSETCSROW
        JMP     GBDLBRC
GBDLBTL:
        ; Row was 0 - scroll back (TOPLN--)
        CALL    GBTOPLN
        MOV     A,H
        ORA     L
        JZ      GBDLBRC         ; already at top
        DCX     H
        CALL    GBSETTOPLN
GBDLBRC:
        ; Recalculate column as length of current line
        CALL    GBCURLNL        ; HL = current line length
        CALL    GBSETCSCOL
        ; Delete preceding CR if present (CR+LF inserted as pair)
        CALL    GBGAPBG         ; HL = GAPBG
        MOV     A,H
        ORA     L
        JZ      GBDLDONE        ; at buffer start, skip
        CALL    GBBASE          ; DE = base
        CALL    GBGAPBG         ; HL = GAPBG
        DCX     H               ; GAPBG - 1
        DAD     D               ; HL = abs address
        MOV     A,M             ; byte before cursor
        CPI     CR
        JNZ     GBDLDONE        ; not CR, done
        ; CR found: absorb it into the gap
        CALL    GBGAPBG
        DCX     H
        CALL    GBSETGAPBG      ; GAPBG--
        CALL    GBTXEND
        DCX     H
        CALL    GBSETTXEND      ; TXEND--
        CALL    GBCSOFF
        DCX     H
        CALL    GBSETCSOFF      ; CSOFF--
        JMP     GBDLDONE
GBDLBCL:
        ; Not a newline
        CPI     CR
        JZ      GBDLDONE        ; CR is invisible, no col change
        ; Visible char: decrement column
        CALL    GBCSCOL
        MOV     A,L
        ORA     A
        JZ      GBDLDONE        ; col already 0
        DCX     H
        CALL    GBSETCSCOL
GBDLDONE:
        CALL    GBSETMOD
        XRA     A
        RET
GBDLBER:
        MVI     A,0FFH
        RET
GBDLONG:
        MVI     A,0FEH          ; line too long to join
        RET

;=============================================================
; GBDELRT - Delete char at cursor (forward delete).
; Entry:  (none)
; Exit:   A=0 ok; A=FFH at end of buffer
;=============================================================
GBDELRT:
        ; Check if gap end is at text end (GAPEN >= BSIZE)
        CALL    GBGAPEN         ; HL = GAPEN
        PUSH    H               ; save GAPEN (GBBSIZ clobbers HL)
        CALL    GBBSIZ          ; DE = buffer size
        POP     H               ; HL = GAPEN restored
        MOV     A,L
        SUB     E
        MOV     A,H
        SBB     D
        JNC     GBDREOF         ; GAPEN >= BSIZE, at end

        ; Get char being deleted
        CALL    GBBASE          ; DE = base
        CALL    GBGAPEN         ; HL = GAPEN offset
        DAD     D               ; abs address
        MOV     A,M
        STA     GBTMP

        ; If deleting LF, check combined line length
        CPI     LF
        JNZ     GBDRGO          ; not LF, safe to delete
        ; Set up GBJLCHK params:
        ;   HL = base+GAPBG-1 (left side, end of current line)
        ;   DE = base+GAPEN+1 (right side, start of next line)
        CALL    GBBASE          ; DE = base
        PUSH    D               ; save base
        CALL    GBGAPBG         ; HL = GAPBG (DE=base ok)
        DCX     H               ; HL = GAPBG-1
        DAD     D               ; HL = base+GAPBG-1 (left)
        POP     D               ; DE = base
        PUSH    H               ; save left start
        CALL    GBGAPEN         ; HL = GAPEN (DE=base ok)
        INX     H               ; HL = GAPEN+1 (skip the LF)
        DAD     D               ; HL = base+GAPEN+1 (right)
        XCHG                    ; DE = base+GAPEN+1
        POP     H               ; HL = base+GAPBG-1
        CALL    GBJLCHK         ; A=0 ok, A=FFH too long
        ORA     A
        JNZ     GBDLONG         ; line too long, refuse
GBDRGO:
        ; Extend gap right: GAPEN += 1
        CALL    GBGAPEN
        INX     H
        CALL    GBSETGAPEN

        ; TXEND -= 1
        CALL    GBTXEND
        DCX     H
        CALL    GBSETTXEND

        ; If deleted char was LF, update line count cache
        LDA     GBTMP
        CPI     LF
        JNZ     GBDRDN
        LDA     GLNVAL
        ORA     A
        JZ      GBDRDN
        LHLD    GLNCNT
        DCX     H
        SHLD    GLNCNT
GBDRDN: CALL    GBSETMOD
        XRA     A
        RET
GBDREOF:
        MVI     A,0FFH
        RET

;=============================================================
; GBMVLT - Move cursor left one character.
; Entry:  (none)
; Exit:   Cursor moved; all regs clobbered
;=============================================================
GBMVLT:
        CALL    GBGAPBG         ; HL = GAPBG
        MOV     A,H
        ORA     L
        RZ                      ; at BOF

        ; Cache base address (GBBASE clobbers A,HL)
        CALL    GBBASE          ; DE = base
        XCHG
        SHLD    GLTBAS          ; save base
        XCHG                    ; DE = base again

        ; Get char to left of gap: base + GAPBG - 1
        CALL    GBGAPBG
        DCX     H
        DAD     D               ; abs address
        MOV     A,M             ; char being passed
        STA     GBTMP

        ; Write char at right end of gap: base + GAPEN - 1
        CALL    GBGAPEN
        DCX     H
        XCHG                    ; DE = GAPEN - 1
        LHLD    GLTBAS          ; HL = base
        DAD     D               ; HL = base + GAPEN - 1
        LDA     GBTMP
        MOV     M,A             ; write saved char

        ; Update GAPBG-=1, GAPEN-=1
        CALL    GBGAPBG
        DCX     H
        CALL    GBSETGAPBG
        CALL    GBGAPEN
        DCX     H
        CALL    GBSETGAPEN

        ; Update cursor offset -=1
        CALL    GBCSOFF
        DCX     H
        CALL    GBSETCSOFF

        ; Update cursor col / row
        LDA     GBTMP
        CPI     LF
        JZ      GBLTLF          ; LF: moved back over newline
        CPI     CR
        JZ      GBLTDN          ; CR: invisible, no col/row change
        ; Other chars: decrement column
GBLTCL:
        CALL    GBCSCOL
        MOV     A,L
        ORA     A
        JZ      GBLTDN
        DCX     H
        CALL    GBSETCSCOL
GBLTDN: RET
GBLTLF:
        ; Moved back over a newline (LF)
        CALL    GBCSROW
        MOV     A,L
        ORA     A
        JZ      GBLTSR
        DCX     H
        CALL    GBSETCSROW
        JMP     GBLTRC
GBLTSR:
        CALL    GBTOPLN
        MOV     A,H
        ORA     L
        JZ      GBLTRC
        DCX     H
        CALL    GBSETTOPLN
GBLTRC:
        CALL    GBCURLNL
        JMP     GBSETCSCOL

;=============================================================
; GBMVRT - Move cursor right one character.
; Entry:  (none)
; Exit:   Cursor moved; all regs clobbered
;=============================================================
GBMVRT:
        ; Check if at end of text (GAPEN >= BSIZE)
        CALL    GBGAPEN         ; HL = GAPEN
        PUSH    H               ; save GAPEN (GBBSIZ clobbers HL)
        CALL    GBBSIZ          ; DE = buffer size
        POP     H               ; HL = GAPEN restored
        MOV     A,L
        SUB     E
        MOV     A,H
        SBB     D
        JNC     GBRTAT          ; GAPEN >= BSIZE, at end

        ; Cache base address (GBBASE clobbers A,HL)
        CALL    GBBASE          ; DE = base
        XCHG
        SHLD    GRTBAS          ; save base
        XCHG                    ; DE = base again

        ; Get char at right side of gap: base + GAPEN
        CALL    GBGAPEN         ; HL = GAPEN
        DAD     D               ; HL = base + GAPEN
        MOV     A,M
        STA     GBTMP

        ; Write char at left of gap: base + GAPBG
        CALL    GBGAPBG         ; HL = GAPBG
        XCHG                    ; DE = GAPBG
        LHLD    GRTBAS          ; HL = base
        DAD     D               ; HL = base + GAPBG
        LDA     GBTMP
        MOV     M,A             ; write char

        ; Slide gap right: GAPBG+=1, GAPEN+=1
        CALL    GBGAPBG
        INX     H
        CALL    GBSETGAPBG
        CALL    GBGAPEN
        INX     H
        CALL    GBSETGAPEN

        ; Cursor offset += 1
        CALL    GBCSOFF
        INX     H
        CALL    GBSETCSOFF

        ; Update column / row
        LDA     GBTMP
        CPI     LF
        JZ      GBRTNL          ; LF: new line
        CPI     CR
        RZ                      ; CR: invisible, no col/row change
        ; Other chars: increment column
GBRTCL:
        CALL    GBCSCOL
        INX     H
        JMP     GBSETCSCOL
GBRTNL:
        LXI     H,0
        CALL    GBSETCSCOL
        CALL    GBCSROW
        INX     H
        MOV     A,L
        PUSH    B
        PUSH    H
        LDA     REROWS
        MOV     B,A
        MOV     A,L
        CMP     B               ; compare row vs REROWS
        POP     H
        POP     B
        JNC     GBRTSC
        JMP     GBSETCSROW
GBRTSC:
        CALL    GBTOPLN
        INX     H
        CALL    GBSETTOPLN
        LDA     REROWS
        DCR     A
        MOV     L,A
        MVI     H,0
        JMP     GBSETCSROW
GBRTAT: RET

;=============================================================
; GBMLNS - Move cursor to start of current line.
; Entry:  (none)
; Exit:   Cursor at col 0; all regs clobbered
;=============================================================
GBMLNS:
        ; Move left until CSCOL = 0 or at BOF
GLSLLP: CALL    GBCSCOL
        MOV     A,L
        ORA     A
        RZ                      ; at col 0
        CALL    GBMVLT
        JMP     GLSLLP

;=============================================================
; GBMLNE - Move cursor to end of current line.
; Entry:  (none)
; Exit:   Cursor at end of line; all regs clobbered
;=============================================================
GBMLNE:
        ; Move right until LF or EOF
GLELP:  CALL    GBGAPEN         ; HL = GAPEN
        PUSH    H               ; save GAPEN (GBBSIZ clobbers HL)
        CALL    GBBSIZ          ; DE = BSIZE
        POP     H               ; HL = GAPEN restored
        ; Check GAPEN >= BSIZE (at end of buffer)
        MOV     A,L
        SUB     E
        MOV     A,H
        SBB     D
        JNC     GLEDN           ; GAPEN >= BSIZE, at end
        CALL    GBBASE
        CALL    GBGAPEN
        DAD     D
        MOV     A,M
        CPI     LF
        JZ      GLEDN
        CPI     CR
        JZ      GLEDN
        CALL    GBMVRT
        JMP     GLELP
GLEDN:  RET

;=============================================================
; GBMVTOP - Move cursor to top of file.
; Entry:  (none)
; Exit:   Cursor at offset 0; all regs clobbered
;=============================================================
GBMVTOP:
        ; Check virtual mode: if active, goto line 1
        LDA     VIMODE
        ORA     A
        JZ      GVTNRM
        LHLD    VBFLN
        MOV     A,H
        ORA     L
        JZ      GVTNRM          ; no BEFORE lines, use normal path
        LXI     H,1
        JMP     VIGOTO
GVTNRM:
        ; Bulk move: copy entire R1 to end of gap (backward copy)
        CALL    GBGAPBG
        MOV     A,H
        ORA     L
        JZ      GVTPOS          ; GAPBG=0, already at top
        ; N = GAPBG (entire pre-gap region)
        SHLD    GPGCNT
        ; Save base address
        CALL    GBBASE
        XCHG
        SHLD    GPGBAS
        ; Dest end: base + GAPEN - 1
        CALL    GBGAPEN
        XCHG
        LHLD    GPGBAS
        DAD     D
        DCX     H               ; HL = dest end
        PUSH    H
        ; Src end: base + GAPBG - 1
        CALL    GBGAPBG
        XCHG
        LHLD    GPGBAS
        DAD     D
        DCX     H               ; HL = src end
        PUSH    H
        ; Load BC = N
        LHLD    GPGCNT
        MOV     B,H
        MOV     C,L
        POP     H               ; HL = src end
        POP     D               ; DE = dest end
        ; Copy backward (dest > src, safe)
GVTCLP: MOV     A,M
        STAX    D
        DCX     H
        DCX     D
        DCX     B
        MOV     A,B
        ORA     C
        JNZ     GVTCLP
        ; --- Update descriptor fields ---
        LHLD    GPGCNT
        MOV     B,H
        MOV     C,L             ; BC = N
        ; GAPEN -= N (gap slides left)
        CALL    GBGAPEN
        MOV     A,L
        SUB     C
        MOV     L,A
        MOV     A,H
        SBB     B
        MOV     H,A
        CALL    GBSETGAPEN
        ; GAPBG = 0
        LXI     H,0
        CALL    GBSETGAPBG
        ; CSOFF = 0
        LXI     H,0
        CALL    GBSETCSOFF
GVTPOS: ; Set cursor to top of file
        LXI     H,0
        CALL    GBSETTOPLN
        LXI     H,0
        CALL    GBSETCSROW
        LXI     H,0
        JMP     GBSETCSCOL

;=============================================================
; GBMVEND - Move cursor to end of file.
; Uses bulk gap move: copies entire R2 region forward in one
; tight loop instead of calling GBMVRT per character.
; Entry:  (none)
; Exit:   Cursor at last char; all regs clobbered
;=============================================================
GBMVEND:
        ; Check virtual mode: if active, goto last line
        LDA     VIMODE
        ORA     A
        JZ      GVENRM
        LHLD    VAFLN
        MOV     A,H
        ORA     L
        JZ      GVENRM          ; no AFTER lines, use normal path
        ; Total lines = VBFLN + buffer_lines + VAFLN
        ; Call GBCNTLN for buffer lines (no recursion since VIMODE
        ; goto will be handled before reaching GBMVEND again)
        ; Actually just use a large target line: VBFLN+buf+VAFLN
        ; We can get total from GBCNTLN (which we'll modify to include VBFLN+VAFLN)
        CALL    GBCNTLN         ; HL = total lines (includes VBFLN+VAFLN)
        JMP     VIGOTO
GVENRM:
        ; Compute N = BSIZE - GAPEN (entire R2 region)
        CALL    GBGAPEN
        PUSH    H
        CALL    GBBSIZ          ; DE = BSIZE
        POP     H               ; HL = GAPEN
        MOV     A,E
        SUB     L
        MOV     C,A
        MOV     A,D
        SBB     H
        MOV     B,A             ; BC = N = BSIZE - GAPEN
        MOV     A,B
        ORA     C
        JZ      GVEPOS          ; N=0, already at end
        MOV     H,B
        MOV     L,C
        SHLD    GPGCNT
        ; Save base address
        CALL    GBBASE
        XCHG
        SHLD    GPGBAS
        ; Dest: base + GAPBG
        CALL    GBGAPBG
        XCHG
        LHLD    GPGBAS
        DAD     D               ; HL = dest
        PUSH    H
        ; Src: base + GAPEN
        CALL    GBGAPEN
        XCHG
        LHLD    GPGBAS
        DAD     D               ; HL = src
        PUSH    H
        ; Load BC = N
        LHLD    GPGCNT
        MOV     B,H
        MOV     C,L
        POP     H               ; HL = src
        POP     D               ; DE = dest
        ; Copy forward (dest < src, safe)
GVECLP: MOV     A,M
        STAX    D
        INX     H
        INX     D
        DCX     B
        MOV     A,B
        ORA     C
        JNZ     GVECLP
        ; --- Update descriptor fields ---
        LHLD    GPGCNT
        MOV     B,H
        MOV     C,L             ; BC = N
        ; GAPBG += N
        CALL    GBGAPBG
        DAD     B
        CALL    GBSETGAPBG
        ; GAPEN += N (= BSIZE)
        CALL    GBGAPEN
        DAD     B
        CALL    GBSETGAPEN
        ; CSOFF += N
        CALL    GBCSOFF
        DAD     B
        CALL    GBSETCSOFF
GVEPOS: ; Compute TOPLN and CSROW from total line count
        CALL    GBCNTLN         ; HL = total lines
        ; Is total_lines <= REROWS?
        MOV     A,H
        ORA     A
        JNZ     GVESCR          ; > 255 lines, must scroll
        PUSH    B
        LDA     REROWS
        INR     A
        MOV     B,A
        MOV     A,L
        CMP     B               ; compare lines vs REROWS+1
        POP     B
        JNC     GVESCR          ; > REROWS lines
        ; total_lines <= REROWS: TOPLN=0, CSROW=lines-1
        DCX     H
        CALL    GBSETCSROW
        LXI     H,0
        CALL    GBSETTOPLN
        JMP     GVECOL
GVESCR: ; total_lines > REROWS: TOPLN = lines - REROWS
        PUSH    B
        LDA     REROWS
        MOV     B,A
        MOV     A,L
        SUB     B
        MOV     L,A
        MOV     A,H
        SBI     0
        MOV     H,A
        POP     B
        CALL    GBSETTOPLN
        LDA     REROWS
        DCR     A
        MOV     L,A
        MVI     H,0
        CALL    GBSETCSROW
GVECOL: CALL    GBCURLNL
        JMP     GBSETCSCOL

;=============================================================
; GBGOTOL - Go to a specific line number (fast bulk move).
; Moves cursor to file top, then forward-scans R2 for
; (target-1) LFs and bulk-copies those bytes into R1.
; Entry:  HL = target line number (1-based)
; Exit:   Cursor at start of target line; regs clobbered
;=============================================================
GBGOTOL:
        MOV     A,H
        ORA     L
        RZ                      ; line 0 = no-op
        ; Clamp target to total line count
        PUSH    H               ; save target
        CALL    GBCNTLN         ; HL = total lines
        XCHG                    ; DE = total
        POP     H               ; HL = target
        MOV     A,H
        CMP     D
        JC      GGTCLMP         ; target_H < total_H, in range
        JNZ     GGTCL2          ; target_H > total_H, clamp
        MOV     A,L
        CMP     E
        JC      GGTCLMP         ; target < total, in range
        JZ      GGTCLMP         ; target == total, in range
GGTCL2: XCHG                    ; HL = total (clamp to max)
GGTCLMP:
        ; In virtual mode, check if target is in buffer range
        LDA     VIMODE
        ORA     A
        JZ      GGTLNRM         ; normal mode
        ; Virtual mode: HL = absolute target line (1-based)
        ; Buffer holds lines VBFLN+1 .. VBFLN+buf_lines
        SHLD    GPGTMP          ; save target
        ; Compute BC = target - VBFLN
        XCHG                    ; DE = target
        LHLD    VBFLN           ; HL = VBFLN
        MOV     A,E
        SUB     L
        MOV     C,A             ; C = low byte of (target - VBFLN)
        MOV     A,D
        SBB     H
        MOV     B,A             ; B = high byte
        JC      GGTVIG          ; target < VBFLN, outside buffer
        ; BC = target - VBFLN. If BC = 0, target = VBFLN (outside: that's in BEFORE)
        MOV     A,B
        ORA     C
        JZ      GGTVIG          ; target = VBFLN, outside buffer
        ; BC = buffer-relative line (1-based). Check if within buffer.
        ; Need buffer line count from GBCNTLN (raw, not including VBFLN/VAFLN)
        PUSH    B               ; save buffer-relative target
        ; Temporarily clear VIMODE to get raw buffer line count
        XRA     A
        STA     VIMODE
        CALL    GBCNTLN         ; HL = buffer lines only
        MVI     A,1
        STA     VIMODE          ; restore VIMODE
        POP     B               ; BC = buffer-relative target
        ; If VAFLN > 0, subtract 1 from buffer lines (phantom line)
        PUSH    H               ; save buffer_lines
        PUSH    B               ; save target
        LHLD    VAFLN
        MOV     A,H
        ORA     L
        POP     B               ; restore target
        POP     H               ; restore buffer_lines
        JZ      GGTCHK          ; VAFLN=0, no phantom
        DCX     H               ; HL = buffer_lines - 1
GGTCHK:
        ; Check BC <= HL (target <= usable buffer lines)
        MOV     A,L
        SUB     C
        MOV     A,H
        SBB     B               ; HL - BC
        JC      GGTVIG          ; buffer_lines < target, outside buffer
        ; Target is in buffer. Use normal GBGOTOL with BC as line number.
        MOV     H,B
        MOV     L,C
        JMP     GGTLNRM
GGTVIG:
        ; Reposition buffer with margin: VIGOTO(max(1, target-REROWS))
        ; This keeps REROWS lines before target in the buffer
        LHLD    GPGTMP          ; HL = absolute target
        LDA     REROWS
        CMA
        INR     A
        MOV     E,A
        MVI     D,0FFH          ; DE = -REROWS
        DAD     D               ; HL = target - REROWS
        JNC     GGTVI1          ; underflow: target < REROWS
        MOV     A,H
        ORA     L
        JNZ     GGTVI2          ; result > 0, use it
GGTVI1: LXI     H,1             ; clamp to 1
GGTVI2: CALL    VIGOTO          ; reposition with margin
        ; Navigate within buffer to actual target line
        LHLD    GPGTMP          ; HL = absolute target
        XCHG                    ; DE = target
        LHLD    VBFLN           ; HL = lines in BEFORE
        MOV     A,E
        SUB     L
        MOV     L,A
        MOV     A,D
        SBB     H
        MOV     H,A             ; HL = target - VBFLN (buffer-relative)
        JMP     GGTLNRM        ; position cursor within buffer
GGTLNRM:
        ; Clamp target to buffer line count
        PUSH    H               ; save target
        LDA     VIMODE
        STA     GPGTM2          ; save current VIMODE
        XRA     A
        STA     VIMODE          ; raw count mode
        CALL    GBCNTLN         ; HL = buffer lines only
        LDA     GPGTM2
        STA     VIMODE          ; restore VIMODE
        XCHG                    ; DE = buffer lines
        POP     H               ; HL = target
        MOV     A,D
        CMP     H
        JC      GGTCLM          ; buf_lines < target (high)
        JNZ     GGTCOK          ; buf_lines > target (high)
        MOV     A,E
        CMP     L
        JNC     GGTCOK          ; buf_lines >= target
GGTCLM: XCHG                    ; HL = clamped to buf_lines
GGTCOK:
        SHLD    GGTLIN          ; save target line number
        DCX     H               ; HL = LFs to skip
        SHLD    GGTCNT          ; save LF count
        ; Move to top first (one bulk copy)
        LDA     VIMODE
        STA     GPGTM2          ; save current VIMODE
        XRA     A
        STA     VIMODE
        CALL    GBMVTOP
        LDA     GPGTM2
        STA     VIMODE          ; restore VIMODE
        ; If target is line 1, already at top
        LHLD    GGTCNT
        MOV     A,H
        ORA     L
        JZ      GGTPOS          ; line 1, done
        ; Save base address
        CALL    GBBASE
        XCHG
        SHLD    GPGBAS
        ; Save GAPEN (after GBMVTOP, gap fills entire front)
        CALL    GBGAPEN
        SHLD    GGTGPE          ; save original GAPEN
        ; Compute R2 start = base + GAPEN
        XCHG                    ; DE = GAPEN
        LHLD    GPGBAS
        DAD     D               ; HL = base + GAPEN = R2 start
        PUSH    H               ; save R2 start address
        ; Compute R2 end = base + BSIZE
        CALL    GBBSIZ          ; DE = BSIZE
        LHLD    GPGBAS
        DAD     D               ; HL = base + BSIZE = R2 end
        XCHG                    ; DE = R2 end
        POP     H               ; HL = R2 start
        ; Forward scan for GGTCNT LFs
GGTSLP: MOV     A,H
        CMP     D
        JNZ     GGTSNE
        MOV     A,L
        CMP     E
        JZ      GGTSDN          ; reached end of text
GGTSNE: MOV     A,M
        INX     H
        CPI     LF
        JNZ     GGTSLP
        ; Found a LF, decrement count
        PUSH    H
        PUSH    D
        LHLD    GGTCNT
        DCX     H
        SHLD    GGTCNT
        MOV     A,H
        ORA     L
        POP     D
        POP     H
        JNZ     GGTSLP          ; more LFs to find
GGTSDN: ; HL = one past last LF (or end of text)
        ; Compute N = HL - (base + GAPEN)
        PUSH    H               ; save end position
        LHLD    GGTGPE          ; HL = GAPEN
        XCHG                    ; DE = GAPEN
        LHLD    GPGBAS          ; HL = base
        DAD     D               ; HL = base + GAPEN = R2 start
        POP     D               ; DE = end position
        MOV     A,E
        SUB     L
        MOV     C,A
        MOV     A,D
        SBB     H
        MOV     B,A             ; BC = N (bytes to copy)
        MOV     A,B
        ORA     C
        JZ      GGTPOS          ; N=0, nothing to move
        MOV     H,B
        MOV     L,C
        SHLD    GPGCNT          ; save byte count
        ; Forward copy: base+GAPEN → base+0 (GAPBG=0 after MVTOP)
        ; Src: base + GAPEN
        LHLD    GGTGPE
        XCHG
        LHLD    GPGBAS
        DAD     D               ; HL = src
        PUSH    H
        ; Dst: base (GAPBG = 0)
        LHLD    GPGBAS          ; HL = dst
        PUSH    H
        ; Load BC = N
        LHLD    GPGCNT
        MOV     B,H
        MOV     C,L
        POP     D               ; DE = dst
        POP     H               ; HL = src
        ; Copy forward (src > dst, safe)
GGTCLP: MOV     A,M
        STAX    D
        INX     H
        INX     D
        DCX     B
        MOV     A,B
        ORA     C
        JNZ     GGTCLP
        ; --- Update descriptor fields ---
        LHLD    GPGCNT
        MOV     B,H
        MOV     C,L             ; BC = N
        ; GAPBG = 0 + N = N
        MOV     H,B
        MOV     L,C
        CALL    GBSETGAPBG
        ; GAPEN = old_GAPEN + N
        LHLD    GGTGPE
        DAD     B
        CALL    GBSETGAPEN
        ; CSOFF = N
        LHLD    GPGCNT
        CALL    GBSETCSOFF
GGTPOS: ; Set TOPLN and CSROW based on target line
        LHLD    GGTLIN          ; HL = target line (1-based)
        ; If target <= REROWS: TOPLN=0, CSROW=target-1
        MOV     A,H
        ORA     A
        JNZ     GGTSRL          ; > 255, must scroll
        PUSH    B
        LDA     REROWS
        INR     A
        MOV     B,A
        MOV     A,L
        CMP     B               ; compare target vs REROWS+1
        POP     B
        JNC     GGTSRL          ; > REROWS, must scroll
        ; No scroll: TOPLN = 0, CSROW = target - 1
        DCX     H
        CALL    GBSETCSROW
        LXI     H,0
        CALL    GBSETTOPLN
        JMP     GGTCOL
GGTSRL: ; Scroll: TOPLN = target - 1, CSROW = 0
        DCX     H
        CALL    GBSETTOPLN
        LXI     H,0
        CALL    GBSETCSROW
GGTCOL: ; CSCOL = 0 (at start of line)
        LXI     H,0
        JMP     GBSETCSCOL

;=============================================================
; GBPGUP - Scroll up one page (REROWS lines).
; Uses bulk gap move for performance: scans backward for
; REROWS LFs, then copies bytes in one tight loop instead
; of calling GBMVRT per character.
; Entry:  (none)
; Exit:   Cursor moved up REROWS lines; regs clobbered
;=============================================================
GBPGUP:
        ; Check if already at top of file
        CALL    GBGAPBG
        MOV     A,H
        ORA     L
        JNZ     GPUNRM          ; GAPBG>0, continue normally
        ; GAPBG=0: check virtual mode for more content above
        LDA     VIMODE
        ORA     A
        RZ                      ; normal mode, true BOF
        LHLD    VBFLN
        MOV     A,H
        ORA     L
        RZ                      ; no BEFORE lines, true BOF
        ; Virtual: compute display target = VBFLN + TOPLN - REROWS + 1
        CALL    GBTOPLN         ; HL = TOPLN
        XCHG                    ; DE = TOPLN
        LHLD    VBFLN           ; HL = VBFLN
        DAD     D               ; HL = VBFLN + TOPLN
        LDA     REROWS
        DCR     A               ; A = REROWS-1
        CMA
        INR     A               ; A = -(REROWS-1)
        MOV     E,A
        MVI     D,0FFH          ; DE = -(REROWS-1)
        DAD     D               ; HL = VBFLN + TOPLN - REROWS + 1
        ; Clamp to minimum 1
        MOV     A,H
        ORA     A
        JP      GPUVGO          ; positive high byte, ok
        LXI     H,1             ; clamp to line 1
GPUVGO: MOV     A,H
        ORA     L
        JNZ     GPUVG1
        LXI     H,1             ; if zero, clamp to 1
GPUVG1:
        ; Save display target, then load with REROWS margin
        SHLD    GPGTMP          ; save display target
        LDA     REROWS
        CMA
        INR     A
        MOV     E,A
        MVI     D,0FFH          ; DE = -REROWS
        DAD     D               ; HL = target - REROWS (margin)
        JNC     GPUVC1          ; underflow: clamp to 1
        MOV     A,H
        ORA     L
        JNZ     GPUVC2
GPUVC1: LXI     H,1
GPUVC2: CALL    VIGOTO          ; load buffer with margin
        ; Navigate cursor to display target within buffer
        LHLD    GPGTMP          ; HL = absolute display target
        XCHG                    ; DE = target
        LHLD    VBFLN           ; HL = VBFLN
        MOV     A,E
        SUB     L
        MOV     L,A
        MOV     A,D
        SBB     H
        MOV     H,A             ; HL = buffer-relative target
        ; Clamp to 1 if zero or negative
        MOV     A,H
        ORA     A
        JM      GPUVC3
        ORA     L
        JNZ     GGTLNRM         ; position cursor within buffer
GPUVC3: LXI     H,1
        JMP     GGTLNRM         ; position cursor at line 1
GPUNRM:
        ; Save base address
        CALL    GBBASE
        XCHG
        SHLD    GPGBAS
        ; Compute scan start: base + GAPBG - 1
        CALL    GBGAPBG
        XCHG                    ; DE = GAPBG
        LHLD    GPGBAS          ; HL = base
        DAD     D               ; HL = base + GAPBG
        DCX     H               ; HL = last pre-gap byte addr
        ; Set up scan: HL = scan ptr, DE = base (stop address)
        XCHG                    ; DE = scan start
        LHLD    GPGBAS          ; HL = base
        XCHG                    ; DE = base, HL = scan start
        LDA     REROWS
        MOV     B,A             ; B = REROWS (LF counter)
        ; --- Backward scan for REROWS LFs ---
GPUSLP: MOV     A,M
        CPI     LF
        JNZ     GPUSNL
        DCR     B
        JZ      GPUFND          ; found all REROWS LFs
GPUSNL: MOV     A,H             ; check if ptr == base
        CMP     D
        JNZ     GPUSGO
        MOV     A,L
        CMP     E
        JZ      GPUBOF          ; reached buffer start
GPUSGO: DCX     H
        JMP     GPUSLP
GPUFND: ; Found all LFs. HL = address of last LF.
        INX     H               ; cursor target = byte after LF
        LDA     REROWS
        DCR     A               ; A = REROWS-1 (effective lines back)
        STA     GPGLFS          ; backward scan: L LFs = L-1 lines
        JMP     GPUCPY
GPUBOF: ; Reached beginning of file.
        LDA     REROWS
        SUB     B               ; A = LFs actually found
        JZ      GPURT           ; 0 LFs above cursor, nothing to do
        STA     GPGLFS
        ; HL = base = cursor target
GPUCPY: ; HL = absolute target address, GPGLFS = LFs crossed
        ; Compute N = (base + GAPBG) - HL
        XCHG                    ; DE = target
        CALL    GBGAPBG         ; HL = GAPBG
        PUSH    D               ; save target
        XCHG                    ; DE = GAPBG
        LHLD    GPGBAS
        DAD     D               ; HL = base + GAPBG
        POP     D               ; DE = target
        MOV     A,L
        SUB     E
        MOV     C,A
        MOV     A,H
        SBB     D
        MOV     B,A             ; BC = N (bytes to move)
        MOV     A,B
        ORA     C
        JZ      GPURT           ; N=0, nothing to do
        MOV     H,B
        MOV     L,C
        SHLD    GPGCNT          ; save byte count
        ; --- Backward copy: pre-gap tail → gap tail ---
        ; Dest end: base + GAPEN - 1
        CALL    GBGAPEN
        XCHG
        LHLD    GPGBAS
        DAD     D
        DCX     H               ; HL = dest end
        PUSH    H               ; save dest end
        ; Src end: base + GAPBG - 1
        CALL    GBGAPBG
        XCHG
        LHLD    GPGBAS
        DAD     D
        DCX     H               ; HL = src end
        ; Load BC = N
        PUSH    H               ; save src end
        LHLD    GPGCNT
        MOV     B,H
        MOV     C,L             ; BC = N
        POP     H               ; HL = src end
        POP     D               ; DE = dest end
        ; Copy backward (safe: dest > src)
GPUCLP: MOV     A,M
        STAX    D
        DCX     H
        DCX     D
        DCX     B
        MOV     A,B
        ORA     C
        JNZ     GPUCLP
        ; --- Update descriptor fields ---
        LHLD    GPGCNT
        MOV     B,H
        MOV     C,L             ; BC = N
        ; GAPBG -= N
        CALL    GBGAPBG
        MOV     A,L
        SUB     C
        MOV     L,A
        MOV     A,H
        SBB     B
        MOV     H,A
        CALL    GBSETGAPBG
        ; GAPEN -= N
        CALL    GBGAPEN
        MOV     A,L
        SUB     C
        MOV     L,A
        MOV     A,H
        SBB     B
        MOV     H,A
        CALL    GBSETGAPEN
        ; CSOFF -= N
        CALL    GBCSOFF
        MOV     A,L
        SUB     C
        MOV     L,A
        MOV     A,H
        SBB     B
        MOV     H,A
        CALL    GBSETCSOFF
        ; --- Update CSROW and TOPLN ---
        LDA     GPGLFS
        MOV     B,A             ; B = L (preserved across accessors)
        ; TOPLN -= L, CSROW unchanged (stays at R)
        CALL    GBTOPLN         ; HL = T
        PUSH    H               ; save T for underflow case
        MOV     A,L
        SUB     B
        MOV     L,A
        MOV     A,H
        SBI     0
        MOV     H,A
        JC      GPUUFL          ; underflow: T < L
        ; No underflow: TOPLN = T - L, CSROW unchanged
        CALL    GBSETTOPLN
        POP     H               ; discard saved T
        JMP     GPUCOL
GPUUFL: ; T < L: TOPLN = 0, CSROW = R + T - L
        POP     H               ; HL = old T (T < L <= 19)
        MOV     C,L             ; C = T (low byte sufficient)
        LXI     H,0
        CALL    GBSETTOPLN
        CALL    GBCSROW         ; L = R
        MOV     A,L             ; A = R
        ADD     C               ; A = R + T
        SUB     B               ; A = R + T - L
        MOV     L,A
        MVI     H,0
        CALL    GBSETCSROW
GPUCOL: CALL    GBCURLNL
        CALL    GBSETCSCOL
GPURT:  RET

;=============================================================
; GBPGDN - Scroll down one page (REROWS lines).
; Uses bulk gap move for performance: scans forward for
; REROWS LFs, then copies bytes in one tight loop instead
; of calling GBMVRT per character.
; Entry:  (none)
; Exit:   Cursor moved down REROWS lines; regs clobbered
;=============================================================
GBPGDN:
        ; Check if at end of file
        CALL    GBGAPEN
        PUSH    H
        CALL    GBBSIZ          ; DE = BSIZE
        POP     H               ; HL = GAPEN
        MOV     A,L
        SUB     E
        MOV     A,H
        SBB     D
        JC      GPDNRM          ; GAPEN < BSIZE, not at EOF
        ; GAPEN >= BSIZE: check virtual mode for more content below
        LDA     VIMODE
        ORA     A
        RZ                      ; normal mode, true EOF
        LHLD    VAFLN
        MOV     A,H
        ORA     L
        RZ                      ; no AFTER lines, true EOF
        ; Virtual: target = VBFLN + TOPLN + REROWS + 1
        CALL    GBTOPLN         ; HL = TOPLN
        XCHG                    ; DE = TOPLN
        LHLD    VBFLN           ; HL = VBFLN
        DAD     D               ; HL = VBFLN + TOPLN
        LDA     REROWS
        INR     A
        MOV     E,A
        MVI     D,0             ; DE = REROWS+1
        DAD     D               ; HL = VBFLN + TOPLN + REROWS + 1
        JMP     VIGOTO
GPDNRM:
        ; Save base address
        CALL    GBBASE
        XCHG
        SHLD    GPGBAS
        ; Compute scan region: base+GAPEN .. base+BSIZE
        CALL    GBGAPEN
        XCHG                    ; DE = GAPEN
        LHLD    GPGBAS
        DAD     D               ; HL = base + GAPEN = src start
        PUSH    H               ; save src start
        CALL    GBBSIZ          ; DE = BSIZE
        LHLD    GPGBAS
        DAD     D               ; HL = base + BSIZE = src end
        XCHG                    ; DE = src end
        POP     H               ; HL = src start
        LDA     REROWS
        MOV     B,A             ; B = REROWS (LF counter)
        ; --- Forward scan for REROWS LFs ---
GPDSLP: MOV     A,H             ; compare ptr with end
        CMP     D
        JNZ     GPDSNE
        MOV     A,L
        CMP     E
        JZ      GPDEOF          ; reached end of text
GPDSNE: MOV     A,M             ; read byte
        INX     H               ; advance ptr past byte
        CPI     LF
        JNZ     GPDSLP
        DCR     B               ; counted a LF
        JNZ     GPDSLP
        ; Found all REROWS LFs. HL = after last LF.
        JMP     GPDCNT
GPDEOF: ; Reached end with fewer LFs. HL = end.
GPDCNT: ; HL = copy-end position, B = remaining LF count
        LDA     REROWS
        SUB     B
        STA     GPGLFS          ; LFs found
        ; Compute N = HL - (base + GAPEN)
        PUSH    H               ; save end position
        CALL    GBGAPEN
        XCHG                    ; DE = GAPEN
        LHLD    GPGBAS
        DAD     D               ; HL = base + GAPEN = src start
        POP     D               ; DE = end position
        MOV     A,E
        SUB     L
        MOV     C,A
        MOV     A,D
        SBB     H
        MOV     B,A             ; BC = N (bytes to copy)
        MOV     A,B
        ORA     C
        RZ                      ; N=0, nothing to do
        MOV     H,B
        MOV     L,C
        SHLD    GPGCNT          ; save byte count
        ; --- Forward copy: base+GAPEN → base+GAPBG ---
        ; Dest: base + GAPBG
        CALL    GBGAPBG
        XCHG
        LHLD    GPGBAS
        DAD     D               ; HL = dest
        PUSH    H               ; save dest
        ; Src: base + GAPEN
        CALL    GBGAPEN
        XCHG
        LHLD    GPGBAS
        DAD     D               ; HL = src
        PUSH    H               ; save src
        ; Load BC = N
        LHLD    GPGCNT
        MOV     B,H
        MOV     C,L
        POP     H               ; HL = src
        POP     D               ; DE = dest
        ; Copy forward (safe: src > dest)
GPDCLP: MOV     A,M
        STAX    D
        INX     H
        INX     D
        DCX     B
        MOV     A,B
        ORA     C
        JNZ     GPDCLP
        ; --- Update descriptor fields ---
        LHLD    GPGCNT
        MOV     B,H
        MOV     C,L             ; BC = N
        ; GAPBG += N
        CALL    GBGAPBG
        DAD     B
        CALL    GBSETGAPBG
        ; GAPEN += N
        CALL    GBGAPEN
        DAD     B
        CALL    GBSETGAPEN
        ; CSOFF += N
        CALL    GBCSOFF
        DAD     B
        CALL    GBSETCSOFF
        ; --- Update CSROW and TOPLN ---
        LDA     GPGLFS
        MOV     B,A             ; B = LFs crossed (L)
        CALL    GBCSROW
        MOV     A,L             ; A = current row (R)
        ADD     B               ; A = R + L
        PUSH    B
        MOV     C,A             ; save R+L in C
        LDA     REROWS
        MOV     B,A             ; B = REROWS
        MOV     A,C             ; A = R+L
        CMP     B               ; compare (R+L) vs REROWS
        POP     B
        JC      GPDNSC          ; R + L < REROWS, no scroll
        ; Scroll: TOPLN += L, CSROW unchanged (stays at R)
        LDA     GPGLFS
        MOV     C,A
        MVI     B,0             ; BC = L
        CALL    GBTOPLN
        DAD     B
        CALL    GBSETTOPLN
        JMP     GPDCOL
GPDNSC: ; No scroll: CSROW = R + L
        MOV     L,A
        MVI     H,0
        CALL    GBSETCSROW
GPDCOL: CALL    GBCURLNL
        CALL    GBSETCSCOL
        ; Check if page-down landed on phantom line at buffer end
        CALL    GBGAPEN
        PUSH    H
        CALL    GBBSIZ
        POP     H
        MOV     A,L
        SUB     E
        MOV     A,H
        SBB     D
        RC                      ; GAPEN < BSIZE, all good
        ; GAPEN >= BSIZE: trigger VIGOTO if virtual with AFTER data
        LDA     VIMODE
        ORA     A
        RZ                      ; normal mode
        LHLD    VAFLN
        MOV     A,H
        ORA     L
        RZ                      ; no AFTER lines
        ; Reposition: target = VBFLN + TOPLN + 1
        CALL    GBTOPLN
        XCHG                    ; DE = TOPLN
        LHLD    VBFLN
        DAD     D
        INX     H               ; HL = VBFLN + TOPLN + 1
        JMP     VIGOTO

;=============================================================
; GBMVUP - Move cursor up one line.
; Entry:  (none)
; Exit:   Cursor on previous line, same col if possible
;=============================================================
GBMVUP:
        CALL    GBCSROW
        MOV     A,L
        ORA     H
        JNZ     GVUROW          ; not at top of screen
        ; At row 0: scroll back if TOPLN > 0
        CALL    GBTOPLN
        MOV     A,H
        ORA     L
        JZ      GVUBOT          ; already at file top
        CALL    GBMLNS         ; go to line start
        CALL    GVUSKP          ; step over LF (and CR if present)
        JMP     GBMLNS         ; go to start of that line
GVUROW:
        ; Move to start of current line, then prev line
        CALL    GBMLNS
        CALL    GVUSKP          ; step over LF (and CR if present)
        JMP     GBMLNS         ; start of prev line
;------------------------------------------------------------
; GVUSKP - Step backward over line ending (LF, then CR if present)
;------------------------------------------------------------
GVUSKP:
        CALL    GBMVLT          ; step over LF
        ; Check if char to left of gap is CR
        CALL    GBGAPBG
        MOV     A,H
        ORA     L
        RZ                      ; at BOF, done
        CALL    GBBASE          ; DE = base
        CALL    GBGAPBG         ; HL = GAPBG
        DCX     H
        DAD     D               ; HL = base + GAPBG - 1
        MOV     A,M
        CPI     CR
        RNZ                     ; not CR, done
        JMP     GBMVLT          ; skip CR too
GVUBOT:
        ; Check virtual mode for content above buffer
        LDA     VIMODE
        ORA     A
        RZ                      ; normal mode, true BOF
        LHLD    VBFLN
        MOV     A,H
        ORA     L
        RZ                      ; no BEFORE lines, true BOF
        ; Virtual: target = max(1, VBFLN - REROWS + 1)
        ; Load buffer with margin so target line is near bottom of screen
        LHLD    VBFLN
        LDA     REROWS
        DCR     A               ; A = REROWS-1
        CMA
        INR     A               ; A = -(REROWS-1)
        MOV     E,A
        MVI     D,0FFH          ; DE = -(REROWS-1)
        DAD     D               ; HL = VBFLN - REROWS + 1
        JNC     GVUB1           ; underflow: clamp to 1
        MOV     A,H
        ORA     L
        JNZ     GVUB2           ; > 0, use it
GVUB1:  LXI     H,1             ; clamp to 1
GVUB2:  CALL    VIGOTO
        RET

;=============================================================
; GBMVDN - Move cursor down one line.
; Entry:  (none)
; Exit:   Cursor on next line; regs clobbered
;=============================================================
GBMVDN:
        ; Move to end of current line then past newline
        CALL    GBMLNE
        ; Check if at end of buffer before reading
        CALL    GBGAPEN         ; HL = GAPEN
        PUSH    H
        CALL    GBBSIZ          ; DE = BSIZE
        POP     H
        MOV     A,L
        SUB     E
        MOV     A,H
        SBB     D
        JNC     GVDNEF          ; GAPEN >= BSIZE, at buffer EOF
        ; Try to step over CR+LF
        CALL    GBBASE
        CALL    GBGAPEN
        DAD     D
        MOV     A,M
        CPI     CR
        JNZ     GVDNLF
        CALL    GBMVRT          ; skip CR
GVDNLF:
        ; Check again after possible CR skip
        CALL    GBGAPEN
        PUSH    H
        CALL    GBBSIZ
        POP     H
        MOV     A,L
        SUB     E
        MOV     A,H
        SBB     D
        JNC     GVDNEF          ; at buffer EOF after CR
        CALL    GBBASE
        CALL    GBGAPEN
        DAD     D
        MOV     A,M
        CPI     LF
        JNZ     GVDNDN
        CALL    GBMVRT          ; skip LF (CSROW/scroll adjusted)
        ; Check if we landed on phantom line at buffer end
        CALL    GBGAPEN
        PUSH    H
        CALL    GBBSIZ
        POP     H
        MOV     A,L
        SUB     E
        MOV     A,H
        SBB     D
        JNC     GVDNPH          ; GAPEN >= BSIZE, phantom line
        JMP     GVDNDN          ; successfully moved down
GVDNPH:
        ; Phantom line after LF skip: CSROW already incremented.
        ; Use +1 (not +2) since we're already past the newline.
        LDA     VIMODE
        ORA     A
        JZ      GVDNDN          ; normal mode, true EOF
        LHLD    VAFLN
        MOV     A,H
        ORA     L
        JZ      GVDNDN          ; no AFTER lines, true EOF
        ; target = VBFLN + TOPLN + CSROW + 1
        CALL    GBTOPLN
        XCHG                    ; DE = TOPLN
        LHLD    VBFLN
        DAD     D               ; HL = VBFLN + TOPLN
        SHLD    GPGTMP
        CALL    GBCSROW         ; HL = CSROW
        XCHG                    ; DE = CSROW
        LHLD    GPGTMP
        DAD     D               ; HL = VBFLN + TOPLN + CSROW
        INX     H               ; HL = VBFLN + TOPLN + CSROW + 1
        JMP     VIGOTO
GVDNEF:
        ; Buffer EOF: check virtual mode for content below
        LDA     VIMODE
        ORA     A
        JZ      GVDNDN          ; normal mode, true EOF
        LHLD    VAFLN
        MOV     A,H
        ORA     L
        JZ      GVDNDN          ; no AFTER lines, true EOF
        ; Virtual: target = VBFLN + TOPLN + CSROW + 2
        CALL    GBTOPLN
        XCHG                    ; DE = TOPLN
        LHLD    VBFLN
        DAD     D               ; HL = VBFLN + TOPLN
        SHLD    GPGTMP          ; save partial sum
        CALL    GBCSROW         ; HL = CSROW
        XCHG                    ; DE = CSROW
        LHLD    GPGTMP          ; HL = VBFLN + TOPLN
        DAD     D               ; HL = VBFLN + TOPLN + CSROW
        INX     H
        INX     H               ; HL = VBFLN + TOPLN + CSROW + 2
        JMP     VIGOTO

GVDNDN:
        ; Safety: recalculate CSCOL from scratch.
        ; Corrects any drift in incremental column tracking
        ; (e.g. CR handling, tab stops, or other edge cases).
        CALL    GBCURLNL        ; HL = chars since last LF
        JMP     GBSETCSCOL      ; force CSCOL = correct value

;=============================================================
; GBDLLN - Delete current line (including its newline).
; Entry:  (none)
; Exit:   Line deleted; regs clobbered
;=============================================================
GBDLLN:
        CALL    GBMLNS         ; go to line start
GDLNLP: CALL    GBGAPEN         ; HL = GAPEN
        PUSH    H               ; save GAPEN (GBBSIZ clobbers HL)
        CALL    GBBSIZ          ; DE = BSIZE
        POP     H               ; HL = GAPEN restored
        ; Check GAPEN >= BSIZE (at end of buffer)
        MOV     A,L
        SUB     E
        MOV     A,H
        SBB     D
        JNC     GDLNDN          ; GAPEN >= BSIZE, at end
        CALL    GBDELRT         ; delete next char (saves to GBTMP)
        LDA     GBTMP           ; get the deleted character
        CPI     LF
        JNZ     GDLNLP          ; keep going until LF
GDLNDN: RET

;=============================================================
; GBWRDNX - Move to start of next word.
; Entry:  (none)
; Exit:   Cursor at start of next word; regs clobbered
;=============================================================
GBWRDNX:
        ; Skip current word chars
GWNWRD: CALL    GBBASE
        CALL    GBGAPEN
        DAD     D
        MOV     A,M
        CALL    GBISWS          ; is whitespace?
        JZ      GWNWSP          ; yes, now skip spaces
        CALL    GBMVRT
        JMP     GWNWRD
GWNWSP: CALL    GBBASE
        CALL    GBGAPEN
        DAD     D
        MOV     A,M
        CALL    GBISWS
        JNZ     GWNDN           ; non-space = word start
        CALL    GBMVRT
        JMP     GWNWSP
GWNDN:  RET

;=============================================================
; GBWRDPV - Move to start of previous word.
; Entry:  (none)
; Exit:   Cursor at start of previous word; regs clobbered
;=============================================================
GBWRDPV:
        ; Skip whitespace left
GWPWSP: CALL    GBGAPBG
        MOV     A,H
        ORA     L
        RZ
        CALL    GBBASE
        CALL    GBGAPBG
        DCX     H
        DAD     D
        MOV     A,M
        CALL    GBISWS
        JNZ     GWPWRD          ; non-space, in a word
        CALL    GBMVLT
        JMP     GWPWSP
GWPWRD: ; Skip word chars left
        CALL    GBGAPBG
        MOV     A,H
        ORA     L
        RZ
        CALL    GBBASE
        CALL    GBGAPBG
        DCX     H
        DAD     D
        MOV     A,M
        CALL    GBISWS
        JZ      GWPDN           ; hit whitespace = done
        CALL    GBMVLT
        JMP     GWPWRD
GWPDN:  RET

;=============================================================
; GBGETLN - Get pointer to start of line N in text.
; Entry:  HL = line number (0-based)
; Exit:   HL = pointer to first byte of line N
;         A  = length of line (0-74)
;         Z  set if line is past end of file
;         Z clear if line exists
;=============================================================
GBGETLN:
        PUSH    H               ; save line number
        ; Count LF chars from text start
        ; Text: [0..GAPBG-1] + [GAPEN..BSIZE-1]
        ; We'll walk logical text using GBLOGRD
        CALL    GBBASE          ; DE = base
        LXI     H,0             ; HL = logical offset
        POP     B               ; BC = target line num
        MOV     A,B
        ORA     C
        JZ      GGLSRT          ; line 0 = start
        PUSH    B
GGLLP:
        CALL    GBLOGRD         ; A=char at HL offset
        JZ      GGLEOF          ; past end
        INX     H               ; advance offset
        CPI     LF
        JNZ     GGLLP
        ; Found a LF: decrement line counter
        POP     B
        DCX     B
        MOV     A,B
        ORA     C
        JZ      GGLSRT
        PUSH    B
        JMP     GGLLP
GGLEOF: POP     B               ; balance stack
        LXI     H,0
        XRA     A
        ORA     A               ; Z = past end
        RET
GGLSRT:
        ; HL = logical offset of line start
        ; Check if buffer is empty (TXEND = 0)
        PUSH    H               ; save logical offset
        CALL    GBTXEND         ; HL = TXEND
        MOV     A,H
        ORA     L               ; TXEND == 0?
        POP     H               ; restore logical offset
        JNZ     GGLSRP          ; not empty, proceed
        ; Empty buffer: line does not exist
        LXI     H,0
        XRA     A
        ORA     A               ; Z set = past end
        RET
GGLSRP:
        ; HL = logical offset of line start
        ; Copy line into flat buffer via GBLOGRD (gap-safe)
        LXI     D,GGLBUF        ; DE = output buffer
        MVI     B,0             ; B = char count
GGLCPY: MOV     A,B
        CPI     MAXCOLS
        JZ      GGLCPD          ; hit column limit
        PUSH    B               ; save char count (GBLOGRD clobbers BC)
        PUSH    D               ; save buffer pointer (GBLOGRD clobbers DE)
        CALL    GBLOGRD         ; A = byte at logical offset HL (preserves HL)
        POP     D               ; restore buffer pointer
        POP     B               ; restore char count
        JZ      GGLCPD          ; past end of text
        CPI     CR
        JNZ     GGLNCR
        INX     H               ; skip CR (invisible, not a delimiter)
        JMP     GGLCPY
GGLNCR: CPI     LF
        JZ      GGLCPD          ; end of line
        STAX    D               ; store char in buffer
        INX     D
        INX     H               ; advance logical offset
        INR     B
        JMP     GGLCPY
GGLCPD: ; NUL-terminate the copy buffer
        XRA     A
        STAX    D
        MOV     A,B             ; A = line length
        LXI     H,GGLBUF        ; HL = pointer to flat copy
        ORI     1               ; NZ = line exists
        RET

;=============================================================
; GBCURLN - Read current cursor line into GGLBUF.
; Fast path: scans backward from GAPBG for line start,
; then copies forward across the gap. O(line_length)
; instead of O(line_number) used by GBGETLN.
; Entry:  (none) - uses current cursor position
; Exit:   HL = GGLBUF, A = length, NZ = line exists
;         Z = buffer empty
; Clobbers: AF BC DE HL
;=============================================================
GBCURLN:
        ; Check if buffer is empty
        CALL    GBTXEND         ; HL = TXEND
        MOV     A,H
        ORA     L
        RZ                      ; Z = buffer empty

        ; --- Compute region boundaries ---
        CALL    GBBASE          ; DE = base
        XCHG
        SHLD    GCLBAS

        CALL    GBGAPBG         ; HL = GAPBG
        PUSH    H               ; save GAPBG for R2 end calc
        XCHG                    ; DE = GAPBG
        LHLD    GCLBAS
        DAD     D               ; HL = base + GAPBG
        SHLD    GCLR1E

        CALL    GBGAPEN         ; HL = GAPEN
        XCHG                    ; DE = GAPEN
        LHLD    GCLBAS
        DAD     D               ; HL = base + GAPEN
        SHLD    GCLR2S

        ; R2 end = R2 start + (TXEND - GAPBG)
        CALL    GBTXEND         ; HL = TXEND
        XCHG                    ; DE = TXEND
        POP     H               ; HL = GAPBG (saved earlier)
        MOV     A,E
        SUB     L
        MOV     E,A
        MOV     A,D
        SBB     H
        MOV     D,A             ; DE = TXEND - GAPBG
        LHLD    GCLR2S
        DAD     D
        SHLD    GCLR2E          ; R2 end

        ; --- Check if R1 has content (GAPBG > 0) ---
        LHLD    GCLR1E          ; HL = base + GAPBG
        XCHG                    ; DE = base + GAPBG
        LHLD    GCLBAS          ; HL = base
        MOV     A,E
        SUB     L
        JNZ     GCLR1           ; low bytes differ
        MOV     A,D
        SBB     H
        JZ      GCLNR0          ; GAPBG = 0, init GGLBUF then R2

GCLR1:
        ; --- Scan backward in R1 for line start ---
        LHLD    GCLR1E
        DCX     H               ; HL = last byte in R1
GCLBLP: MOV     A,M
        CPI     LF
        JZ      GCLBF           ; found LF
        ; Check if HL == base
        LDA     GCLBAS+1
        CMP     H
        JNZ     GCLBN
        LDA     GCLBAS
        CMP     L
        JZ      GCLATB          ; at base, line starts here
GCLBN:  DCX     H
        JMP     GCLBLP

GCLBF:  INX     H               ; past the LF = line start
GCLATB: ; HL = line start in R1
        ; --- Copy R1 portion (before cursor) into GGLBUF ---
        LXI     D,GGLBUF
        MVI     B,0             ; B = char count
GCLR1C: ; Check if HL reached R1 end
        LDA     GCLR1E+1
        CMP     H
        JNZ     GCLR1G
        LDA     GCLR1E
        CMP     L
        JZ      GCLNR1          ; R1 exhausted, continue R2
GCLR1G: MOV     A,M
        CPI     CR
        JZ      GCLR1N          ; skip CR
        CPI     LF
        JZ      GCLCPD          ; unexpected LF = end of line
        MOV     A,B
        CPI     MAXCOLS
        JZ      GCLCPD          ; column limit
        MOV     A,M
        STAX    D
        INX     D
        INR     B
GCLR1N: INX     H
        JMP     GCLR1C

GCLNR0: ; R1 empty (GAPBG = 0): init GGLBUF ptr and count
        LXI     D,GGLBUF
        MVI     B,0
GCLNR1: ; --- Copy R2 portion (after cursor) into GGLBUF ---
        LHLD    GCLR2S
GCLR2C: ; Check if HL reached R2 end
        LDA     GCLR2E+1
        CMP     H
        JNZ     GCLR2G
        LDA     GCLR2E
        CMP     L
        JZ      GCLCPD          ; R2 exhausted
GCLR2G: MOV     A,M
        CPI     CR
        JZ      GCLR2N          ; skip CR
        CPI     LF
        JZ      GCLCPD          ; LF = end of line
        MOV     A,B
        CPI     MAXCOLS
        JZ      GCLCPD          ; column limit
        MOV     A,M
        STAX    D
        INX     D
        INR     B
GCLR2N: INX     H
        JMP     GCLR2C

GCLCPD: ; NUL-terminate
        XRA     A
        STAX    D
        MOV     A,B             ; A = true line length
        LXI     H,GGLBUF
        ; Set NZ to indicate line exists without corrupting A.
        ; B is the char count; if 0 (empty line) we still need NZ.
        ; Use: compare A with FFH — only equal if length is 255
        ; (max line), so NZ for all practical lengths 0-254.
        ; Actually simpler: INR B / DCR B sets NZ if B was > 0,
        ; Z if B was 0. But we need NZ even when B=0 (empty line).
        ; Simplest: just save A, force NZ, restore A via MOV.
        MOV     C,A             ; save true length in C
        MVI     A,1             ; force NZ (A nonzero)
        ORA     A               ; set NZ flag
        MOV     A,C             ; restore true length (MOV doesn't affect flags)
        RET

;=============================================================
; GBCNTLN - Count lines in current buffer.
; Uses a cached value when valid; falls back to a fast
; direct memory scan (not GBLOGRD) when cache is invalid.
; Entry:  (none)
; Exit:   HL = line count (number of LF chars + 1)
;=============================================================
GBCNTLN:
        LDA     GLNVAL
        ORA     A
        JZ      GCNFULL         ; cache invalid, do full scan
        ; Return cached value + virtual lines
        LHLD    GLNCNT
        JMP     GCNVRT          ; add VBFLN + VAFLN
GCNFULL:
        ; --- Fast direct memory scan ---
        ; Region 1: base .. base+GAPBG (pre-gap text)
        CALL    GBBASE
        XCHG
        SHLD    GCNBAS
        CALL    GBGAPBG
        XCHG                    ; DE = GAPBG
        LHLD    GCNBAS
        DAD     D
        SHLD    GCNR1E          ; R1 end = base + GAPBG
        ; Region 2: base+GAPEN .. base+BSIZE (post-gap text)
        CALL    GBGAPEN
        XCHG
        LHLD    GCNBAS
        DAD     D
        SHLD    GCNR2S          ; R2 start = base + GAPEN
        CALL    GBBSIZ          ; DE = BSIZE
        LHLD    GCNBAS
        DAD     D
        SHLD    GCNR2E          ; R2 end = base + BSIZE
        ; Scan R1 counting LFs
        LXI     B,1             ; line count starts at 1
        LHLD    GCNR1E
        XCHG                    ; DE = R1 end
        LHLD    GCNBAS          ; HL = R1 start
GCN1LP: MOV     A,H
        CMP     D
        JNZ     GCN1NE
        MOV     A,L
        CMP     E
        JZ      GCN1DN          ; end of R1
GCN1NE: MOV     A,M
        INX     H
        CPI     LF
        JNZ     GCN1LP
        INX     B
        JMP     GCN1LP
GCN1DN: ; Scan R2
        LHLD    GCNR2E
        XCHG                    ; DE = R2 end
        LHLD    GCNR2S          ; HL = R2 start
GCN2LP: MOV     A,H
        CMP     D
        JNZ     GCN2NE
        MOV     A,L
        CMP     E
        JZ      GCNDN           ; end of R2
GCN2NE: MOV     A,M
        INX     H
        CPI     LF
        JNZ     GCN2LP
        INX     B
        JMP     GCN2LP
GCNDN:  MOV     H,B
        MOV     L,C             ; HL = line count
        ; Cache result
        SHLD    GLNCNT
        MVI     A,1
        STA     GLNVAL
        ; Add virtual line counts
GCNVRT:
        ; HL = buffer line count; add VBFLN + VAFLN if virtual
        LDA     VIMODE
        ORA     A
        RZ                      ; normal mode: return raw count
        XCHG                    ; DE = buffer lines
        LHLD    VBFLN
        DAD     D               ; HL = buffer_lines + VBFLN
        XCHG                    ; DE = partial sum
        LHLD    VAFLN
        DAD     D               ; HL = buffer_lines + VBFLN + VAFLN
        RET

;=============================================================
; GBFNDLN - Find logical offset of line N by direct memory scan.
; Scans buffer memory directly (not through GBLOGRD) for speed.
; Entry:  HL = 0-based line number
; Exit:   HL = logical offset of line start
;         NZ = found; Z = past end of text (or buffer empty)
; Clobbers: AF BC DE
;=============================================================
GBFNDLN:
        MOV     A,H
        ORA     L
        JZ      GFLN0           ; line 0 = offset 0

        SHLD    GFLCNT          ; save target line count

        ; --- Compute physical region boundaries ---
        ; Region 1 (pre-gap): base .. base+GAPBG-1
        ; Region 2 (post-gap): base+GAPEN .. end
        CALL    GBBASE          ; DE = base
        XCHG
        SHLD    GFLBAS          ; save base

        CALL    GBBASE          ; DE = base
        CALL    GBGAPBG         ; HL = GAPBG
        SHLD    GFLGBG          ; save GAPBG
        DAD     D               ; HL = base + GAPBG
        SHLD    GFLR1E          ; R1 end (exclusive)

        CALL    GBBASE          ; DE = base
        CALL    GBGAPEN         ; HL = GAPEN
        SHLD    GFLGPE          ; save GAPEN
        DAD     D               ; HL = base + GAPEN
        SHLD    GFLR2S          ; R2 start

        ; R2 end = R2 start + (TXEND - GAPBG)
        CALL    GBTXEND         ; HL = TXEND
        PUSH    H
        CALL    GBGAPBG         ; HL = GAPBG
        POP     D               ; DE = TXEND
        MOV     A,E
        SUB     L
        MOV     E,A
        MOV     A,D
        SBB     H
        MOV     D,A             ; DE = TXEND - GAPBG = post-gap text len
        LHLD    GFLR2S
        DAD     D               ; HL = R2 end
        SHLD    GFLR2E

        ; --- Scan Region 1: HL=ptr, DE=end, BC=lines ---
        LHLD    GFLCNT
        MOV     B,H
        MOV     C,L             ; BC = lines to skip
        LHLD    GFLR1E
        XCHG                    ; DE = R1 end
        LHLD    GFLBAS          ; HL = R1 start (= base)

GFL1LP: MOV     A,H
        CMP     D
        JNZ     GFL1NE
        MOV     A,L
        CMP     E
        JZ      GFL1DN          ; reached end of region 1
GFL1NE: MOV     A,M             ; read byte
        INX     H               ; advance pointer
        CPI     LF
        JNZ     GFL1LP
        DCX     B               ; found LF, count down
        MOV     A,B
        ORA     C
        JNZ     GFL1LP          ; more lines to skip
        ; --- Found in region 1: convert to logical offset ---
        ; logical offset = HL - base
        XCHG                    ; DE = physical ptr
        LHLD    GFLBAS
        MOV     A,E
        SUB     L
        MOV     L,A
        MOV     A,D
        SBB     H
        MOV     H,A             ; HL = logical offset
        ORI     1               ; NZ = found
        RET

GFL1DN: ; Region 1 exhausted, continue with region 2
        LHLD    GFLR2E
        XCHG                    ; DE = R2 end
        LHLD    GFLR2S          ; HL = R2 start

GFL2LP: MOV     A,H
        CMP     D
        JNZ     GFL2NE
        MOV     A,L
        CMP     E
        JZ      GFLEOF          ; past end of all text
GFL2NE: MOV     A,M
        INX     H
        CPI     LF
        JNZ     GFL2LP
        DCX     B
        MOV     A,B
        ORA     C
        JNZ     GFL2LP
        ; --- Found in region 2: convert to logical offset ---
        ; logical = (ptr - base) - (GAPEN - GAPBG)
        XCHG                    ; DE = physical ptr
        LHLD    GFLBAS
        MOV     A,E
        SUB     L
        MOV     L,A
        MOV     A,D
        SBB     H
        MOV     H,A             ; HL = ptr - base
        XCHG                    ; DE = ptr - base
        LHLD    GFLGPE          ; HL = GAPEN
        PUSH    D
        XCHG                    ; DE = GAPEN
        LHLD    GFLGBG          ; HL = GAPBG
        MOV     A,E
        SUB     L
        MOV     L,A
        MOV     A,D
        SBB     H
        MOV     H,A             ; HL = gap size
        POP     D               ; DE = ptr - base
        MOV     A,E
        SUB     L
        MOV     L,A
        MOV     A,D
        SBB     H
        MOV     H,A             ; HL = (ptr - base) - gap = logical offset
        ORI     1               ; NZ = found
        RET

GFLEOF: XRA     A               ; Z = past end
        RET

GFLN0:  ; Line 0 starts at logical offset 0
        PUSH    H
        CALL    GBTXEND
        MOV     A,H
        ORA     L
        POP     H
        LXI     H,0
        RZ                      ; empty buffer, Z
        ORI     1               ; NZ = found
        RET

;=============================================================
; GBFNDCS - Find TOPLN logical offset by backward scan from
; cursor position.  Sets up GFL* region boundaries for GBRDLNO.
; Much faster than GBFNDLN for large files because it scans
; at most CSROW lines (~1600 bytes) instead of all text.
; Entry:  (none) - uses CSROW from buffer descriptor
; Exit:   HL = logical offset of TOPLN start
;         NZ = found; Z = buffer empty
; Clobbers: AF BC DE
;=============================================================
GBFNDCS:
        ; --- Compute GFL* region boundaries ---
        CALL    GBBASE          ; DE = base
        XCHG
        SHLD    GFLBAS

        CALL    GBGAPBG         ; HL = GAPBG
        SHLD    GFLGBG
        XCHG                    ; DE = GAPBG
        LHLD    GFLBAS          ; HL = base
        DAD     D               ; HL = base + GAPBG
        SHLD    GFLR1E

        CALL    GBGAPEN         ; HL = GAPEN
        SHLD    GFLGPE
        XCHG                    ; DE = GAPEN
        LHLD    GFLBAS          ; HL = base
        DAD     D               ; HL = base + GAPEN
        SHLD    GFLR2S

        ; R2 end = R2 start + (TXEND - GAPBG)
        CALL    GBTXEND         ; HL = TXEND
        PUSH    H               ; save TXEND for empty check
        XCHG                    ; DE = TXEND
        LHLD    GFLGBG          ; HL = GAPBG
        MOV     A,E
        SUB     L
        MOV     E,A
        MOV     A,D
        SBB     H
        MOV     D,A             ; DE = TXEND - GAPBG = post-gap len
        LHLD    GFLR2S
        DAD     D
        SHLD    GFLR2E

        ; Check if buffer is empty
        POP     H               ; HL = TXEND
        MOV     A,H
        ORA     L
        JZ      GFCSZ           ; TXEND=0, buffer empty

        ; --- Get CSROW and compute LFs to count ---
        ; We need CSROW+1 LFs because the CSROW-th LF backward
        ; ends the TOPLN line itself; the (CSROW+1)-th ends the
        ; line BEFORE TOPLN, so INX H gives TOPLN start.
        LHLD    CURBDP
        MVI     A,BD_CSROW
        ADD     L
        MOV     L,A
        MVI     A,0
        ADC     H
        MOV     H,A
        MOV     A,M             ; A = CSROW
        INR     A               ; A = CSROW + 1
        MOV     C,A             ; C = LFs to find

        ; Safety: GAPBG must be > 0 for backward scan
        LHLD    GFLGBG
        MOV     A,H
        ORA     L
        JZ      GFCS0           ; R1 empty, TOPLN at offset 0

        ; --- Backward scan in R1 for C LFs ---
        LHLD    GFLR1E
        DCX     H               ; HL = last pre-gap byte

GFCSLP: MOV     A,M
        CPI     LF
        JNZ     GFCSN1
        DCR     C
        JZ      GFCSFD          ; found all LFs

GFCSN1: LDA     GFLBAS+1
        CMP     H
        JNZ     GFCSOK
        LDA     GFLBAS
        CMP     L
        JZ      GFCS0           ; reached buffer start
GFCSOK: DCX     H
        JMP     GFCSLP

GFCSFD: ; HL = ptr at the last LF; TOPLN starts after it
        INX     H
        ; Convert to logical offset: HL - base
        XCHG                    ; DE = physical ptr
        LHLD    GFLBAS
        MOV     A,E
        SUB     L
        MOV     L,A
        MOV     A,D
        SBB     H
        MOV     H,A             ; HL = logical offset
        ORI     1               ; NZ
        RET

GFCS0:  ; TOPLN starts at offset 0
        LXI     H,0
        ORI     1               ; NZ
        RET

GFCSZ:  ; Buffer empty
        LXI     H,0
        XRA     A               ; Z
        RET

;=============================================================
; GBRDLNO - Read one line at a given logical offset into GGLBUF.
; Fast version: uses direct memory access via GFL* region
; boundaries computed by GBFNDCS or GBFNDLN.
; Entry:  HL = logical offset of line start
; Exit:   HL = logical offset of NEXT line start (past LF)
;         DE = GGLBUF (NUL-terminated text)
;         A  = line length
;         NZ = line exists; Z = offset was past end of text
; Clobbers: AF BC
;=============================================================
GBRDLNO:
        ; Check if offset is past end
        PUSH    H
        CALL    GBTXEND         ; HL = TXEND
        MOV     B,H
        MOV     C,L             ; BC = TXEND
        POP     H               ; HL = offset
        MOV     A,L
        SUB     C
        MOV     A,H
        SBB     B               ; offset - TXEND
        JNC     GRLEOF          ; offset >= TXEND

        ; Determine which region: offset < GAPBG -> R1, else R2
        XCHG                    ; DE = logical offset
        LHLD    GFLGBG          ; HL = GAPBG
        MOV     A,E
        SUB     L
        MOV     A,D
        SBB     H               ; carry if offset < GAPBG
        JC      GRLIR1

        ; --- Start in Region 2 ---
        ; physical = base + offset + GAPEN - GAPBG
        PUSH    D               ; save offset
        LHLD    GFLGPE          ; HL = GAPEN
        POP     D               ; DE = offset
        DAD     D               ; HL = GAPEN + offset
        XCHG                    ; DE = GAPEN + offset
        LHLD    GFLGBG          ; HL = GAPBG
        MOV     A,E
        SUB     L
        MOV     E,A
        MOV     A,D
        SBB     H
        MOV     D,A             ; DE = offset + GAPEN - GAPBG
        LHLD    GFLBAS
        DAD     D               ; HL = physical address in R2
        LXI     D,GGLBUF
        MVI     B,0
        JMP     GRL2LP

GRLIR1: ; --- Start in Region 1 ---
        ; physical = base + offset
        LHLD    GFLBAS
        DAD     D               ; HL = base + offset
        LXI     D,GGLBUF
        MVI     B,0
        ; fall through to R1 loop

        ; --- Region 1 reading loop ---
        ; HL = read ptr, DE = output ptr, B = col count
GRL1LP: LDA     GFLR1E+1
        CMP     H
        JNZ     GRL1NE
        LDA     GFLR1E
        CMP     L
        JZ      GRL1DN          ; R1 exhausted, switch to R2
GRL1NE: MOV     A,B
        CPI     MAXCOLS
        JNC     GRL1SK          ; past column limit
        MOV     A,M             ; read byte
        INX     H               ; advance read ptr
        CPI     LF
        JZ      GRL1LF
        CPI     CR
        JZ      GRL1LP          ; skip CR
        STAX    D               ; store in GGLBUF
        INX     D
        INR     B               ; col++
        JMP     GRL1LP

GRL1SK: ; Column limit in R1; scan for LF without storing
        LDA     GFLR1E+1
        CMP     H
        JNZ     GRS1NE
        LDA     GFLR1E
        CMP     L
        JZ      GRS1DN          ; R1 exhausted during skip
GRS1NE: MOV     A,M
        INX     H
        CPI     LF
        JZ      GRL1LF
        JMP     GRL1SK

GRS1DN: ; R1 skip exhausted, continue skip in R2
        LHLD    GFLR2S

GRL2SK: ; Column limit in R2; scan for LF
        LDA     GFLR2E+1
        CMP     H
        JNZ     GRS2NE
        LDA     GFLR2E
        CMP     L
        JZ      GRLDN2          ; end of text
GRS2NE: MOV     A,M
        INX     H
        CPI     LF
        JZ      GRL2LF
        JMP     GRL2SK

GRL1DN: ; R1 data exhausted, switch to R2
        LHLD    GFLR2S

        ; --- Region 2 reading loop ---
GRL2LP: LDA     GFLR2E+1
        CMP     H
        JNZ     GRL2NE
        LDA     GFLR2E
        CMP     L
        JZ      GRLDN2          ; end of text
GRL2NE: MOV     A,B
        CPI     MAXCOLS
        JNC     GRL2SK          ; past column limit
        MOV     A,M             ; read byte
        INX     H
        CPI     LF
        JZ      GRL2LF
        CPI     CR
        JZ      GRL2LP          ; skip CR
        STAX    D               ; store in GGLBUF
        INX     D
        INR     B               ; col++
        JMP     GRL2LP

        ; --- Found LF in Region 1 ---
GRL1LF: ; HL = ptr past LF (physical, in R1)
        ; logical offset = HL - base
        XRA     A
        STAX    D               ; NUL-terminate output
        XCHG                    ; DE = physical ptr
        LHLD    GFLBAS
        MOV     A,E
        SUB     L
        MOV     L,A
        MOV     A,D
        SBB     H
        MOV     H,A             ; HL = logical offset
        MOV     A,B             ; A = line length
        LXI     D,GGLBUF
        ORI     1               ; NZ
        RET

        ; --- Found LF in Region 2 / end of text ---
GRL2LF:
GRLDN2: ; HL = ptr past LF or at R2 end (physical, in R2)
        ; logical = (HL - base) - (GAPEN - GAPBG)
        XRA     A
        STAX    D               ; NUL-terminate output
        PUSH    B               ; save col count
        XCHG                    ; DE = physical ptr
        LHLD    GFLBAS
        MOV     A,E
        SUB     L
        MOV     L,A
        MOV     A,D
        SBB     H
        MOV     H,A             ; HL = ptr - base
        PUSH    H               ; save ptr-base
        LHLD    GFLGPE          ; HL = GAPEN
        XCHG                    ; DE = GAPEN
        LHLD    GFLGBG          ; HL = GAPBG
        MOV     A,E
        SUB     L
        MOV     L,A
        MOV     A,D
        SBB     H
        MOV     H,A             ; HL = gap size
        POP     D               ; DE = ptr - base
        MOV     A,E
        SUB     L
        MOV     L,A
        MOV     A,D
        SBB     H
        MOV     H,A             ; HL = logical offset
        POP     B               ; restore col count
        MOV     A,B             ; A = line length
        LXI     D,GGLBUF
        ORI     1               ; NZ
        RET

GRLEOF: ; Past end of text
        LXI     D,GGLBUF
        XRA     A
        STAX    D               ; empty NUL-terminated string
        ; A=0, Z=1
        RET

;=============================================================
; GBLOGRD - Read logical text byte at offset HL.
; Entry:  HL = logical offset into text
; Exit:   A  = byte; Z set if past end of text
;         HL unchanged; DE clobbered
;=============================================================
GBLOGRD:
        SHLD    GBLOFF          ; save logical offset; callers need HL unchanged on return
        PUSH    H
        CALL    GBTXEND         ; HL = TXEND
        MOV     A,L
        ORA     H
        POP     H
        JZ      GBLRZ           ; empty buffer
        ; Compare offset HL with TXEND: is offset >= TXEND?
        PUSH    H
        CALL    GBTXEND         ; HL = TXEND
        POP     D               ; DE = offset
        MOV     A,E
        SUB     L
        MOV     A,D
        SBB     H               ; offset - TXEND
        JNC     GBLRZ           ; offset >= TXEND (no borrow = past end)
        ; Adjust for gap: is offset < GAPBG?
        PUSH    D               ; save offset
        CALL    GBGAPBG         ; HL = GAPBG
        POP     D               ; DE = offset
        MOV     A,E
        SUB     L
        MOV     A,D
        SBB     H               ; offset - GAPBG
        JC      GBLRDI          ; offset < GAPBG (borrow = before gap): direct
        ; offset >= GAPBG: logical = physical + gapsize
        PUSH    D
        CALL    GBGAPEN
        MOV     B,H
        MOV     C,L             ; BC = GAPEN
        CALL    GBGAPBG
        ; gapsize = GAPEN - GAPBG
        MOV     A,C
        SUB     L
        MOV     C,A
        MOV     A,B
        SBB     H
        MOV     B,A             ; BC = gap size
        POP     D               ; DE = logical offset
        MOV     A,E
        ADD     C
        MOV     E,A
        MOV     A,D
        ADC     B
        MOV     D,A             ; DE = physical offset
GBLRDI: ; DE = physical offset; compute abs address = base + physical
        PUSH    D               ; save physical offset (GBBASE clobbers DE)
        CALL    GBBASE          ; DE = buffer base, HL clobbered to CURBDP+1
        POP     H               ; HL = physical offset
        DAD     D               ; HL = buffer_base + physical_offset = abs address
        MOV     A,M
        ORA     A
        JZ      GBLRZ           ; NUL treated as end-of-text
        MOV     B,A             ; save byte
        LHLD    GBLOFF          ; restore caller's logical offset into HL
        MOV     A,B             ; A = byte
        ORA     A               ; Z=0 (byte exists)
        RET
GBLRZ:  LHLD    GBLOFF          ; restore caller's logical offset into HL
        XRA     A               ; A=0, Z=1 (past end)
        RET

;=============================================================
; Helper: GBISWS - test if A is a word separator.
; Exit:  Z=1 if whitespace/punctuation; Z=0 if word char
;=============================================================
GBISWS:
        CPI     ' '
        RZ
        CPI     TAB
        RZ
        CPI     CR
        RZ
        CPI     LF
        RZ
        CPI     ','
        RZ
        CPI     '.'
        RZ
        CPI     ';'
        RZ
        CPI     ':'
        RZ
        ORI     1               ; force NZ
        RET

;=============================================================
; GBCURLNL - Return length of text before cursor on line.
; Entry:  (none)
; Exit:   HL = column count (chars since last LF)
;=============================================================
GBCURLNL:
        CALL    GBCSOFF         ; HL = cursor offset
        MOV     B,H
        MOV     C,L             ; BC = offset
        LXI     H,0             ; HL = count
GCLL:   MOV     A,B
        ORA     C
        RZ
        ; Read byte at BC-1
        DCX     B
        PUSH    B               ; save offset (GBLOGRD clobbers BC)
        PUSH    H               ; save count
        MOV     H,B
        MOV     L,C
        CALL    GBLOGRD
        POP     H               ; restore count
        POP     B               ; restore offset
        CPI     LF
        RZ                      ; found previous newline
        CPI     CR
        JZ      GCLL            ; skip CR (invisible, not a column)
        INX     H
        JMP     GCLL

;=============================================================
; Descriptor field accessors - read/write via CURBDP
; Convention: field loaded into HL, or stored from HL
;=============================================================

; GBBASE: DE = buffer base address
GBBASE:
        LHLD    CURBDP
        MVI     A,BD_BSTAR
        ADD     L
        MOV     L,A
        MVI     A,0
        ADC     H
        MOV     H,A
        MOV     E,M
        INX     H
        MOV     D,M
        RET

; GBBSIZ: DE = buffer size
GBBSIZ:
        LHLD    CURBDP
        MVI     A,BD_BSIZE
        ADD     L
        MOV     L,A
        MVI     A,0
        ADC     H
        MOV     H,A
        MOV     E,M
        INX     H
        MOV     D,M
        RET

; GBGAPBG: HL = GAPBG
GBGAPBG:
        LHLD    CURBDP
        MVI     A,BD_GAPBG
        ADD     L
        MOV     L,A
        MVI     A,0
        ADC     H
        MOV     H,A
        MOV     A,M
        INX     H
        MOV     H,M
        MOV     L,A
        RET

; GBGAPEN: HL = GAPEN
GBGAPEN:
        LHLD    CURBDP
        MVI     A,BD_GAPEN
        ADD     L
        MOV     L,A
        MVI     A,0
        ADC     H
        MOV     H,A
        MOV     A,M
        INX     H
        MOV     H,M
        MOV     L,A
        RET

; GBTXEND: HL = TXEND
GBTXEND:
        LHLD    CURBDP
        MVI     A,BD_TXEND
        ADD     L
        MOV     L,A
        MVI     A,0
        ADC     H
        MOV     H,A
        MOV     A,M
        INX     H
        MOV     H,M
        MOV     L,A
        RET

; GBTOPLN: HL = TOPLN
GBTOPLN:
        LHLD    CURBDP
        MVI     A,BD_TOPLN
        ADD     L
        MOV     L,A
        MVI     A,0
        ADC     H
        MOV     H,A
        MOV     A,M
        INX     H
        MOV     H,M
        MOV     L,A
        RET

; GBCSROW: HL = CSROW (1 byte, zero-extended)
GBCSROW:
        LHLD    CURBDP
        MVI     A,BD_CSROW
        ADD     L
        MOV     L,A
        MVI     A,0
        ADC     H
        MOV     H,A
        MOV     L,M
        MVI     H,0
        RET

; GBCSCOL: HL = CSCOL (1 byte, zero-extended)
GBCSCOL:
        LHLD    CURBDP
        MVI     A,BD_CSCOL
        ADD     L
        MOV     L,A
        MVI     A,0
        ADC     H
        MOV     H,A
        MOV     L,M
        MVI     H,0
        RET

; GBCSOFF: HL = CSOFF
GBCSOFF:
        LHLD    CURBDP
        MVI     A,BD_CSOFF
        ADD     L
        MOV     L,A
        MVI     A,0
        ADC     H
        MOV     H,A
        MOV     A,M
        INX     H
        MOV     H,M
        MOV     L,A
        RET

; GBGAPLN: HL = gap size (GAPEN - GAPBG)
GBGAPLN:
        CALL    GBGAPEN
        MOV     B,H
        MOV     C,L             ; BC = GAPEN
        CALL    GBGAPBG         ; HL = GAPBG
        MOV     A,C
        SUB     L
        MOV     L,A
        MOV     A,B
        SBB     H
        MOV     H,A             ; HL = GAPEN - GAPBG
        RET

; GBSETGAPBG: store HL into GAPBG field
GBSETGAPBG:
        PUSH    H
        LHLD    CURBDP
        MVI     A,BD_GAPBG
        ADD     L
        MOV     L,A
        MVI     A,0
        ADC     H
        MOV     H,A
        POP     D
        MOV     M,E
        INX     H
        MOV     M,D
        RET

; GBSETGAPEN: store HL into GAPEN field
GBSETGAPEN:
        PUSH    H
        LHLD    CURBDP
        MVI     A,BD_GAPEN
        ADD     L
        MOV     L,A
        MVI     A,0
        ADC     H
        MOV     H,A
        POP     D
        MOV     M,E
        INX     H
        MOV     M,D
        RET

; GBSETTXEND: store HL into TXEND field
GBSETTXEND:
        PUSH    H
        LHLD    CURBDP
        MVI     A,BD_TXEND
        ADD     L
        MOV     L,A
        MVI     A,0
        ADC     H
        MOV     H,A
        POP     D
        MOV     M,E
        INX     H
        MOV     M,D
        RET

; GBSETTOPLN: store HL into TOPLN field
GBSETTOPLN:
        PUSH    H
        LHLD    CURBDP
        MVI     A,BD_TOPLN
        ADD     L
        MOV     L,A
        MVI     A,0
        ADC     H
        MOV     H,A
        POP     D
        MOV     M,E
        INX     H
        MOV     M,D
        RET

; GBSETCSROW: store L into CSROW field
GBSETCSROW:
        PUSH    H
        LHLD    CURBDP
        MVI     A,BD_CSROW
        ADD     L
        MOV     L,A
        MVI     A,0
        ADC     H
        MOV     H,A
        POP     D
        MOV     M,E             ; store low byte
        RET

; GBSETCSCOL: store L into CSCOL field
GBSETCSCOL:
        PUSH    H
        LHLD    CURBDP
        MVI     A,BD_CSCOL
        ADD     L
        MOV     L,A
        MVI     A,0
        ADC     H
        MOV     H,A
        POP     D
        MOV     M,E
        RET

; GBSETCSOFF: store HL into CSOFF field
GBSETCSOFF:
        PUSH    H
        LHLD    CURBDP
        MVI     A,BD_CSOFF
        ADD     L
        MOV     L,A
        MVI     A,0
        ADC     H
        MOV     H,A
        POP     D
        MOV     M,E
        INX     H
        MOV     M,D
        RET

; GBSETMOD: mark buffer as modified
GBSETMOD:
        LHLD    CURBDP
        MVI     A,BD_MODIF
        ADD     L
        MOV     L,A
        MVI     A,0
        ADC     H
        MOV     H,A
        MVI     M,1
        RET

;=============================================================
; GBJLCHK - Check if joining two lines exceeds MAXCOLS.
; Called before deleting a LF that separates two lines.
; Entry: HL = left scan start (physical addr, last byte
;             of left line or CR before LF)
;        DE = right scan start (physical addr, first byte
;             of right line after the LF)
; Exit:  A=0 ok to join, A=FFH combined too long
;        All regs clobbered
;=============================================================
GBJLCHK:
        SHLD    GJKLPTR         ; left scan pointer
        XCHG
        SHLD    GJKRPTR         ; right scan pointer
        ; Get buffer physical bounds
        CALL    GBBASE          ; DE = base
        XCHG
        SHLD    GJKBAS
        CALL    GBBSIZ          ; DE = bsize
        LHLD    GJKBAS
        DAD     D
        SHLD    GJKBEND         ; base + bsize

        ; --- Right side: scan forward to next LF or end ---
        XRA     A
        STA     GJKRCNT         ; right count = 0
        LHLD    GJKRPTR
GJKRLP: XCHG                    ; DE = ptr
        LHLD    GJKBEND         ; HL = end
        MOV     A,E
        SUB     L
        MOV     A,D
        SBB     H               ; ptr - end
        JNC     GJKRDN          ; ptr >= end, done
        LDAX    D               ; A = byte at ptr
        INX     D               ; advance ptr
        CPI     LF
        JZ      GJKRDN
        CPI     CR
        JZ      GJKRL2
        ; visible char
        LXI     H,GJKRCNT
        INR     M
GJKRL2: XCHG                    ; HL = advanced ptr
        JMP     GJKRLP
GJKRDN:
        ; --- Left side: scan backward to prev LF or base ---
        XRA     A
        STA     GJKLCNT         ; left count = 0
        LHLD    GJKLPTR
        XCHG                    ; DE = ptr
        LHLD    GJKBAS
        MOV     A,E
        SUB     L
        MOV     A,D
        SBB     H
        JC      GJKLDN          ; ptr < base, left empty
        XCHG                    ; HL = ptr
        ; Skip initial CR if present
        MOV     A,M
        CPI     CR
        JNZ     GJKLLP
        DCX     H               ; skip CR
        ; Re-check >= base
        XCHG
        LHLD    GJKBAS
        MOV     A,E
        SUB     L
        MOV     A,D
        SBB     H
        JC      GJKLDN
        XCHG
GJKLLP: ; Check ptr >= base
        XCHG
        LHLD    GJKBAS
        MOV     A,E
        SUB     L
        MOV     A,D
        SBB     H
        JC      GJKLDN          ; below base
        XCHG                    ; HL = ptr
        MOV     A,M
        DCX     H               ; move backward
        CPI     LF
        JZ      GJKLDN
        CPI     CR
        JZ      GJKLLP
        PUSH    H
        LXI     H,GJKLCNT
        INR     M
        POP     H
        JMP     GJKLLP
GJKLDN:
        ; Check combined length
        LDA     GJKRCNT
        MOV     B,A
        LDA     GJKLCNT
        ADD     B               ; A = left + right
        JC      GJKFAL          ; overflow > 255 = MAXCOLS
        XRA     A               ; ok
        RET
GJKFAL: MVI     A,0FFH
        RET

;=============================================================
; DATA SEGMENT
;=============================================================
        DSEG
GBTMP:  DB      0               ; temporary char storage
GBLOFF: DW      0               ; GBLOGRD: saved logical offset (HL on entry)
GGLBUF: DS      MAXCOLS+1       ; GBGETLN: flat line copy buffer (NUL terminated)

; GBFNDLN working variables
GFLCNT: DW      0               ; target line counter
GFLBAS: DW      0               ; buffer base address
GFLGBG: DW      0               ; saved GAPBG (for offset calc)
GFLGPE: DW      0               ; saved GAPEN (for offset calc)
GFLR1E: DW      0               ; region 1 end (base + GAPBG)
GFLR2S: DW      0               ; region 2 start (base + GAPEN)
GFLR2E: DW      0               ; region 2 end

; Bulk page up/down working variables
GPGBAS: DW      0               ; buffer base address
GPGCNT: DW      0               ; byte count for bulk copy
GPGLFS: DB      0               ; LFs found during scan

; GBMVRT/GBMVLT cached base address
GRTBAS: DW      0               ; cached GBBASE for GBMVRT
GLTBAS: DW      0               ; cached GBBASE for GBMVLT

; GBGOTOL working variables
GGTLIN: DW      0               ; target line number (1-based)
GGTCNT: DW      0               ; LFs remaining to find
GGTGPE: DW      0               ; saved GAPEN (before bulk copy)

; Line count cache variables
GLNCNT: DW      0               ; cached total line count
GLNVAL: DB      0               ; 1 = GLNCNT is valid, 0 = invalid

; GBCURLN working variables
GCLBAS: DW      0               ; buffer base address
GCLR1E: DW      0               ; R1 end (base + GAPBG)
GCLR2S: DW      0               ; R2 start (base + GAPEN)
GCLR2E: DW      0               ; R2 end

; GBCNTLN fast scan working variables
GCNBAS: DW      0               ; buffer base address
GCNR1E: DW      0               ; region 1 end (base + GAPBG)
GCNR2S: DW      0               ; region 2 start (base + GAPEN)
GCNR2E: DW      0               ; region 2 end (base + BSIZE)

; Virtual buffer temp variables
GPGTMP: DW      0               ; temp for VIGOTO target calculation
GPGTM2: DB      0               ; saved VIMODE during GBGOTOL

; GBJLCHK working variables
GJKLPTR: DW     0               ; left scan pointer
GJKRPTR: DW     0               ; right scan pointer
GJKBAS: DW      0               ; buffer base address
GJKBEND: DW     0               ; buffer physical end
GJKRCNT: DB     0               ; right side char count
GJKLCNT: DB     0               ; left side char count

        END

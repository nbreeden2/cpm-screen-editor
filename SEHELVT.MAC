;============================================================
; FILE:    SEHELVT.MAC
; PROJECT: SEDIT - Screen Editor for CP/M 2.2
; VERSION: 1.0
; DATE:    2026-04-14
; AUTHOR:  Claude Code and RetroTechReboot
;------------------------------------------------------------
; DESCRIPTION:
;   VT52-compatible help screen display. Drop-in replacement
;   for SEHELP.MAC. Uses VT52 escape sequences:
;     Clear screen: ESC H ESC J
;     Clear to EOL: ESC K
;     Reverse video: ESC p / ESC q
;
;   MUST be linked LAST -- contains BMDATEND EQU $.
;
;   Build: M80 =SEHELVT
;   Link:  (replace SEHELP with SEHELVT at end of link cmd)
;============================================================

;--- Imports ----------------------------------------------
        EXTRN   CURGOTO
        EXTRN   OUTSTR
        EXTRN   OUTCHAR
        EXTRN   RSTAT

;--- Exports ----------------------------------------------
        PUBLIC  HLPSHOW
        PUBLIC  BMDATEND

;=============================================================
        INCLUDE SEDIT.INC

        CSEG

HLPSHOW:
        ; Clear screen
        LXI     D,HLPCLR
        CALL    OUTSTR

        ; Draw header (row 1, reverse video)
        MVI     B,1
        MVI     C,1
        CALL    CURGOTO
        LXI     D,HLPHDR
        CALL    OUTSTR

        ; Draw help lines (rows 3-23, 2 columns)
        XRA     A
        STA     HLPIDX

HLPLP:  LDA     HLPIDX
        CPI     HLPLINES
        JNC     HLPWAIT

        ; Position left column (row = index + 3, col = 1)
        ADI     3
        MOV     B,A
        MVI     C,1
        CALL    CURGOTO

        ; Get left text pointer from table
        LDA     HLPIDX
        MOV     L,A
        MVI     H,0
        DAD     H
        LXI     D,HLPLTBL
        DAD     D
        MOV     E,M
        INX     H
        MOV     D,M
        CALL    OUTSTR

        ; Position right column (row = index + 3, col = 41)
        LDA     HLPIDX
        ADI     3
        MOV     B,A
        MVI     C,41
        CALL    CURGOTO

        ; Get right text pointer from table
        LDA     HLPIDX
        MOV     L,A
        MVI     H,0
        DAD     H
        LXI     D,HLPRTBL
        DAD     D
        MOV     E,M
        INX     H
        MOV     D,M
        CALL    OUTSTR

        ; Increment index
        LDA     HLPIDX
        INR     A
        STA     HLPIDX
        JMP     HLPLP

HLPWAIT:
        ; Footer prompt at bottom row
        LDA     RSTAT
        MOV     B,A
        MVI     C,1
        CALL    CURGOTO
        LXI     D,HLPFTR
        CALL    OUTSTR

        ; Drain any buffered keyboard input
HLPDRN: MVI     E,0FFH
        MVI     C,BF_RAWIO
        CALL    BDOS
        ORA     A
        JNZ     HLPDRN

        ; Wait for a fresh keypress
HLPKEY: MVI     E,0FFH
        MVI     C,BF_RAWIO
        CALL    BDOS
        ORA     A
        JZ      HLPKEY

        ; Clear the footer line before returning
        LDA     RSTAT
        MOV     B,A
        MVI     C,1
        CALL    CURGOTO
        LXI     D,HLPCEL
        CALL    OUTSTR
        ; Reset attribute
        LXI     D,HLPNRM
        JMP     OUTSTR

;=============================================================
; String constants — VT52 escape sequences
;=============================================================

HLPCLR:  DB     ESC,'H',ESC,'J','$'            ; home + erase to end
HLPCEL:  DB     ESC,'K','$'                    ; erase to end of line
HLPNRM:  DB     ESC,'q','$'                    ; reverse video off
HLPHDR:  DB     ESC,'p'                        ; reverse video on
         DB     ' SEDIT v1.25 Key Reference'
         DB     '                              '
         DB     ESC,'q','$'                    ; reverse video off
HLPFTR:  DB     ESC,'p'                        ; reverse video on
         DB     ' Press any key to return...   '
         DB     '                              '
         DB     ESC,'q','$'                    ; reverse video off

; Left column lines (40 chars max each, $-terminated)
HLL01:  DB  '^E   Cursor up             $'
HLL02:  DB  '^X   Cursor down           $'
HLL03:  DB  '^S   Cursor left           $'
HLL04:  DB  '^D   Cursor right          $'
HLL05:  DB  '^A   Word left              $'
HLL06:  DB  '^F   Word right             $'
HLL07:  DB  '^R   Page up               $'
HLL08:  DB  '^C   Page down             $'
HLL09:  DB  '^W   Scroll up             $'
HLL10:  DB  '^Z   Scroll down           $'
HLL11:  DB  '^QS  Line start            $'
HLL12:  DB  '^QD  Line end              $'
HLL13:  DB  '^QR  File top              $'
HLL14:  DB  '^QC  File end              $'
HLL15:  DB  'Arrows: cursor movement    $'
HLL16:  DB  'Home / End: line start/end $'
HLL17:  DB  'PgUp / PgDn: page scroll   $'
HLL18:  DB  '                           $'
HLL19:  DB  '^V   Toggle insert/ovr     $'
HLL20:  DB  '^I   Insert tab            $'

; Right column lines
HLR01:  DB  '^G/Del Delete right        $'
HLR02:  DB  '^H   Backspace (del left)  $'
HLR03:  DB  '^T   Delete word right     $'
HLR04:  DB  '^Y   Delete line           $'
HLR05:  DB  '^KB  Block mark start/end  $'
HLR06:  DB  '^KC  Block copy            $'
HLR07:  DB  '^KD  Block delete          $'
HLR08:  DB  '^KP  Paste clipboard       $'
HLR09:  DB  '^QF  Find text             $'
HLR10:  DB  '^QA  Find and replace      $'
HLR11:  DB  '^L   Find next             $'
HLR12:  DB  '^Q[  Jump to match {}/()   $'
HLR13:  DB  '^KS  Save file             $'
HLR14:  DB  '^KX/Q Exit (save)          $'
HLR15:  DB  'ESC  Open menu             $'
HLR16:  DB  'F1   Find next             $'
HLR17:  DB  'F2   Save file             $'
HLR18:  DB  'F3   Block mark            $'
HLR19:  DB  'F4   Menu                  $'
HLR20:  DB  '^M   Insert newline        $'

HLPLINES EQU    20

; Pointer tables in CSEG
HLPLTBL:
        DW      HLL01
        DW      HLL02
        DW      HLL03
        DW      HLL04
        DW      HLL05
        DW      HLL06
        DW      HLL07
        DW      HLL08
        DW      HLL09
        DW      HLL10
        DW      HLL11
        DW      HLL12
        DW      HLL13
        DW      HLL14
        DW      HLL15
        DW      HLL16
        DW      HLL17
        DW      HLL18
        DW      HLL19
        DW      HLL20

HLPRTBL:
        DW      HLR01
        DW      HLR02
        DW      HLR03
        DW      HLR04
        DW      HLR05
        DW      HLR06
        DW      HLR07
        DW      HLR08
        DW      HLR09
        DW      HLR10
        DW      HLR11
        DW      HLR12
        DW      HLR13
        DW      HLR14
        DW      HLR15
        DW      HLR16
        DW      HLR17
        DW      HLR18
        DW      HLR19
        DW      HLR20

;------------------------------------------------------------
; BMDATEND - marks the end of all static data.
; MUST be in CSEG at the very end of the last-linked module.
;------------------------------------------------------------
BMDATEND EQU    $

;=============================================================
; DATA SEGMENT
;=============================================================
        DSEG

HLPIDX: DB      0

        END
